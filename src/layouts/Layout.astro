---
import '../styles/global.css';
import type { CategoryId } from '../data/categories';

interface Props {
	title: string;
	description: string;
	category?: CategoryId;
	ogImage?: string;
	hideLogo?: boolean;
}

const {
	title,
	description,
	category = 'holidays',
	ogImage = '/og-image.png',
	hideLogo = false,
} = Astro.props;

const siteUrl = Astro.site ?? 'https://clockr.co';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const navLinks = [
	{ label: 'Tools', href: '/tools' },
	{ label: 'Countdowns', href: '/countdowns' },
	{ label: 'History', href: '/history' },
	{ label: 'More', href: '/more' },
];

const footerLinks = [
	{ label: 'About', href: '/about' },
	{ label: 'Privacy', href: '/privacy' },
	{ label: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, siteUrl)} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(ogImage, siteUrl)} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700;800;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="w-full border-b border-border">
			<nav>
				<a href="/" class:list={[{ 'home-hide-logo': hideLogo }]}>
					<span class="logo-main">Clock</span><span class="logo-r">r</span>
				</a>

				<ul class="nav-links">
					{
						navLinks.map((link) => (
							<li>
								<a href={link.href}>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>

				<a href="/create-countdown" class="nav-cta">Create Countdown</a>
			</nav>
		</header>

		<main class="flex-1 w-full">
			<slot />
		</main>

		<footer class="w-full border-t border-border mt-auto">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-10 text-center sm:px-6"
			>
				<p class="font-display text-sm font-bold text-text-secondary">
					Your time and date friend
				</p>

				<ul class="flex flex-wrap items-center justify-center gap-6">
					{
						footerLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-text-secondary transition-colors hover:text-text-primary"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>

				<p class="text-sm text-text-secondary">
					&copy; {new Date().getFullYear()} Clockr.co. All rights reserved.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	.logo-main {
		font-size: 36px;
		font-weight: 900;
		letter-spacing: -1.5px;
		background: linear-gradient(135deg, #FF5C4D, #FF9A3C);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-family: 'Outfit', sans-serif;
	}

	.logo-r {
		font-size: 36px;
		font-weight: 900;
		color: #00E5C4;
		font-family: 'Outfit', sans-serif;
		letter-spacing: -1.5px;
	}

	.nav-links {
		display: flex;
		gap: 32px;
		align-items: center;
	}

	.nav-links a {
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		letter-spacing: 0.3px;
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: #FF5C4D;
	}

	nav {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		padding: 20px 48px;
		gap: 32px;
	}

	.nav-cta {
		background: #FF5C4D;
		color: #ffffff;
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		padding: 10px 24px;
		border-radius: 8px;
		text-decoration: none;
		letter-spacing: 0.2px;
		transition: background 0.2s ease;
		white-space: nowrap;
	}

	.nav-cta:hover {
		background: #FF2D1A;
	}
</style>
