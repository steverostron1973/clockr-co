---
import '../styles/global.css';
import type { CategoryId } from '../data/categories';
import { categoryGradients, categoryRgb, getCategoryGradient } from '../data/categories';

interface Props {
	title: string;
	description: string;
	category?: CategoryId;
	ogImage?: string;
}

const {
	title,
	description,
	category = 'holidays',
	ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site ?? 'https://clockr.co';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const navLinks = [
	{ label: 'History', href: '/history' },
	{ label: 'More', href: '/more' },
];

const countdownDropdownLinks = [
	{ label: 'Days Until Christmas', href: '/days-until-christmas' },
	{ label: 'Boxing Day Countdown', href: '/days-until-boxing-day' },
	{ label: 'Days Until New Year', href: '/days-until-new-year' },
	{ label: 'Days Until Halloween', href: '/days-until-halloween' },
	{ label: "Days Until Valentine's Day", href: '/days-until-valentines' },
	{ label: 'Days Until Easter', href: '/days-until-easter' },
	{ label: "St Patrick's Day Countdown", href: '/days-until-st-patricks-day' },
	{ label: "Mother's Day Countdown", href: '/days-until-mothers-day' },
	{ label: "Father's Day Countdown", href: '/days-until-fathers-day' },
	{ label: 'Thanksgiving Countdown', href: '/days-until-thanksgiving' },
	{ label: 'Black Friday Countdown', href: '/days-until-black-friday' },
	{ label: 'Days Until Bonfire Night', href: '/days-until-bonfire-night' },
	{ label: 'Back to School Countdown', href: '/days-until-back-to-school' },
];

const toolsDropdownLinks = [
	{ label: 'All tools', href: '/#all-tools' },
	{ label: 'Overtime Calculator', href: '/overtime-calculator' },
	{ label: 'Project Deadline Calculator', href: '/project-deadline-calculator' },
	{ label: 'Invoice Due Date Calculator', href: '/invoice-due-date-calculator' },
	{ label: 'Pomodoro Timer', href: '/pomodoro-timer' },
	{ label: 'Age Calculator', href: '/age-calculator' },
	{ label: 'Days Until Birthday', href: '/days-until-birthday' },
	{ label: 'Pregnancy Due Date Calculator', href: '/pregnancy-due-date-calculator' },
	{ label: 'Anniversary Calculator', href: '/anniversary-calculator' },
	{ label: 'Age Difference Calculator', href: '/age-difference-calculator' },
	{ label: 'Retirement Countdown Calculator', href: '/retirement-countdown-calculator' },
	{ label: "How Many Days Until I'm X", href: '/days-until-im-x' },
	{ label: 'Zodiac Sign Finder', href: '/zodiac-sign-finder' },
	{ label: 'Season Countdown', href: '/season-countdown' },
	{ label: 'Your Life in Numbers', href: '/life-in-numbers' },
	{ label: 'What Generation Am I', href: '/what-generation' },
];

const footerLinks = [
	{ label: 'About', href: '/about' },
	{ label: 'Privacy', href: '/privacy' },
	{ label: 'Contact', href: '/contact' },
];

const catGradient = categoryGradients[category];
const catRgb = categoryRgb[category];
const catGradientCss = getCategoryGradient(catGradient.from, catGradient.to);
const categoryStyle = `--cat-from: ${catGradient.from}; --cat-to: ${catGradient.to}; --cat-gradient: ${catGradientCss}; --cat-from-rgb: ${catRgb.from}; --cat-to-rgb: ${catRgb.to};`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, siteUrl)} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(ogImage, siteUrl)} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700;800;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen flex flex-col" style={categoryStyle}>
		<header class="w-full border-b border-border">
			<nav>
				<div class="logo-wrap">
					<a href="/">
						<span class="logo-main">Clock</span><span class="logo-r">r</span>
					</a>
				</div>

				<ul class="nav-links">
					<li class="tools-dropdown">
						<details>
							<summary>Tools</summary>
							<div class="tools-menu" role="menu" aria-label="Tools">
								{
									toolsDropdownLinks.map((link) => (
										<a role="menuitem" href={link.href} class="tools-menu-link">
											{link.label}
										</a>
									))
								}
							</div>
						</details>
					</li>
					<li class="tools-dropdown">
						<details>
							<summary>Countdowns</summary>
							<div class="tools-menu" role="menu" aria-label="Countdowns">
								{
									countdownDropdownLinks.map((link) => (
										<a role="menuitem" href={link.href} class="tools-menu-link">
											{link.label}
										</a>
									))
								}
							</div>
						</details>
					</li>
					{
						navLinks.map((link) => (
							<li>
								<a href={link.href}>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>

				<a href="/create-countdown" class="nav-cta">Create Countdown</a>
			</nav>
		</header>

		<main class="flex-1 w-full">
			<slot />
		</main>

		<footer class="w-full border-t border-border mt-auto">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-10 text-center sm:px-6"
			>
				<p class="font-display text-sm font-bold text-text-secondary">
					Your time and date friend
				</p>

				<ul class="flex flex-wrap items-center justify-center gap-6">
					{
						footerLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-text-secondary transition-colors hover:text-text-primary"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>

				<p class="text-sm text-text-secondary">
					&copy; {new Date().getFullYear()} Clockr.co. All rights reserved.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	.logo-main {
		font-size: 36px;
		font-weight: 900;
		letter-spacing: -1.5px;
		background: linear-gradient(135deg, #FF5C4D, #FF9A3C);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-family: 'Outfit', sans-serif;
	}

	.logo-r {
		font-size: 36px;
		font-weight: 900;
		color: #00E5C4;
		font-family: 'Outfit', sans-serif;
		letter-spacing: -1.5px;
	}

	.logo-wrap {
		visibility: visible !important;
		display: flex !important;
		align-items: center;
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 32px;
		align-items: center;
	}

	.nav-links a {
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		letter-spacing: 0.3px;
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: #FF5C4D;
	}

	.tools-dropdown details {
		position: relative;
	}

	.tools-dropdown summary {
		list-style: none;
		cursor: pointer;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 0.3px;
		transition: color 0.2s ease;
	}

	.tools-dropdown summary::-webkit-details-marker {
		display: none;
	}

	.tools-dropdown summary:hover {
		color: #FF5C4D;
	}

	.tools-dropdown summary::after {
		content: '▾';
		margin-left: 8px;
		font-size: 12px;
		opacity: 0.7;
	}

	.tools-menu {
		position: absolute;
		top: calc(100% + 12px);
		left: 50%;
		transform: translateX(-50%);
		min-width: 260px;
		background: #111111;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		padding: 10px;
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.55);
		display: flex;
		flex-direction: column;
		gap: 4px;
		z-index: 50;
	}

	.tools-menu-link {
		display: block;
		padding: 10px 12px;
		border-radius: 10px;
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
		transition: background 0.15s ease, color 0.15s ease;
	}

	.tools-menu-link:hover {
		background: rgba(255, 92, 77, 0.12);
		color: rgba(255, 255, 255, 0.95);
	}

	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px 48px;
	}

	.nav-cta {
		background: #FF5C4D;
		color: #ffffff;
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		padding: 10px 24px;
		border-radius: 8px;
		text-decoration: none;
		letter-spacing: 0.2px;
		transition: background 0.2s ease;
		white-space: nowrap;
	}

	.nav-cta:hover {
		background: #FF2D1A;
	}
</style>
