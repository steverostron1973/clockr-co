<script>
	const startInput = document.getElementById('start-date') as HTMLInputElement;
	const endInput = document.getElementById('end-date') as HTMLInputElement;
	const calculateBtn = document.getElementById('calculate-btn');
	const results = document.getElementById('date-results');

	function formatNumber(n: number) {
		return n.toLocaleString();
	}

	function toDateInputValue(date: Date) {
		const year = date.getFullYear();
		const month = String(date.getMonth() + 1).padStart(2, '0');
		const day = String(date.getDate()).padStart(2, '0');
		return `${year}-${month}-${day}`;
	}

	function startOfDay(date: Date) {
		const d = new Date(date);
		d.setHours(0, 0, 0, 0);
		return d;
	}

	function getDateBreakdown(from: Date, to: Date) {
		let years = to.getFullYear() - from.getFullYear();
		let months = to.getMonth() - from.getMonth();
		let days = to.getDate() - from.getDate();

		if (days < 0) {
			months--;
			days += new Date(to.getFullYear(), to.getMonth(), 0).getDate();
		}
		if (months < 0) {
			years--;
			months += 12;
		}

		return { years, months, days };
	}

	function getTotalMonths(from: Date, to: Date) {
		const { years, months } = getDateBreakdown(from, to);
		return years * 12 + months;
	}

	function calculateDateDiff() {
		if (!startInput || !endInput || !results) return;

		const start = startOfDay(new Date(startInput.value));
		const end = startOfDay(new Date(endInput.value));

		if (!startInput.value || !endInput.value || isNaN(start.getTime()) || isNaN(end.getTime())) {
			return;
		}

		results.style.display = 'block';

		const isFuture = end >= start;
		const earlier = isFuture ? start : end;
		const later = isFuture ? end : start;

		const diffMs = later.getTime() - earlier.getTime();
		const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
		const totalWeeks = Math.floor(totalDays / 7);
		const totalHours = totalDays * 24;
		const { years, months, days } = getDateBreakdown(earlier, later);
		const totalMonths = getTotalMonths(earlier, later);

		const totalDaysEl = document.getElementById('total-days');
		const exactEl = document.getElementById('date-exact');
		const weeksEl = document.getElementById('total-weeks');
		const hoursEl = document.getElementById('total-hours');
		const monthsEl = document.getElementById('total-months');
		const directionIconEl = document.getElementById('direction-icon');
		const directionTextEl = document.getElementById('direction-text');

		if (totalDaysEl) totalDaysEl.textContent = formatNumber(totalDays);
		if (exactEl)
			exactEl.textContent = `${years} years, ${months} months, ${days} days`;
		if (weeksEl) weeksEl.textContent = formatNumber(totalWeeks);
		if (hoursEl) hoursEl.textContent = formatNumber(totalHours);
		if (monthsEl) monthsEl.textContent = formatNumber(totalMonths);

		const today = startOfDay(new Date());
		let directionMessage = '';

		if (start.getTime() === end.getTime()) {
			if (directionIconEl) directionIconEl.textContent = '📍';
			directionMessage = 'Both dates are the same — zero days apart.';
		} else if (isFuture) {
			if (directionIconEl) directionIconEl.textContent = '⏭️';
			if (end > today && start <= today) {
				directionMessage = `Future date gap — ${formatNumber(totalDays)} days until ${end.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}.`;
			} else {
				directionMessage = `Future date gap — the end date is ${formatNumber(totalDays)} days after the start date.`;
			}
		} else {
			if (directionIconEl) directionIconEl.textContent = '⏮️';
			if (end < today && start <= today) {
				directionMessage = `Past date gap — ${formatNumber(totalDays)} days since ${end.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}.`;
			} else {
				directionMessage = `Past date gap — the end date is ${formatNumber(totalDays)} days before the start date.`;
			}
		}

		if (directionTextEl) directionTextEl.textContent = directionMessage;
	}

	function getNextOccurrence(month: number, day: number) {
		const today = startOfDay(new Date());
		let target = new Date(today.getFullYear(), month, day);
		if (target < today) {
			target = new Date(today.getFullYear() + 1, month, day);
		}
		return target;
	}

	const presets: Record<string, () => { start: Date; end: Date }> = {
		christmas: () => ({
			start: startOfDay(new Date()),
			end: getNextOccurrence(11, 25),
		}),
		'new-year': () => ({
			start: startOfDay(new Date()),
			end: getNextOccurrence(0, 1),
		}),
		millennium: () => ({
			start: new Date(2000, 0, 1),
			end: startOfDay(new Date()),
		}),
		halloween: () => ({
			start: startOfDay(new Date()),
			end: getNextOccurrence(9, 31),
		}),
		valentines: () => ({
			start: startOfDay(new Date()),
			end: getNextOccurrence(1, 14),
		}),
		'moon-landing': () => ({
			start: new Date(1969, 6, 20),
			end: startOfDay(new Date()),
		}),
	};

	function applyPreset(presetKey: string) {
		const preset = presets[presetKey];
		if (!preset || !startInput || !endInput) return;

		const { start, end } = preset();
		startInput.value = toDateInputValue(start);
		endInput.value = toDateInputValue(end);
		calculateDateDiff();
	}

	calculateBtn?.addEventListener('click', calculateDateDiff);

	document.querySelectorAll('.date-example-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const preset = (btn as HTMLButtonElement).dataset.preset;
			if (preset) applyPreset(preset);
		});
	});

	const today = toDateInputValue(new Date());
	if (startInput) startInput.value = today;
</script>
