<script>
	const fromSelect = document.getElementById('from-city') as HTMLSelectElement;
	const toSelect = document.getElementById('to-city') as HTMLSelectElement;
	const dateInput = document.getElementById('tz-date') as HTMLInputElement;
	const timeInput = document.getElementById('tz-time') as HTMLInputElement;
	const swapBtn = document.getElementById('swap-btn');

	const resultLabel = document.getElementById('result-label');
	const resultTime = document.getElementById('result-time');
	const resultDate = document.getElementById('result-date');
	const fromOffsetLabel = document.getElementById('from-offset-label');
	const toOffsetLabel = document.getElementById('to-offset-label');
	const fromOffsetEl = document.getElementById('from-offset');
	const toOffsetEl = document.getElementById('to-offset');
	const timeDiffEl = document.getElementById('time-diff');
	const dayRelationEl = document.getElementById('day-relation');

	const timeFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const dateFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const offsetFormatterCache = new Map<string, Intl.DateTimeFormat>();

	function getSelectedTimezone(select: HTMLSelectElement): string {
		return select.selectedOptions[0]?.dataset.timezone ?? 'UTC';
	}

	function getSelectedCity(select: HTMLSelectElement): string {
		return select.value;
	}

	function getTimeFormatter(timeZone: string) {
		if (!timeFormatterCache.has(timeZone)) {
			timeFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					hour: '2-digit',
					minute: '2-digit',
					hour12: false,
				}),
			);
		}
		return timeFormatterCache.get(timeZone)!;
	}

	function getDateFormatter(timeZone: string) {
		if (!dateFormatterCache.has(timeZone)) {
			dateFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					weekday: 'long',
					day: 'numeric',
					month: 'long',
					year: 'numeric',
				}),
			);
		}
		return dateFormatterCache.get(timeZone)!;
	}

	function getOffsetFormatter(timeZone: string) {
		if (!offsetFormatterCache.has(timeZone)) {
			offsetFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					timeZoneName: 'shortOffset',
				}),
			);
		}
		return offsetFormatterCache.get(timeZone)!;
	}

	function formatOffset(timeZone: string, date: Date): string {
		const parts = getOffsetFormatter(timeZone).formatToParts(date);
		const raw = parts.find((p) => p.type === 'timeZoneName')?.value ?? '';
		return raw.replace('GMT', 'UTC');
	}

	function wallClockToUtc(
		year: number,
		month: number,
		day: number,
		hour: number,
		minute: number,
		timeZone: string,
	): Date {
		let date = new Date(Date.UTC(year, month - 1, day, hour, minute, 0));
		const formatter = new Intl.DateTimeFormat('en-US', {
			timeZone,
			hourCycle: 'h23',
			year: 'numeric',
			month: 'numeric',
			day: 'numeric',
			hour: 'numeric',
			minute: 'numeric',
			second: 'numeric',
		});

		for (let i = 0; i < 2; i++) {
			const parts = formatter.formatToParts(date);
			const get = (type: string) =>
				parseInt(parts.find((p) => p.type === type)?.value ?? '0', 10);
			const tzYear = get('year');
			const tzMonth = get('month');
			const tzDay = get('day');
			const tzHour = get('hour');
			const tzMinute = get('minute');
			const desired = Date.UTC(year, month - 1, day, hour, minute);
			const actual = Date.UTC(tzYear, tzMonth - 1, tzDay, tzHour, tzMinute);
			date = new Date(date.getTime() + (desired - actual));
		}

		return date;
	}

	function getOffsetMinutes(timeZone: string, date: Date): number {
		const utc = new Date(date.toLocaleString('en-US', { timeZone: 'UTC' }));
		const tz = new Date(date.toLocaleString('en-US', { timeZone }));
		return (tz.getTime() - utc.getTime()) / 60000;
	}

	function getDateKey(timeZone: string, date: Date): number {
		const fmt = new Intl.DateTimeFormat('en-CA', {
			timeZone,
			year: 'numeric',
			month: '2-digit',
			day: '2-digit',
		});
		const [y, m, d] = fmt.format(date).split('-').map(Number);
		return y * 10000 + m * 100 + d;
	}

	function formatDuration(totalMinutes: number): string {
		const hours = Math.floor(totalMinutes / 60);
		const mins = totalMinutes % 60;
		const parts: string[] = [];
		if (hours > 0) parts.push(`${hours} hour${hours === 1 ? '' : 's'}`);
		if (mins > 0) parts.push(`${mins} minute${mins === 1 ? '' : 's'}`);
		return parts.join(' ') || '0 hours';
	}

	function setDefaults() {
		const now = new Date();
		const y = now.getFullYear();
		const m = String(now.getMonth() + 1).padStart(2, '0');
		const d = String(now.getDate()).padStart(2, '0');
		const h = String(now.getHours()).padStart(2, '0');
		const min = String(now.getMinutes()).padStart(2, '0');

		if (dateInput) dateInput.value = `${y}-${m}-${d}`;
		if (timeInput) timeInput.value = `${h}:${min}`;
	}

	function selectCity(select: HTMLSelectElement, city: string) {
		for (const option of select.options) {
			if (option.value === city) {
				select.value = city;
				return;
			}
		}
	}

	function convert() {
		if (!fromSelect || !toSelect || !dateInput || !timeInput) return;
		if (!dateInput.value || !timeInput.value) return;

		const fromTz = getSelectedTimezone(fromSelect);
		const toTz = getSelectedTimezone(toSelect);
		const fromCity = getSelectedCity(fromSelect);
		const toCity = getSelectedCity(toSelect);

		const [year, month, day] = dateInput.value.split('-').map(Number);
		const [hour, minute] = timeInput.value.split(':').map(Number);

		const utcDate = wallClockToUtc(year, month, day, hour, minute, fromTz);

		if (resultLabel) resultLabel.textContent = `In ${toCity}`;
		if (resultTime)
			resultTime.textContent = getTimeFormatter(toTz).format(utcDate);
		if (resultDate)
			resultDate.textContent = getDateFormatter(toTz).format(utcDate);

		if (fromOffsetLabel) fromOffsetLabel.textContent = fromCity;
		if (toOffsetLabel) toOffsetLabel.textContent = toCity;
		if (fromOffsetEl) fromOffsetEl.textContent = formatOffset(fromTz, utcDate);
		if (toOffsetEl) toOffsetEl.textContent = formatOffset(toTz, utcDate);

		const diffMinutes = getOffsetMinutes(toTz, utcDate) - getOffsetMinutes(fromTz, utcDate);
		if (timeDiffEl) {
			if (diffMinutes === 0) {
				timeDiffEl.textContent = `${toCity} is the same time as ${fromCity}`;
			} else if (diffMinutes < 0) {
				timeDiffEl.textContent = `${toCity} is ${formatDuration(Math.abs(diffMinutes))} behind ${fromCity}`;
			} else {
				timeDiffEl.textContent = `${toCity} is ${formatDuration(diffMinutes)} ahead of ${fromCity}`;
			}
		}

		const fromDay = getDateKey(fromTz, utcDate);
		const toDay = getDateKey(toTz, utcDate);
		if (dayRelationEl) {
			if (toDay > fromDay) {
				dayRelationEl.textContent = `Next day in ${toCity}`;
			} else if (toDay < fromDay) {
				dayRelationEl.textContent = `Previous day in ${toCity}`;
			} else {
				dayRelationEl.textContent = `Same day in both cities`;
			}
		}
	}

	setDefaults();
	convert();

	fromSelect?.addEventListener('change', convert);
	toSelect?.addEventListener('change', convert);
	dateInput?.addEventListener('change', convert);
	dateInput?.addEventListener('input', convert);
	timeInput?.addEventListener('change', convert);
	timeInput?.addEventListener('input', convert);

	swapBtn?.addEventListener('click', () => {
		if (!fromSelect || !toSelect) return;
		const fromVal = fromSelect.value;
		const toVal = toSelect.value;
		fromSelect.value = toVal;
		toSelect.value = fromVal;
		convert();
	});

	document.querySelectorAll('.tz-preset-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const from = (btn as HTMLButtonElement).dataset.from;
			const to = (btn as HTMLButtonElement).dataset.to;
			if (from && to && fromSelect && toSelect) {
				selectCity(fromSelect, from);
				selectCity(toSelect, to);
				convert();
			}
		});
	});
</script>
