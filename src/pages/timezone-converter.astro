---
import Layout from '../layouts/Layout.astro';
import { allWorldClockCities } from '../data/worldClockSearchCities';

const cities = [...allWorldClockCities].sort((a, b) =>
	a.city.localeCompare(b.city),
);

const presets = [
	{ from: 'London', to: 'New York', label: 'London ↔ New York' },
	{ from: 'London', to: 'Dubai', label: 'London ↔ Dubai' },
	{ from: 'London', to: 'Sydney', label: 'London ↔ Sydney' },
	{ from: 'New York', to: 'Los Angeles', label: 'New York ↔ Los Angeles' },
	{ from: 'New York', to: 'Tokyo', label: 'New York ↔ Tokyo' },
	{ from: 'Dubai', to: 'Mumbai', label: 'Dubai ↔ Mumbai' },
	{ from: 'Singapore', to: 'London', label: 'Singapore ↔ London' },
	{ from: 'Paris', to: 'New York', label: 'Paris ↔ New York' },
];
---

<Layout
	title="Time Zone Converter — Convert Time Between Cities | Clockr"
	description="Convert time between any two cities instantly. Free time zone converter covering 250+ cities worldwide."
	category="timezones"
>
	<div class="tz-page">
		<div class="tz-header">
			<div class="tz-eyebrow">🌍 Time Zones</div>
			<h1 class="tz-title">
				<span class="tz-gradient">Time Zone</span><br />
				<span class="tz-gradient">Converter</span>
			</h1>
			<p class="tz-subtitle">
				Convert time between any two cities instantly
			</p>
		</div>

		<div class="tz-form-card">
			<div class="tz-selectors">
				<div class="tz-select-wrap">
					<label class="tz-label" for="from-city">From</label>
					<select id="from-city" class="tz-select">
						{
							cities.map((c) => (
								<option
									value={c.city}
									data-timezone={c.timezone}
									selected={c.city === 'London'}
								>
									{c.flag} {c.city}, {c.country}
								</option>
							))
						}
					</select>
				</div>

				<button
					type="button"
					class="tz-swap"
					id="swap-btn"
					aria-label="Swap cities"
					title="Swap cities"
				>
					⇄
				</button>

				<div class="tz-select-wrap">
					<label class="tz-label" for="to-city">To</label>
					<select id="to-city" class="tz-select">
						{
							cities.map((c) => (
								<option
									value={c.city}
									data-timezone={c.timezone}
									selected={c.city === 'New York'}
								>
									{c.flag} {c.city}, {c.country}
								</option>
							))
						}
					</select>
				</div>
			</div>

			<div class="tz-datetime">
				<div class="tz-input-wrap">
					<label class="tz-label" for="tz-date">Date</label>
					<input type="date" id="tz-date" class="tz-input" />
				</div>
				<div class="tz-input-wrap">
					<label class="tz-label" for="tz-time">Time</label>
					<input type="time" id="tz-time" class="tz-input" />
				</div>
			</div>
		</div>

		<div class="tz-result-card">
			<div class="tz-result-label" id="result-label">In New York</div>
			<div class="tz-result-time" id="result-time">--:--</div>
			<div class="tz-result-date" id="result-date">—</div>
		</div>

		<div class="tz-meta">
			<div class="tz-meta-row">
				<span class="tz-meta-label" id="from-offset-label">London</span>
				<span class="tz-meta-value" id="from-offset">—</span>
			</div>
			<div class="tz-meta-row">
				<span class="tz-meta-label" id="to-offset-label">New York</span>
				<span class="tz-meta-value" id="to-offset">—</span>
			</div>
			<div class="tz-meta-row tz-meta-highlight">
				<span class="tz-meta-label">Time difference</span>
				<span class="tz-meta-value" id="time-diff">—</span>
			</div>
			<div class="tz-meta-row">
				<span class="tz-meta-label">Day relationship</span>
				<span class="tz-meta-value" id="day-relation">—</span>
			</div>
		</div>

		<div class="tz-presets">
			<h3 class="tz-presets-title">Common conversions</h3>
			<div class="tz-presets-grid">
				{
					presets.map((p) => (
						<button
							type="button"
							class="tz-preset-btn"
							data-from={p.from}
							data-to={p.to}
						>
							{p.label}
						</button>
					))
				}
			</div>
		</div>

		<!-- HOW IT WORKS -->
		<section class="tz-how">
			<h2 class="tz-section-title">How does a time zone converter work?</h2>
			<div class="tz-how-card">
				<p>
					Time zones work as offsets from UTC (Coordinated Universal Time). Each
					zone represents a fixed number of hours and minutes ahead of or behind
					UTC — for example, New York is typically UTC−5 and Tokyo is UTC+9. When
					you convert a time between two cities, you are essentially shifting the
					clock by the difference between their two UTC offsets.
				</p>
				<p>
					Daylight saving time complicates conversions. Many countries shift their
					clocks forward by one hour in spring and back in autumn, meaning the
					offset between two cities can change twice a year. London and New York
					might be five hours apart in winter but only four in summer. A reliable
					converter must know which DST rules apply to each city on the specific
					date you are converting.
				</p>
				<p>
					Clockr uses IANA timezone identifiers — such as "Europe/London" and
					"America/New_York" — and the browser's Intl.DateTimeFormat API to
					handle all daylight saving rules automatically for over 250 cities. The
					IANA database contains the complete history of timezone changes for
					every region, so your conversion stays accurate regardless of the date
					you choose.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="tz-faq">
			<h2 class="tz-section-title">Frequently asked questions</h2>
			<div class="tz-faq-list">
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>How do I convert time between two countries?</summary
					>
					<div class="tz-faq-answer">
						<p>
							Select your source city in the "From" dropdown and your destination
							city in the "To" dropdown, then enter the date and time you want to
							convert. Clockr instantly shows the equivalent local time in the
							destination city, along with the UTC offsets and time difference.
							Use the swap button to reverse the direction, or pick a common
							conversion from the presets below the converter.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>What is the difference between GMT and UTC?</summary
					>
					<div class="tz-faq-answer">
						<p>
							GMT (Greenwich Mean Time) and UTC are practically identical for
							everyday use — both represent offset zero. GMT is based on Earth's
							rotation and was the original global standard centred on Greenwich,
							London. UTC is based on atomic clocks and is the modern international
							standard. The difference between them is less than a second. In
							winter the UK uses GMT; in summer it switches to BST (UTC+1).
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>Which countries do not observe daylight saving time?</summary
					>
					<div class="tz-faq-answer">
						<p>
							Many countries near the equator do not use DST because daylight
							hours vary little year-round. Japan, China, India, South Korea, and
							most of Africa and Southeast Asia do not observe it. In the United
							States, Arizona (except the Navajo Nation) and Hawaii stay on
							standard time year-round. Since 2024, Mexico has also stopped
							observing DST in most regions.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>What is the best time to schedule a meeting between the US and UK?</summary
					>
					<div class="tz-faq-answer">
						<p>
							The overlap window depends on the season due to DST. When both
							countries are on daylight saving, the gap is typically four to five
							hours — meaning 9:00 AM Eastern in the US is 2:00 PM in London.
							A practical meeting window is 9:00 AM to 12:00 PM Eastern (2:00 PM
							to 5:00 PM UK time). Use Clockr to check the exact offset for your
							specific meeting date.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>How many hours ahead is Australia compared to the UK?</summary
					>
					<div class="tz-faq-answer">
						<p>
							It depends on which Australian city and the time of year. Sydney
							is typically 10 or 11 hours ahead of London — 11 hours during
							Northern Hemisphere summer when London is on BST and Sydney is on
							standard time, or 10 hours when both offsets align differently.
							Perth is only 7 or 8 hours ahead. Always check the specific cities
							and date in Clockr, as Australian states observe DST on different
							schedules.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>What time zone should I use for international business?</summary
					>
					<div class="tz-faq-answer">
						<p>
							UTC is the standard reference for international business, aviation,
							and computing — it avoids ambiguity about which country's daylight
							saving rules apply. Many global companies schedule meetings in UTC
							or specify times with the UTC offset (e.g. "14:00 UTC"). For
							day-to-day work, convert to each participant's local time using a
							timezone converter so nobody joins at the wrong hour.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>Why does India have a half-hour time zone offset?</summary
					>
					<div class="tz-faq-answer">
						<p>
							India uses a single time zone — IST (UTC+5:30) — across the entire
							country, despite spanning nearly 30 degrees of longitude. The
							half-hour offset was chosen in 1906 to place the standard meridian
							near the centre of the country, roughly between western Gujarat and
							eastern Assam. A single zone simplifies national scheduling, even
							though solar noon varies by over an hour from east to west.
						</p>
					</div>
				</details>
				<details class="tz-faq-item">
					<summary class="tz-faq-question"
						>What is the time difference between New York and Los Angeles?</summary
					>
					<div class="tz-faq-answer">
						<p>
							Los Angeles is three hours behind New York year-round. Both cities
							observe daylight saving time on the same schedule, so the three-hour
							gap stays constant — when it is noon in New York, it is 9:00 AM in
							Los Angeles. Select both cities in Clockr's converter to see the
							exact time for any date and time you enter.
						</p>
					</div>
				</details>
			</div>
		</section>

		<!-- RELATED TOOLS -->
		<div class="tz-related">
			<h3 class="tz-related-title">You might also like</h3>
			<div class="tz-related-grid">
				<a href="/time-zone-meeting-planner" class="tz-related-card"
					><span class="tz-related-name">Time Zone Meeting Planner</span></a
				>
				<a href="/world-clock" class="tz-related-card"
					><span class="tz-related-name">World Clock</span></a
				>
				<a href="/time-difference" class="tz-related-card"
					><span class="tz-related-name">Time Difference Calculator</span></a
				>
				<a href="/business-days" class="tz-related-card"
					><span class="tz-related-name">Business Days Calculator</span></a
				>
				<a href="/countdown-timer" class="tz-related-card"
					><span class="tz-related-name">Countdown Timer</span></a
				>
			</div>
		</div>
	</div>
</Layout>

