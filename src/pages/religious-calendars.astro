---
import Layout from '../layouts/Layout.astro';

const tools = [
	{
		name: 'Days Until Ramadan',
		description: 'Countdown to the start of Ramadan',
		href: '/days-until-ramadan',
		emoji: '🌙',
	},
	{
		name: 'Days Until Diwali',
		description: 'Countdown to the Festival of Lights',
		href: '/days-until-diwali',
		emoji: '🪔',
	},
	{
		name: 'Days Until Hanukkah',
		description: 'Countdown to the Festival of Lights',
		href: '/days-until-hanukkah',
		emoji: '🕎',
	},
	{
		name: 'Days Until Eid',
		description: 'Countdown to Eid al-Fitr and Eid al-Adha',
		href: '/days-until-eid',
		emoji: '🌙',
	},
	{
		name: 'Hijri Calendar Converter',
		description: 'Convert between Gregorian and Hijri dates',
		href: '/hijri-calendar-converter',
		emoji: '📅',
	},
	{
		name: 'Hebrew Calendar Converter',
		description: 'Convert between Gregorian and Hebrew dates',
		href: '/hebrew-calendar-converter',
		emoji: '✡️',
	},
	{
		name: 'Days Until Easter',
		description: 'Countdown to Easter Sunday',
		href: '/days-until-easter',
		emoji: '🐣',
	},
];
---

<Layout
	title="Religious Calendars — Ramadan, Easter & More | Clockr"
	description="Ramadan, Diwali, Easter and more — live countdowns to major religious dates and holy days."
	category="religious"
>
	<div class="rc-page">
		<div class="rc-header">
			<div class="rc-eyebrow">
				<span class="rc-eyebrow-square" aria-hidden="true"></span>
				RELIGIOUS CALENDARS
			</div>
			<h1 class="rc-title">
				<span class="rc-gradient">Religious Calendars</span>
			</h1>
			<p class="rc-subtitle">Ramadan, Diwali, Easter and more</p>
		</div>

		<div class="rc-grid">
			{
				tools.map((item) => (
					<a href={item.href} class="rc-card">
						<span class="rc-card-emoji" aria-hidden="true">
							{item.emoji}
						</span>
						<span class="rc-card-name">{item.name}</span>
						<span class="rc-card-desc">{item.description}</span>
					</a>
				))
			}
		</div>

		<section class="rc-how">
			<h2 class="rc-section-title">About religious calendar tools</h2>
			<div class="rc-how-card">
				<p>
					Many holy days follow lunar or ecclesiastical calendars rather than
					fixed Gregorian dates — so Ramadan, Easter, Diwali and others shift
					year to year. These countdowns track the next upcoming date using
					established calendar rules, with notes where local moon sighting or
					tradition may differ. Pick a card above to get started.
				</p>
			</div>
		</section>

		<div class="rc-related">
			<h3 class="rc-related-title">You might also like</h3>
			<div class="rc-related-grid">
				<a href="/holiday-countdowns" class="rc-related-card"
					><span class="rc-related-name">Holiday Countdowns</span></a
				>
				<a href="/moon-phase-calculator" class="rc-related-card"
					><span class="rc-related-name">Moon Phase Calculator</span></a
				>
				<a href="/create-countdown" class="rc-related-card"
					><span class="rc-related-name">Create Your Own Countdown</span></a
				>
				<a href="/#all-tools" class="rc-related-card"
					><span class="rc-related-name">All tools</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.rc-page {
		max-width: 900px;
		margin: 0 auto;
		padding: 60px 24px 80px;
	}

	.rc-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.rc-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.rc-eyebrow-square {
		width: 8px;
		height: 8px;
		border-radius: 2px;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		flex-shrink: 0;
		-webkit-text-fill-color: initial;
	}

	.rc-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.rc-gradient {
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.rc-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
		margin: 0;
		max-width: 540px;
		margin-inline: auto;
	}

	.rc-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 14px;
		margin-bottom: 56px;
	}

	@media (max-width: 640px) {
		.rc-grid {
			grid-template-columns: 1fr;
		}
	}

	.rc-card {
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: #0c0c0c;
		border: 1px solid rgba(232, 147, 122, 0.15);
		border-radius: 14px;
		padding: 22px 20px;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.rc-card:hover {
		border-color: rgba(201, 149, 108, 0.45);
		transform: translateY(-3px);
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.35);
	}

	.rc-card-emoji {
		font-size: 28px;
		line-height: 1;
		margin-bottom: 4px;
	}

	.rc-card-name {
		font-family: 'Outfit', sans-serif;
		font-size: 17px;
		font-weight: 700;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.rc-card-desc {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.45);
		line-height: 1.5;
	}

	.rc-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.rc-how {
		margin-bottom: 48px;
	}

	.rc-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(232, 147, 122, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.rc-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.rc-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.rc-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.rc-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.rc-related-grid {
			grid-template-columns: 1fr;
		}
	}

	.rc-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.rc-related-card:hover {
		border-color: rgba(232, 147, 122, 0.4);
	}

	.rc-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
