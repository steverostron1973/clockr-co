---
import Layout from '../layouts/Layout.astro';
import { gridCities, searchOnlyCities } from '../data/worldClockSearchCities';
---

<Layout
	title="World Clock — Current Time in Every City | Clockr"
	description="Check the current local time in cities around the world. Live updating world clock with 24 major cities."
>
	<div class="wc-page">
		<div class="wc-header">
			<div class="wc-eyebrow">🌍 Time Zones</div>
			<h1 class="wc-title">
				<span class="wc-gradient">World Clock</span>
			</h1>
			<p class="wc-subtitle">
				Current local time in cities around the world
			</p>
		</div>

		<div class="wc-search-wrap">
			<label class="wc-search-label" for="wc-search">Search cities</label>
			<input
				type="search"
				id="wc-search"
				class="wc-search"
				placeholder="Search 200+ cities worldwide…"
				autocomplete="off"
			/>
		</div>

		<div class="wc-grid" id="wc-grid">
			{
				gridCities.map((c) => (
					<div
						class="wc-card"
						data-city={c.city.toLowerCase()}
						data-country={c.country.toLowerCase()}
						data-timezone={c.timezone}
					>
						<div class="wc-card-top">
							<div class="wc-card-location">
								<div class="wc-city">{c.city}</div>
								<div class="wc-country">{c.country}</div>
							</div>
							<span class="wc-flag" aria-hidden="true">{c.flag}</span>
						</div>
						<div class="wc-time" data-time>--:--:--</div>
						<div class="wc-date" data-date>—</div>
						<div class="wc-offset" data-offset>—</div>
					</div>
				))
			}
			{
				searchOnlyCities.map((c) => (
					<div
						class="wc-card"
						data-search-only
						hidden
						data-city={c.city.toLowerCase()}
						data-country={c.country.toLowerCase()}
						data-timezone={c.timezone}
					>
						<div class="wc-card-top">
							<div class="wc-card-location">
								<div class="wc-city">{c.city}</div>
								<div class="wc-country">{c.country}</div>
							</div>
							<span class="wc-flag" aria-hidden="true">{c.flag}</span>
						</div>
						<div class="wc-time" data-time>--:--:--</div>
						<div class="wc-date" data-date>—</div>
						<div class="wc-offset" data-offset>—</div>
					</div>
				))
			}
		</div>

		<p class="wc-empty" id="wc-empty" hidden>No cities match your search.</p>

		<!-- HOW IT WORKS -->
		<section class="wc-how">
			<h2 class="wc-section-title">How does a world clock work?</h2>
			<div class="wc-how-card">
				<p>
					The world is divided into time zones based on longitude. Each zone is
					roughly 15 degrees wide, representing one hour of difference from its
					neighbour. As the Earth rotates, the sun appears to move across the
					sky at different times in different places — noon in London is still
					night in New York. Time zones let every region set its clocks to match
					local solar time.
				</p>
				<p>
					UTC (Coordinated Universal Time) is the global standard that all time
					zones are offset from. It replaced GMT as the international reference
					in 1972 and is kept precise using atomic clocks. Every city on a world
					clock is expressed as UTC plus or minus a number of hours — for
					example, New York is UTC−5 and Tokyo is UTC+9.
				</p>
				<p>
					Clockr uses the browser's built-in Intl.DateTimeFormat API with IANA
					timezone identifiers to display accurate local times for every city.
					Each city card is linked to a named timezone like
					"America/New_York" or "Asia/Tokyo", and the API handles daylight
					saving changes, half-hour offsets, and historical adjustments
					automatically — updating every second without any server round-trip.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="wc-faq">
			<h2 class="wc-section-title">Frequently asked questions</h2>
			<div class="wc-faq-list">
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>How many time zones are there in the world?</summary
					>
					<div class="wc-faq-answer">
						<p>
							There are 24 primary longitudinal time zones, one for each hour of
							the day. In practice, however, there are around 38 different
							UTC offsets in use worldwide because countries adopt zones that
							don't align neatly with 15-degree segments. Some nations use
							half-hour or quarter-hour offsets, and daylight saving time adds
							further variation throughout the year.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>What is UTC and how does it work?</summary
					>
					<div class="wc-faq-answer">
						<p>
							UTC (Coordinated Universal Time) is the world's primary time
							standard. It is based on atomic clocks and is accurate to within
							a fraction of a second. All time zones are defined as an offset
							from UTC — for example, UTC+1 is one hour ahead and UTC−8 is eight
							hours behind. UTC occasionally adds a leap second to stay aligned
							with Earth's rotation, though leap seconds are being phased out.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>Which country has the most time zones?</summary
					>
					<div class="wc-faq-answer">
						<p>
							France holds the record with 12 or 13 time zones, depending on how
							overseas territories are counted — including locations in the
							Pacific, Indian Ocean, and South America. Russia spans 11 time
							zones across its vast territory, and the United States covers 11
							when including territories like Guam and American Samoa.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>What is the International Date Line?</summary
					>
					<div class="wc-faq-answer">
						<p>
							The International Date Line is an imaginary boundary running
							roughly along the 180° meridian in the Pacific Ocean. Crossing it
							eastward moves the calendar back one day; crossing westward moves
							it forward one day. It exists so that neighbouring regions on
							opposite sides of the globe don't share the same date while being
							24 hours apart in local time. The line zigzags around island
							nations to keep entire countries on the same calendar day.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>Why do some countries have half-hour time zones?</summary
					>
					<div class="wc-faq-answer">
						<p>
							Half-hour and quarter-hour offsets exist because political and
							geographic boundaries don't always align with neat 15-degree
							longitude segments. India uses UTC+5:30 so that the entire
							country shares one time zone despite spanning nearly 30 degrees of
							longitude. Nepal uses UTC+5:45, and Australia's Lord Howe Island
							uses UTC+10:30 in summer and UTC+11 in winter. These offsets
							reflect practical decisions about national unity and local solar
							time.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>What is daylight saving time and which countries use it?</summary
					>
					<div class="wc-faq-answer">
						<p>
							Daylight saving time (DST) shifts clocks forward by one hour in
							spring and back in autumn to make better use of evening daylight.
							It is used in parts of North America, Europe, Australia, and a
							handful of other regions — but not uniformly. Many countries,
							including Japan, India, and most of Africa, do not observe DST at
							all. Clockr automatically reflects DST changes through IANA
							timezone data, so city times stay accurate year-round.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>What is the biggest time difference between two places on Earth?</summary
					>
					<div class="wc-faq-answer">
						<p>
							The maximum offset between two inhabited places is 26 hours.
							Howland and Baker Islands in the Pacific (UTC−12) are a full day
							behind Kiritimati in Kiribati (UTC+14) — so when it is noon on
							Monday in Kiritimati, it is still 10:00 on Sunday in Howland
							Island. Even between major cities, the gap can be 20 hours or
							more, such as between Honolulu and Auckland.
						</p>
					</div>
				</details>
				<details class="wc-faq-item">
					<summary class="wc-faq-question"
						>What time zone is GMT and is it the same as UTC?</summary
					>
					<div class="wc-faq-answer">
						<p>
							GMT (Greenwich Mean Time) is the time zone centred on the Royal
							Observatory in Greenwich, London. For almost all practical
							purposes, GMT and UTC are identical — both are at offset zero.
							Technically, GMT is based on Earth's rotation while UTC is based on
							atomic clocks, but the difference is less than a second. In
							winter, the UK uses GMT; in summer it switches to BST (British
							Summer Time, UTC+1).
						</p>
					</div>
				</details>
			</div>
		</section>

		<!-- RELATED TOOLS -->
		<div class="wc-related">
			<h3 class="wc-related-title">You might also like</h3>
			<div class="wc-related-grid">
				<a href="/timezone-converter" class="wc-related-card"
					><span class="wc-related-name">Time Zone Converter</span></a
				>
				<a href="/time-difference" class="wc-related-card"
					><span class="wc-related-name">Time Difference Calculator</span></a
				>
				<a href="/countdown-timer" class="wc-related-card"
					><span class="wc-related-name">Countdown Timer</span></a
				>
				<a href="/world-clock" class="wc-related-card"
					><span class="wc-related-name">World Clock</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.wc-page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.wc-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.wc-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.wc-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.wc-gradient {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.wc-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.wc-search-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		margin-bottom: 32px;
	}

	.wc-search-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 0.5px;
	}

	.wc-search {
		width: 100%;
		max-width: 480px;
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.3);
		border-radius: 12px;
		padding: 16px 24px;
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #ffffff;
		text-align: center;
		outline: none;
		transition: border-color 0.2s ease;
	}

	.wc-search::placeholder {
		color: rgba(255, 255, 255, 0.25);
	}

	.wc-search:focus {
		border-color: rgba(139, 92, 246, 0.8);
		box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);
	}

	.wc-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 12px;
		margin-bottom: 60px;
	}

	@media (min-width: 640px) {
		.wc-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.wc-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.wc-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 24px 20px;
		transition: border-color 0.2s ease;
	}

	.wc-card:hover {
		border-color: rgba(139, 92, 246, 0.35);
	}

	.wc-card[hidden] {
		display: none;
	}

	.wc-card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 16px;
		gap: 12px;
	}

	.wc-card-location {
		min-width: 0;
	}

	.wc-city {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #ffffff;
		letter-spacing: -0.3px;
		margin-bottom: 2px;
	}

	.wc-country {
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.35);
	}

	.wc-flag {
		font-size: 22px;
		line-height: 1;
		flex-shrink: 0;
		opacity: 0.85;
	}

	.wc-time {
		font-family: 'Outfit', sans-serif;
		font-size: 36px;
		font-weight: 900;
		letter-spacing: -1px;
		line-height: 1;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 8px;
		font-variant-numeric: tabular-nums;
	}

	.wc-date {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.5);
		margin-bottom: 6px;
		line-height: 1.4;
	}

	.wc-offset {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.3);
	}

	.wc-empty {
		text-align: center;
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.4);
		margin: -40px 0 60px;
	}

	.wc-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.wc-how {
		margin-bottom: 48px;
	}

	.wc-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.wc-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.wc-how-card p:last-child {
		margin-bottom: 0;
	}

	.wc-faq {
		margin-bottom: 48px;
	}

	.wc-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.wc-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.wc-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.wc-faq-question::-webkit-details-marker {
		display: none;
	}

	.wc-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.wc-faq-item[open] .wc-faq-question::after {
		content: '−';
	}

	.wc-faq-answer {
		padding: 0 24px 18px;
	}

	.wc-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.wc-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.wc-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.wc-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.wc-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.wc-related-card:hover {
		border-color: rgba(0, 229, 196, 0.4);
	}

	.wc-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	@media (max-width: 639px) {
		.wc-title {
			font-size: 48px;
			letter-spacing: -2px;
		}

		.wc-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const timeFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const dateFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const offsetFormatterCache = new Map<string, Intl.DateTimeFormat>();

	function getTimeFormatter(timeZone: string) {
		if (!timeFormatterCache.has(timeZone)) {
			timeFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					hour: '2-digit',
					minute: '2-digit',
					second: '2-digit',
					hour12: false,
				}),
			);
		}
		return timeFormatterCache.get(timeZone)!;
	}

	function getDateFormatter(timeZone: string) {
		if (!dateFormatterCache.has(timeZone)) {
			dateFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					weekday: 'long',
					day: 'numeric',
					month: 'long',
					year: 'numeric',
				}),
			);
		}
		return dateFormatterCache.get(timeZone)!;
	}

	function getOffsetFormatter(timeZone: string) {
		if (!offsetFormatterCache.has(timeZone)) {
			offsetFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					timeZoneName: 'shortOffset',
				}),
			);
		}
		return offsetFormatterCache.get(timeZone)!;
	}

	function formatOffset(timeZone: string, now: Date): string {
		const parts = getOffsetFormatter(timeZone).formatToParts(now);
		const raw = parts.find((p) => p.type === 'timeZoneName')?.value ?? '';
		return raw.replace('GMT', 'UTC');
	}

	function updateClocks() {
		const now = new Date();
		const cards = document.querySelectorAll<HTMLElement>('.wc-card');

		cards.forEach((card) => {
			const timeZone = card.dataset.timezone;
			if (!timeZone) return;

			const timeEl = card.querySelector('[data-time]');
			const dateEl = card.querySelector('[data-date]');
			const offsetEl = card.querySelector('[data-offset]');

			if (timeEl) timeEl.textContent = getTimeFormatter(timeZone).format(now);
			if (dateEl) dateEl.textContent = getDateFormatter(timeZone).format(now);
			if (offsetEl) offsetEl.textContent = formatOffset(timeZone, now);
		});
	}

	function filterCities() {
		const search = document.getElementById('wc-search') as HTMLInputElement;
		const empty = document.getElementById('wc-empty');
		const cards = document.querySelectorAll<HTMLElement>('.wc-card');
		const query = (search?.value ?? '').trim().toLowerCase();

		let visible = 0;

		cards.forEach((card) => {
			const isSearchOnly = card.hasAttribute('data-search-only');
			const city = card.dataset.city ?? '';
			const country = card.dataset.country ?? '';
			const match = city.includes(query) || country.includes(query);

			if (!query) {
				card.hidden = isSearchOnly;
				if (!isSearchOnly) visible++;
			} else {
				card.hidden = !match;
				if (match) visible++;
			}
		});

		if (empty) empty.hidden = visible > 0;
	}

	updateClocks();
	setInterval(updateClocks, 1000);

	const searchInput = document.getElementById('wc-search');
	searchInput?.addEventListener('input', filterCities);
</script>
