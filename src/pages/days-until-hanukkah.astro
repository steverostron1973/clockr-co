---
import Layout from '../layouts/Layout.astro';
import {
	formatHanukkahDate,
	getHanukkahDatesForClient,
	getNextHanukkah,
} from '../data/hanukkahDates';

const nextHanukkah = getNextHanukkah(new Date());
const targetYear = nextHanukkah.year;
const targetDateLabel = formatHanukkahDate(nextHanukkah.date);
const hanukkahDates = getHanukkahDatesForClient();

const leftEmojis = [
	{ emoji: '🕎', size: 48, rotation: -15, top: '10%', side: '2%', delay: 0 },
	{ emoji: '🕯️', size: 32, rotation: 12, top: '25%', side: '8%', delay: 0.5 },
	{ emoji: '✨', size: 40, rotation: -8, top: '45%', side: '4%', delay: 1 },
	{ emoji: '🌟', size: 28, rotation: 15, top: '65%', side: '10%', delay: 1.5 },
	{ emoji: '🕎', size: 44, rotation: -12, top: '80%', side: '6%', delay: 2 },
	{ emoji: '✨', size: 36, rotation: 8, top: '35%', side: '2%', delay: 2.5 },
];

const rightEmojis = [
	{ emoji: '🕯️', size: 36, rotation: -5, top: '15%', side: '3%', delay: 3 },
	{ emoji: '🕎', size: 48, rotation: 14, top: '30%', side: '9%', delay: 3.5 },
	{ emoji: '✨', size: 30, rotation: -10, top: '50%', side: '5%', delay: 4 },
	{ emoji: '🌟', size: 42, rotation: 6, top: '70%', side: '8%', delay: 4.5 },
	{ emoji: '🕯️', size: 28, rotation: -15, top: '85%', side: '4%', delay: 5 },
	{ emoji: '🕎', size: 46, rotation: 10, top: '40%', side: '2%', delay: 5.5 },
];
---

<Layout
	title={`Days Until Hanukkah ${targetYear} — Hanukkah Countdown | Clockr`}
	description={`How many days until Hanukkah ${targetYear}? Live countdown to the Festival of Lights — ${targetDateLabel}.`}
	category="religious"
>
	<div class="hanukkah-page">
		<section class="hanukkah-hero" aria-label="Hanukkah countdown">
			<div class="hanukkah-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="hanukkah-float-emoji hanukkah-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="hanukkah-float-emoji hanukkah-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
			</div>

			<div class="hanukkah-hero-centre">
				<h1 class="hanukkah-hero-title">Days Until Hanukkah</h1>
				<p class="hanukkah-hero-subtitle">Countdown to the Festival of Lights</p>

				<div class="hanukkah-countdown" id="hanukkah-countdown">
					<div class="hanukkah-countdown-block">
						<span
							class="hanukkah-countdown-num hanukkah-countdown-num--days"
							id="hero-days">0</span
						>
						<span class="hanukkah-countdown-unit">Days</span>
					</div>
					<span class="hanukkah-countdown-sep">:</span>
					<div class="hanukkah-countdown-block">
						<span class="hanukkah-countdown-num" id="hero-hours">00</span>
						<span class="hanukkah-countdown-unit">Hours</span>
					</div>
					<span class="hanukkah-countdown-sep">:</span>
					<div class="hanukkah-countdown-block">
						<span class="hanukkah-countdown-num" id="hero-mins">00</span>
						<span class="hanukkah-countdown-unit">Minutes</span>
					</div>
					<span class="hanukkah-countdown-sep">:</span>
					<div class="hanukkah-countdown-block">
						<span class="hanukkah-countdown-num" id="hero-secs">00</span>
						<span class="hanukkah-countdown-unit">Seconds</span>
					</div>
				</div>

				<p class="hanukkah-target-date" id="hero-target-date">{targetDateLabel}</p>
			</div>
		</section>

		<div class="hanukkah-body">
			<section class="hanukkah-stats-section">
				<h2 class="hanukkah-stats-heading">Hanukkah by the numbers</h2>
				<div class="hanukkah-stats-grid">
					<div class="hanukkah-stat-card">
						<div class="hanukkah-stat-label">First night of Hanukkah</div>
						<div class="hanukkah-stat-value" id="stat-date">—</div>
					</div>
					<div class="hanukkah-stat-card">
						<div class="hanukkah-stat-label">Day of the week</div>
						<div class="hanukkah-stat-value" id="stat-weekday">—</div>
					</div>
					<div class="hanukkah-stat-card">
						<div class="hanukkah-stat-label">Weeks until Hanukkah</div>
						<div class="hanukkah-stat-value" id="stat-weeks">—</div>
					</div>
					<div class="hanukkah-stat-card">
						<div class="hanukkah-stat-label">Exact time remaining</div>
						<div class="hanukkah-stat-value" id="stat-exact">—</div>
					</div>
				</div>
			</section>

			<button class="hanukkah-share-btn" id="hanukkah-share-btn"
				>📋 Copy &amp; Share</button
			>

			<section class="hanukkah-about">
				<h2 class="hanukkah-section-title">About Hanukkah</h2>
				<div class="hanukkah-about-card">
					<p>
						Hanukkah (Chanukah) is the Jewish eight-day festival of lights,
						commemorating the rededication of the Second Temple in Jerusalem
						after the Maccabean revolt. According to tradition, a single day's
						supply of oil miraculously burned for eight nights — a symbol of
						perseverance and hope that inspires the nightly lighting of the
						menorah.
					</p>
					<p>
						Families celebrate by lighting one additional candle on the
						hanukkiah each evening, playing dreidel, eating foods fried in oil
						such as latkes and sufganiyot, and exchanging gifts. Though a
						minor festival in the Jewish calendar, Hanukkah is widely observed
						across the Jewish diaspora and has become a cherished winter
						celebration of light overcoming darkness.
					</p>
				</div>
			</section>

			<section class="hanukkah-how">
				<h2 class="hanukkah-section-title">How is the Hanukkah countdown calculated?</h2>
				<div class="hanukkah-how-card">
					<p>
						This countdown targets midnight on the first day of Hanukkah in
						your local time zone — the calendar date when the festival begins.
						The dates shown follow the Hebrew lunisolar calendar, when Hanukkah
						always starts on 25 Kislev. The display updates every second with
						the precise days, hours, minutes, and seconds remaining.
					</p>
					<p>
						Because the Hebrew calendar adds a leap month roughly every three
						years, Hanukkah can shift more dramatically in the Gregorian
						calendar than some other religious holidays — anywhere from late
						November to late December. Once the current year's date has passed,
						the countdown automatically rolls forward to the next listed
						Hanukkah.
					</p>
				</div>
			</section>

			<section class="hanukkah-faq">
				<h2 class="hanukkah-section-title">Frequently asked questions</h2>
				<div class="hanukkah-faq-list">
					<details class="hanukkah-faq-item">
						<summary class="hanukkah-faq-question"
							>Why does the date of Hanukkah change every year?</summary
						>
						<div class="hanukkah-faq-answer">
							<p>
								Hanukkah always begins on 25 Kislev in the Hebrew calendar,
								but that date maps to different Gregorian dates each year
								because the Jewish year is lunisolar — it follows the moon's
								cycles while staying aligned with the seasons through periodic
								leap months. Hanukkah typically falls between late November
								and late December on the civil calendar.
							</p>
						</div>
					</details>
					<details class="hanukkah-faq-item">
						<summary class="hanukkah-faq-question"
							>How long does Hanukkah last?</summary
						>
						<div class="hanukkah-faq-answer">
							<p>
								Hanukkah lasts eight nights and days, commemorating the miracle
								of the oil that burned for eight days. Each evening, one
								additional candle is lit on the hanukkiah (menorah) until all
								eight candles plus the shamash (helper candle) are glowing on
								the final night. This countdown targets the first night of the
								festival.
							</p>
						</div>
					</details>
					<details class="hanukkah-faq-item">
						<summary class="hanukkah-faq-question"
							>When does Hanukkah actually begin each night?</summary
						>
						<div class="hanukkah-faq-answer">
							<p>
								In Jewish tradition, a new day begins at sundown, not midnight.
								The first candle is lit at sundown on the evening before the
								calendar date shown on this page. For example, if Hanukkah
								falls on 4 December, families light the first candle on the
								evening of 3 December. This countdown uses midnight on the
								listed date as its target for consistency with other Clockr
								countdowns.
							</p>
						</div>
					</details>
					<details class="hanukkah-faq-item">
						<summary class="hanukkah-faq-question"
							>What is the difference between a menorah and a hanukkiah?</summary
						>
						<div class="hanukkah-faq-answer">
							<p>
								A menorah is the seven-branched candelabrum described in the
								Torah and used in the ancient Temple. A hanukkiah is the
								nine-branched candelabrum used specifically at Hanukkah — eight
								candles for the eight nights, plus a ninth shamash candle used
								to light the others. Both are symbols of light, but only the
								hanukkiah is used during the festival.
							</p>
						</div>
					</details>
				</div>
			</section>

			<div class="hanukkah-related">
				<h3 class="hanukkah-related-title">Related tools</h3>
				<div class="hanukkah-related-grid">
					<a href="/days-until-diwali" class="hanukkah-related-card"
						><span class="hanukkah-related-name">Days Until Diwali</span></a
					>
					<a href="/days-until-ramadan" class="hanukkah-related-card"
						><span class="hanukkah-related-name">Days Until Ramadan</span></a
					>
					<a href="/religious-calendars" class="hanukkah-related-card"
						><span class="hanukkah-related-name">Religious Calendars</span></a
					>
					<a href="/days-until-easter" class="hanukkah-related-card"
						><span class="hanukkah-related-name">Days Until Easter</span></a
					>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
