	}

	.hanukkah-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.hanukkah-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(232, 147, 122, 0.15);
		border-radius: 14px;
