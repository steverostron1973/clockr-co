	}

	.hanukkah-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hanukkah-faq-question::-webkit-details-marker {
		display: none;
	}

	.hanukkah-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hanukkah-faq-item[open] .hanukkah-faq-question::after {
		content: '−';
	}

	.hanukkah-faq-answer {
