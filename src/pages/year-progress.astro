---
import Layout from '../layouts/Layout.astro';

const YEAR = 2026;
const MONTH_NAMES = [
	'January',
	'February',
	'March',
	'April',
	'May',
	'June',
	'July',
	'August',
	'September',
	'October',
	'November',
	'December',
];
---

<Layout
	title="Year Progress Bar 2026 — How Much of the Year is Left | Clockr"
	description="See exactly how much of 2026 has passed and how much is left. Real-time year progress bar updated to the second."
>
	<div class="yp-page">
		<!-- PAGE HEADER -->
		<div class="yp-header">
			<div class="yp-eyebrow">📅 Year in Review</div>
			<h1 class="yp-title">
				<span class="yp-gradient">Year Progress</span>
			</h1>
			<p class="yp-subtitle">How much of 2026 is gone?</p>
		</div>

		<!-- MAIN PROGRESS -->
		<div class="yp-main-card">
			<div class="yp-percent" id="yp-percent">0.00%</div>
			<div class="yp-bar-track">
				<div class="yp-bar-fill" id="yp-bar-fill"></div>
			</div>
			<p class="yp-message" id="yp-message">Loading...</p>
		</div>

		<!-- STATS GRID -->
		<div class="yp-grid">
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-days-elapsed">0</div>
				<div class="yp-stat-label">Days elapsed</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-days-remaining">0</div>
				<div class="yp-stat-label">Days remaining</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-weeks-elapsed">0</div>
				<div class="yp-stat-label">Weeks elapsed</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-weeks-remaining">0</div>
				<div class="yp-stat-label">Weeks remaining</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-hours-elapsed">0</div>
				<div class="yp-stat-label">Hours elapsed</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-hours-remaining">0</div>
				<div class="yp-stat-label">Hours remaining</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-day-of-year">Day 0 of 365</div>
				<div class="yp-stat-label">Day of the year</div>
			</div>
			<div class="yp-stat-card">
				<div class="yp-stat-num" id="yp-week-number">0</div>
				<div class="yp-stat-label">Week number</div>
			</div>
		</div>

		<!-- MONTH COMPARISON -->
		<div class="yp-months-section">
			<h2 class="yp-months-title">How this year compares</h2>
			<div class="yp-months-list" id="yp-months-list">
				{
					MONTH_NAMES.map((name) => (
						<div class="yp-month-row">
							<span class="yp-month-name">{name}</span>
							<div class="yp-month-track">
								<div class="yp-month-fill" data-month={name} />
							</div>
							<span class="yp-month-pct" data-month-pct={name}>
								0%
							</span>
						</div>
					))
				}
			</div>
		</div>

		<!-- SHARE -->
		<button class="yp-share" id="yp-share-btn">📋 Copy &amp; Share</button>

		<!-- RELATED TOOLS -->
		<div class="yp-related">
			<h3 class="yp-related-title">You might also like</h3>
			<div class="yp-related-grid">
				<a href="/countdown-timer" class="yp-related-card">⏱️ Countdown Timer</a>
				<a href="/age-calculator" class="yp-related-card">🎂 Age Calculator</a>
				<a href="/date-calculator" class="yp-related-card">📅 Date Calculator</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.yp-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.yp-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.yp-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.yp-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.yp-gradient {
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.yp-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.yp-main-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 92, 77, 0.2);
		border-radius: 20px;
		padding: 40px;
		text-align: center;
		margin-bottom: 16px;
		box-shadow: 0 0 40px rgba(255, 92, 77, 0.06);
	}

	.yp-percent {
		font-family: 'Outfit', sans-serif;
		font-size: 72px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 24px;
	}

	.yp-bar-track {
		width: 100%;
		height: 24px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 20px;
	}

	.yp-bar-fill {
		height: 100%;
		width: 0%;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		border-radius: 12px;
		transition: width 0.3s ease;
		box-shadow: 0 0 20px rgba(255, 92, 77, 0.4);
	}

	.yp-message {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.5;
		min-height: 1.5em;
		transition: opacity 0.4s ease;
	}

	.yp-message.yp-message-fade {
		opacity: 0;
	}

	.yp-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 12px;
		margin-bottom: 32px;
	}

	.yp-stat-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 92, 77, 0.15);
		border-radius: 14px;
		padding: 24px 12px;
		text-align: center;
	}

	.yp-stat-num {
		font-family: 'Outfit', sans-serif;
		font-size: 28px;
		font-weight: 900;
		letter-spacing: -1px;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 6px;
	}

	.yp-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
	}

	.yp-months-section {
		background: #0c0c0c;
		border: 1px solid rgba(255, 92, 77, 0.15);
		border-radius: 20px;
		padding: 32px;
		margin-bottom: 24px;
	}

	.yp-months-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 24px;
	}

	.yp-months-list {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.yp-month-row {
		display: grid;
		grid-template-columns: 100px 1fr 48px;
		align-items: center;
		gap: 12px;
	}

	.yp-month-name {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.5);
	}

	.yp-month-track {
		height: 8px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 4px;
		overflow: hidden;
	}

	.yp-month-fill {
		height: 100%;
		width: 0%;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		border-radius: 4px;
		transition: width 0.3s ease;
	}

	.yp-month-pct {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.4);
		text-align: right;
	}

	.yp-share {
		display: block;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		max-width: 320px;
		margin: 0 auto 60px;
		transition: opacity 0.2s ease;
	}

	.yp-share:hover {
		opacity: 0.9;
	}

	.yp-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.yp-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.yp-related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.yp-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.yp-related-card:hover {
		border-color: rgba(255, 92, 77, 0.4);
		color: #fff;
	}

	@media (max-width: 640px) {
		.yp-title {
			font-size: 48px;
		}

		.yp-percent {
			font-size: 52px;
		}

		.yp-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.yp-related-grid {
			grid-template-columns: 1fr;
		}

		.yp-month-row {
			grid-template-columns: 80px 1fr 40px;
		}
	}
</style>

<script define:vars={{ YEAR, MONTH_NAMES }}>
	const MS_PER_SECOND = 1000;
	const MS_PER_MINUTE = 60 * MS_PER_SECOND;
	const MS_PER_HOUR = 60 * MS_PER_MINUTE;
	const MS_PER_DAY = 24 * MS_PER_HOUR;

	const yearStart = new Date(YEAR, 0, 1, 0, 0, 0, 0);
	const yearEnd = new Date(YEAR + 1, 0, 1, 0, 0, 0, 0);
	const yearDurationMs = yearEnd.getTime() - yearStart.getTime();
	const totalDaysInYear = Math.round(yearDurationMs / MS_PER_DAY);

	let lastMessage = '';

	function formatNumber(n) {
		return n.toLocaleString();
	}

	function getWeekNumber(date) {
		const d = new Date(
			Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()),
		);
		const dayNum = d.getUTCDay() || 7;
		d.setUTCDate(d.getUTCDate() + 4 - dayNum);
		const yearStartWeek = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
		return Math.ceil(
			((d.getTime() - yearStartWeek.getTime()) / MS_PER_DAY + 1) / 7,
		);
	}

	function getMessage(percent) {
		if (percent < 10) return 'Fresh start. Anything is possible.';
		if (percent < 25) return 'Still early — the year has barely begun.';
		if (percent < 50) return "One quarter down. How's that resolution going?";
		if (percent < 75) return 'Halfway. The year is at halftime.';
		if (percent < 90) return 'Three quarters gone. Make the last stretch count.';
		return 'Almost out of year. No pressure.';
	}

	function getMonthProgress(now, monthIndex) {
		const currentMonth = now.getFullYear() === YEAR ? now.getMonth() : -1;

		if (now.getFullYear() < YEAR) return 0;
		if (now.getFullYear() > YEAR) return 100;

		if (monthIndex < currentMonth) return 100;
		if (monthIndex > currentMonth) return 0;

		const monthStart = new Date(YEAR, monthIndex, 1, 0, 0, 0, 0);
		const monthEnd = new Date(YEAR, monthIndex + 1, 1, 0, 0, 0, 0);
		const elapsed = now.getTime() - monthStart.getTime();
		const duration = monthEnd.getTime() - monthStart.getTime();
		return Math.min(100, Math.max(0, (elapsed / duration) * 100));
	}

	function updateMessage(percent) {
		const messageEl = document.getElementById('yp-message');
		if (!messageEl) return;

		const newMessage = getMessage(percent);
		if (newMessage === lastMessage) return;

		messageEl.classList.add('yp-message-fade');
		setTimeout(() => {
			messageEl.textContent = newMessage;
			messageEl.classList.remove('yp-message-fade');
			lastMessage = newMessage;
		}, 200);
	}

	function update() {
		const now = new Date();

		let elapsedMs = now.getTime() - yearStart.getTime();
		if (now.getFullYear() < YEAR) elapsedMs = 0;
		if (now.getFullYear() > YEAR) elapsedMs = yearDurationMs;

		const remainingMs = Math.max(0, yearDurationMs - elapsedMs);
		const percent = Math.min(100, Math.max(0, (elapsedMs / yearDurationMs) * 100));

		const daysElapsed = Math.floor(elapsedMs / MS_PER_DAY);
		const daysRemaining = Math.max(0, totalDaysInYear - daysElapsed);
		const weeksElapsed = Math.floor(daysElapsed / 7);
		const weeksRemaining = Math.ceil(daysRemaining / 7);
		const hoursElapsed = Math.floor(elapsedMs / MS_PER_HOUR);
		const hoursRemaining = Math.floor(remainingMs / MS_PER_HOUR);
		const dayOfYear = Math.min(totalDaysInYear, daysElapsed + 1);
		const weekNumber =
			now.getFullYear() === YEAR ? getWeekNumber(now) : now.getFullYear() > YEAR ? 52 : 1;

		const percentEl = document.getElementById('yp-percent');
		const barFill = document.getElementById('yp-bar-fill');
		if (percentEl) percentEl.textContent = percent.toFixed(2) + '%';
		if (barFill) barFill.style.width = percent + '%';

		updateMessage(percent);

		const setText = (id, text) => {
			const el = document.getElementById(id);
			if (el) el.textContent = text;
		};

		setText('yp-days-elapsed', formatNumber(daysElapsed));
		setText('yp-days-remaining', formatNumber(daysRemaining));
		setText('yp-weeks-elapsed', formatNumber(weeksElapsed));
		setText('yp-weeks-remaining', formatNumber(weeksRemaining));
		setText('yp-hours-elapsed', formatNumber(hoursElapsed));
		setText('yp-hours-remaining', formatNumber(hoursRemaining));
		setText('yp-day-of-year', `Day ${dayOfYear} of ${totalDaysInYear}`);
		setText('yp-week-number', String(weekNumber));

		MONTH_NAMES.forEach((name, index) => {
			const monthPct = getMonthProgress(now, index);
			const fill = document.querySelector(
				`.yp-month-fill[data-month="${name}"]`,
			);
			const pctLabel = document.querySelector(
				`.yp-month-pct[data-month-pct="${name}"]`,
			);
			if (fill) fill.style.width = monthPct + '%';
			if (pctLabel) pctLabel.textContent = Math.round(monthPct) + '%';
		});
	}

	const shareBtn = document.getElementById('yp-share-btn');
	if (shareBtn) {
		shareBtn.addEventListener('click', () => {
			const percentEl = document.getElementById('yp-percent');
			const pct = percentEl?.textContent?.replace('%', '') ?? '0.00';
			const url = window.location.href;
			navigator.clipboard.writeText(
				`${YEAR} is ${pct}% complete. ${url}`,
			);
			shareBtn.textContent = '✓ Copied!';
			setTimeout(() => {
				shareBtn.textContent = '📋 Copy & Share';
			}, 2000);
		});
	}

	update();
	setInterval(update, 1000);
</script>
