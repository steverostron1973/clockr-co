---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy | Clockr"
	description="Clockr does not collect, store, or share any personal data. All calculations are performed entirely within your browser."
>
	<div class="content-page">
		<div class="content-header">
			<div class="content-eyebrow">🔒 Legal</div>
			<h1 class="content-title">
				<span class="content-gradient">Privacy Policy</span>
			</h1>
		</div>

		<div class="content-card">
			<p>
				Clockr does not collect, store, or share any personal data. All
				calculations are performed entirely within your browser. No information
				you enter is transmitted to any server.
			</p>
			<p>
				This site uses Google AdSense to display advertisements. Google may use
				cookies to serve ads based on your visit. You can opt out of personalised
				advertising by visiting
				<a
					href="https://adssettings.google.com"
					target="_blank"
					rel="noopener noreferrer">Google's Ad Settings</a
				>.
			</p>
			<p>
				This site may use anonymous analytics to understand traffic patterns. No
				personally identifiable information is collected.
			</p>
			<p class="content-meta">Last updated: July 2026</p>
		</div>
	</div>
</Layout>

<style>
	.content-page {
		max-width: 720px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.content-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.content-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		margin-bottom: 16px;
	}

	.content-title {
		font-family: 'Outfit', sans-serif;
		font-size: 56px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin: 0;
	}

	.content-gradient {
		background: var(--cat-gradient, linear-gradient(135deg, #FF5C4D, #FF9A3C));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.content-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 20px;
		padding: 40px;
	}

	.content-card p {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.7;
		margin: 0 0 20px;
	}

	.content-card p:last-child {
		margin-bottom: 0;
	}

	.content-meta {
		font-size: 14px !important;
		color: rgba(255, 255, 255, 0.4) !important;
	}

	.content-card a {
		color: #FF5C4D;
		text-decoration: none;
	}

	.content-card a:hover {
		text-decoration: underline;
	}

	@media (max-width: 600px) {
		.content-title {
			font-size: 40px;
			letter-spacing: -2px;
		}

		.content-card {
			padding: 28px 24px;
		}
	}
</style>
