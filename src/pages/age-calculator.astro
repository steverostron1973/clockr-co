---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Age Calculator — Clockr.co"
	description="Find out exactly how old you are in years, months, days, hours, minutes and seconds. Your age calculated precisely."
>
	<div class="age-page">
		<!-- PAGE HEADER -->
		<div class="age-header">
			<div class="age-eyebrow">🎂 Age & Birthdays</div>
			<h1 class="age-title">
				<span class="age-gradient">How old are</span><br />
				<span class="age-gradient">you, exactly?</span>
			</h1>
			<p class="age-subtitle">
				Enter your date of birth and discover your exact age — down to the
				second.
			</p>
		</div>

		<!-- INPUT -->
		<div class="age-input-wrap">
			<label class="age-label" for="dob-input">Your date of birth</label>
			<input type="date" id="dob-input" class="age-input" />
		</div>

		<!-- RESULTS — hidden until date entered -->
		<div class="age-results" id="age-results" style="display:none">
			<!-- MAIN AGE DISPLAY -->
			<div class="age-main-card">
				<div class="age-main-num" id="age-years">0</div>
				<div class="age-main-label">years old</div>
				<div class="age-exact" id="age-exact">0 years, 0 months, 0 days</div>
			</div>

			<!-- BREAKDOWN GRID -->
			<div class="age-grid">
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-days">0</div>
					<div class="age-stat-label">Days alive</div>
				</div>
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-weeks">0</div>
					<div class="age-stat-label">Weeks alive</div>
				</div>
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-hours">0</div>
					<div class="age-stat-label">Hours alive</div>
				</div>
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-seconds">0</div>
					<div class="age-stat-label">Seconds alive</div>
				</div>
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-christmases">0</div>
					<div class="age-stat-label">Christmases experienced</div>
				</div>
				<div class="age-stat-card">
					<div class="age-stat-num" id="age-mondays">0</div>
					<div class="age-stat-label">Mondays survived</div>
				</div>
			</div>

			<!-- NEXT MILESTONE -->
			<div class="age-milestone-card">
				<div class="age-milestone-label">⚡ Your next milestone</div>
				<div class="age-milestone-text" id="age-milestone">Loading...</div>
			</div>

			<!-- FUN FACT -->
			<div class="age-fact-card">
				<div class="age-fact-text" id="age-fact">Loading...</div>
			</div>

			<!-- SHARE BUTTON -->
			<button class="age-share" id="age-share-btn">📤 Share my age</button>
		</div>

		<!-- HOW IT WORKS -->
		<section class="age-how">
			<h2 class="age-section-title">How does an age calculator work?</h2>
			<div class="age-how-card">
				<p>
					An age calculator works by comparing your date of birth to today's
					date. It starts by finding the difference in full years — how many
					complete birthdays you have celebrated — then calculates any remaining
					months and days between your last birthday and today. The result is
					your age expressed as years, months, and days rather than a single
					number.
				</p>
				<p>
					The exact calculation is more complex than simply subtracting one year
					from another. Leap years add an extra day every four years, which
					affects the total number of days you have been alive. Months vary in
					length — from 28 days in February to 31 in January — so the number of
					days between two dates depends on which months fall in between. Time
					zones can also shift the precise moment your age changes, especially
					if you were born near midnight in a different zone than where you live
					now.
				</p>
				<p>
					Clockr calculates your age down to the second by measuring the
					difference in milliseconds between your birth date and the current
					moment. That total is converted into years, months, days, hours,
					minutes, and seconds — and the display updates every second so you can
					watch your age tick upward in real time.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="age-faq">
			<h2 class="age-section-title">Frequently asked questions</h2>
			<div class="age-faq-list">
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>How do I calculate my exact age?</summary
					>
					<div class="age-faq-answer">
						<p>
							Enter your date of birth into Clockr's age calculator above. The
							tool instantly compares your birth date to the current date and
							time, breaking your age down into years, months, days, hours,
							minutes, and seconds. For the most accurate result, use your
							actual date of birth — the calculator updates every second, so you
							always see your precise age right now.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>Why is my age different in different countries?</summary
					>
					<div class="age-faq-answer">
						<p>
							Different cultures count age differently. In most Western
							countries, you turn a new age on your birthday — so you become
							one year older at midnight on that date each year. In some East
							Asian traditions, people were historically considered one year old
							at birth and gained a year at the Lunar New Year rather than on
							their birthday. Legal definitions of adulthood also vary: the age
							of majority is 18 in most countries but 20 in Japan and 21 in
							some others. Time zones can also affect the exact moment your age
							changes if your birth time falls near midnight.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>What is the most common birthday in the world?</summary
					>
					<div class="age-faq-answer">
						<p>
							Birth patterns vary by country, but data from the United States
							and several European nations consistently shows September as the
							most common birth month. Within that month, 9 September and 10
							September frequently rank among the most common individual
							birthdays. Globally, summer and early autumn months tend to see
							higher birth rates in the Northern Hemisphere, while patterns
							differ in the Southern Hemisphere. No single day is the most common
							birthday everywhere in the world.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question">How old am I in days?</summary>
					<div class="age-faq-answer">
						<p>
							To find your age in days, count every calendar day from your date
							of birth to today, including leap days. You can multiply complete
							years by 365 or 366 and add the days since your last birthday, but
							the simplest approach is to subtract your birth date from today's
							date. Clockr does this automatically — enter your date of birth
							and the "Days alive" figure shows your exact total.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>What is the youngest age ever recorded for a world record?</summary
					>
					<div class="age-faq-answer">
						<p>
							Lina Medina of Peru holds the Guinness World Record as the
							youngest confirmed mother, giving birth at age 5 years and 7
							months in 1939. For survival records, the youngest premature
							babies to survive have been born at around 21 to 22 weeks
							gestation, weighing under one pound. These extraordinary cases
							represent the extreme lower limits of human development rather
							than typical childhood milestones.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>How do leap years affect my age calculation?</summary
					>
					<div class="age-faq-answer">
						<p>
							Leap years add an extra day on 29 February every four years (with
							century-year exceptions), giving those years 366 days instead of
							365. If you were born on 29 February, your official birthday in
							non-leap years is often celebrated on 28 February or 1 March. For
							your total age in days, each leap year you have lived through adds
							one extra day to your count. Clockr accounts for every leap year
							automatically when calculating your age.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question"
						>What age am I on my half birthday?</summary
					>
					<div class="age-faq-answer">
						<p>
							Your half birthday falls exactly six months after your actual
							birthday — or six months before your next one, depending on how
							you look at it. On that date you are halfway between two birthday
							ages. For example, if you turned 30 on 15 March, your half
							birthday is 15 September and you are "30 and a half." It is a fun
							milestone, though it has no legal significance in most countries.
						</p>
					</div>
				</details>
				<details class="age-faq-item">
					<summary class="age-faq-question">How many seconds old am I?</summary>
					<div class="age-faq-answer">
						<p>
							Multiply your total days alive by 86,400 — the number of seconds
							in a day — then add the seconds elapsed since midnight today. The
							result is a surprisingly large number. Clockr calculates this live:
							enter your date of birth above and watch the "Seconds alive"
							counter tick upward every second.
						</p>
					</div>
				</details>
			</div>
		</section>

		<!-- RELATED TOOLS -->
		<div class="age-related">
			<h3 class="age-related-title">You might also like</h3>
			<div class="age-related-grid">
				<a href="/life-in-numbers" class="age-related-card"
					><span class="age-related-name">Your Life in Numbers</span></a
				>
				<a href="/days-until-birthday" class="age-related-card"
					><span class="age-related-name">Days Until My Birthday</span></a
				>
				<a href="/age-on-other-planets" class="age-related-card"
					><span class="age-related-name">Your Age on Other Planets</span></a
				>
				<a href="/what-generation" class="age-related-card"
					><span class="age-related-name">What Generation Am I?</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.age-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.age-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.age-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.age-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.age-gradient {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.age-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.age-input-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		margin-bottom: 48px;
	}

	.age-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 0.5px;
	}

	.age-input {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.3);
		border-radius: 12px;
		padding: 16px 24px;
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #ffffff;
		text-align: center;
		outline: none;
		cursor: pointer;
		transition: border-color 0.2s ease;
	}

	.age-input:focus {
		border-color: rgba(139, 92, 246, 0.8);
		box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);
	}

	.age-main-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 20px;
		padding: 40px;
		text-align: center;
		margin-bottom: 16px;
		box-shadow: 0 0 40px rgba(139, 92, 246, 0.06);
	}

	.age-main-num {
		font-family: 'Outfit', sans-serif;
		font-size: 120px;
		font-weight: 900;
		letter-spacing: -6px;
		line-height: 1;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 8px;
	}

	.age-main-label {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.5);
		margin-bottom: 12px;
	}

	.age-exact {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.4);
	}

	.age-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		margin-bottom: 16px;
	}

	.age-stat-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 24px 16px;
		text-align: center;
	}

	.age-stat-num {
		font-family: 'Outfit', sans-serif;
		font-size: 32px;
		font-weight: 900;
		letter-spacing: -1px;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 6px;
	}

	.age-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
	}

	.age-milestone-card {
		background: rgba(139, 92, 246, 0.06);
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 14px;
		padding: 20px 24px;
		margin-bottom: 12px;
	}

	.age-milestone-label {
		font-family: 'Outfit', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 2px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 8px;
	}

	.age-milestone-text {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.5;
	}

	.age-fact-card {
		background: rgba(236, 72, 153, 0.05);
		border-left: 3px solid #ec4899;
		border-radius: 0 12px 12px 0;
		padding: 16px 20px;
		margin-bottom: 24px;
	}

	.age-fact-text {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.6;
	}

	.age-share {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		width: 100%;
		margin-bottom: 60px;
		transition: opacity 0.2s ease;
	}

	.age-share:hover {
		opacity: 0.9;
	}

	.age-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.age-how {
		margin-bottom: 48px;
	}

	.age-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.age-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.age-how-card p:last-child {
		margin-bottom: 0;
	}

	.age-faq {
		margin-bottom: 48px;
	}

	.age-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.age-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.age-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.age-faq-question::-webkit-details-marker {
		display: none;
	}

	.age-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.age-faq-item[open] .age-faq-question::after {
		content: '−';
	}

	.age-faq-answer {
		padding: 0 24px 18px;
	}

	.age-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.age-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.age-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.age-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.age-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.age-related-card:hover {
		border-color: rgba(139, 92, 246, 0.4);
	}

	.age-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>

<script>
	const dobInput = document.getElementById('dob-input') as HTMLInputElement;
	const results = document.getElementById('age-results');

	const funFacts = [
		"That's longer than it took to build the Great Wall of China — incredible.",
		"You've experienced more sunrises than there are pages in 14 copies of War and Peace.",
		"In that time, your heart has beaten approximately {beats} times. Extraordinary.",
		"You've lived through {weeks} weekends. Hope most of them were good ones.",
		"That's enough time to walk around the Earth's equator {walks} times at average walking pace.",
	];

	function formatNumber(n: number) {
		return n.toLocaleString();
	}

	function calculateAge() {
		if (!dobInput || !results) return;

		const dob = new Date(dobInput.value);
		if (!dobInput.value || isNaN(dob.getTime())) return;

		const now = new Date();
		const diff = now.getTime() - dob.getTime();

		if (diff < 0) return;

		results.style.display = 'block';

		const totalSeconds = Math.floor(diff / 1000);
		const totalMinutes = Math.floor(totalSeconds / 60);
		const totalHours = Math.floor(totalMinutes / 60);
		const totalDays = Math.floor(totalHours / 24);
		const totalWeeks = Math.floor(totalDays / 7);

		let years = now.getFullYear() - dob.getFullYear();
		let months = now.getMonth() - dob.getMonth();
		let days = now.getDate() - dob.getDate();

		if (days < 0) {
			months--;
			days += new Date(now.getFullYear(), now.getMonth(), 0).getDate();
		}
		if (months < 0) {
			years--;
			months += 12;
		}

		const yearsEl = document.getElementById('age-years');
		const exactEl = document.getElementById('age-exact');
		const daysEl = document.getElementById('age-days');
		const weeksEl = document.getElementById('age-weeks');
		const hoursEl = document.getElementById('age-hours');
		const secondsEl = document.getElementById('age-seconds');
		const christmasesEl = document.getElementById('age-christmases');
		const mondaysEl = document.getElementById('age-mondays');
		const milestoneEl = document.getElementById('age-milestone');
		const factEl = document.getElementById('age-fact');
		const shareBtn = document.getElementById('age-share-btn');

		if (yearsEl) yearsEl.textContent = String(years);
		if (exactEl)
			exactEl.textContent = `${years} years, ${months} months, ${days} days`;
		if (daysEl) daysEl.textContent = formatNumber(totalDays);
		if (weeksEl) weeksEl.textContent = formatNumber(totalWeeks);
		if (hoursEl) hoursEl.textContent = formatNumber(totalHours);
		if (secondsEl) secondsEl.textContent = formatNumber(totalSeconds);
		if (christmasesEl) christmasesEl.textContent = String(years);
		if (mondaysEl)
			mondaysEl.textContent = formatNumber(Math.floor(totalDays / 7));

		const nextMilestone = Math.ceil(totalDays / 1000) * 1000;
		const daysToMilestone = nextMilestone - totalDays;
		const milestoneDate = new Date(
			now.getTime() + daysToMilestone * 24 * 60 * 60 * 1000,
		);
		if (milestoneEl)
			milestoneEl.textContent = `Your ${formatNumber(nextMilestone)}th day alive is in ${daysToMilestone} days — on ${milestoneDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}.`;

		const factIndex = years % funFacts.length;
		const fact = funFacts[factIndex]
			.replace('{beats}', formatNumber((totalSeconds * 1.2) | 0))
			.replace('{weeks}', formatNumber(totalWeeks))
			.replace('{walks}', (totalDays / 365 * 0.12).toFixed(1));
		if (factEl) factEl.textContent = '💡 ' + fact;

		if (shareBtn) {
			shareBtn.onclick = () => {
				navigator.clipboard.writeText(
					`I've been alive for ${formatNumber(totalDays)} days, ${formatNumber(totalHours)} hours and ${formatNumber(totalSeconds)} seconds. Find out yours at Clockr.co 🎂`,
				);
				shareBtn.textContent = '✅ Copied to clipboard!';
				setTimeout(() => {
					shareBtn.textContent = '📤 Share my age';
				}, 2000);
			};
		}
	}

	dobInput?.addEventListener('change', calculateAge);
	setInterval(() => {
		if (dobInput?.value) calculateAge();
	}, 1000);
</script>
