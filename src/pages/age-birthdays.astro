---
import Layout from '../layouts/Layout.astro';

const tools = [
	{
		name: 'Age Calculator',
		description: 'How old are you, exactly?',
		href: '/age-calculator',
		emoji: '🎂',
	},
	{
		name: 'Age Difference Calculator',
		description: 'Compare the age gap between two people',
		href: '/age-difference-calculator',
		emoji: '👥',
	},
	{
		name: 'Days Until Birthday',
		description: 'Countdown to your next birthday',
		href: '/days-until-birthday',
		emoji: '🎈',
	},
	{
		name: 'Pregnancy Due Date Calculator',
		description: 'Estimate your due date and pregnancy week',
		href: '/pregnancy-due-date-calculator',
		emoji: '👶',
	},
	{
		name: 'Age on Other Planets',
		description: 'How old would you be on Mars?',
		href: '/age-on-other-planets',
		emoji: '🪐',
	},
	{
		name: 'Zodiac Sign Finder',
		description: 'Find your star sign from your date of birth',
		href: '/zodiac-sign-finder',
		emoji: '✨',
	},
];
---

<Layout
	title="Age & Birthdays — Age Calculators, Birthday Countdowns & More | Clockr"
	description="How old are you, exactly? Age calculators, birthday countdowns, pregnancy due dates, zodiac signs and more."
	category="birthdays"
>
	<div class="ab-page">
		<div class="ab-header">
			<div class="ab-eyebrow">
				<span class="ab-eyebrow-square" aria-hidden="true"></span>
				AGE & BIRTHDAYS
			</div>
			<h1 class="ab-title">
				<span class="ab-gradient">Age & Birthdays</span>
			</h1>
			<p class="ab-subtitle">How old are you, exactly?</p>
		</div>

		<div class="ab-grid">
			{
				tools.map((item) => (
					<a href={item.href} class="ab-card">
						<span class="ab-card-emoji" aria-hidden="true">
							{item.emoji}
						</span>
						<span class="ab-card-name">{item.name}</span>
						<span class="ab-card-desc">{item.description}</span>
					</a>
				))
			}
		</div>

		<section class="ab-how">
			<h2 class="ab-section-title">About age & birthday tools</h2>
			<div class="ab-how-card">
				<p>
					From exact age in years, months and days to birthday countdowns, due
					dates, and which zodiac sign you fall into — these tools turn a date of
					birth into clear, useful answers. Pick a card above to get started.
				</p>
			</div>
		</section>

		<div class="ab-related">
			<h3 class="ab-related-title">You might also like</h3>
			<div class="ab-related-grid">
				<a href="/milestones" class="ab-related-card"
					><span class="ab-related-name">Milestones</span></a
				>
				<a href="/holiday-countdowns" class="ab-related-card"
					><span class="ab-related-name">Holiday Countdowns</span></a
				>
				<a href="/create-countdown" class="ab-related-card"
					><span class="ab-related-name">Create Your Own Countdown</span></a
				>
				<a href="/fun-holidays" class="ab-related-card"
					><span class="ab-related-name">Fun & Unofficial Holidays</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.ab-page {
		max-width: 900px;
		margin: 0 auto;
		padding: 60px 24px 80px;
	}

	.ab-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.ab-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.ab-eyebrow-square {
		width: 8px;
		height: 8px;
		border-radius: 2px;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		flex-shrink: 0;
		-webkit-text-fill-color: initial;
	}

	.ab-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.ab-gradient {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.ab-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
		margin: 0;
		max-width: 540px;
		margin-inline: auto;
	}

	.ab-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 14px;
		margin-bottom: 56px;
	}

	@media (max-width: 640px) {
		.ab-grid {
			grid-template-columns: 1fr;
		}
	}

	.ab-card {
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 22px 20px;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.ab-card:hover {
		border-color: rgba(236, 72, 153, 0.45);
		transform: translateY(-3px);
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.35);
	}

	.ab-card-emoji {
		font-size: 28px;
		line-height: 1;
		margin-bottom: 4px;
	}

	.ab-card-name {
		font-family: 'Outfit', sans-serif;
		font-size: 17px;
		font-weight: 700;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.ab-card-desc {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.45);
		line-height: 1.5;
	}

	.ab-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ab-how {
		margin-bottom: 48px;
	}

	.ab-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.ab-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.ab-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.ab-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ab-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.ab-related-grid {
			grid-template-columns: 1fr;
		}
	}

	.ab-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.ab-related-card:hover {
		border-color: rgba(139, 92, 246, 0.4);
	}

	.ab-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
