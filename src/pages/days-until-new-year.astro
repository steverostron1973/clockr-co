</style>

<script>
	function pad(n: number) {
		return String(n).padStart(2, '0');
	}

	function getTargetNewYear(): Date {
		const now = new Date();
		let year = now.getFullYear();
		const newYear = new Date(year, 0, 1, 0, 0, 0, 0);
		if (now.getTime() >= newYear.getTime()) {
			year += 1;
		}
		return new Date(year, 0, 1, 0, 0, 0, 0);
	}

	function updateCountdown() {
		const now = new Date();
		const newYear = getTargetNewYear();
		const diff = newYear.getTime() - now.getTime();

		if (diff <= 0) return;

		const totalSeconds = Math.floor(diff / 1000);
		const days = Math.floor(totalSeconds / 86400);
		const hours = Math.floor((totalSeconds % 86400) / 3600);
		const mins = Math.floor((totalSeconds % 3600) / 60);
		const secs = totalSeconds % 60;
		const totalHours = Math.floor(totalSeconds / 3600);

		const heroDays = document.getElementById('hero-days');
		const heroHours = document.getElementById('hero-hours');
		const heroMins = document.getElementById('hero-mins');
		const heroSecs = document.getElementById('hero-secs');
		const statExact = document.getElementById('stat-exact');
		const statWeekday = document.getElementById('stat-weekday');
		const statWeeks = document.getElementById('stat-weeks');
		const statHours = document.getElementById('stat-hours');
		const shareDays = document.getElementById('share-days');

		if (heroDays) heroDays.textContent = String(days);
		if (heroHours) heroHours.textContent = pad(hours);
		if (heroMins) heroMins.textContent = pad(mins);
		if (heroSecs) heroSecs.textContent = pad(secs);

		const year = newYear.getFullYear();
		const weekday = newYear.toLocaleDateString('en-GB', { weekday: 'long' });
		const weeks = Math.floor(days / 7);

		if (statExact)
			statExact.textContent = `${days} days, ${hours} hours, ${mins} minutes, ${secs} seconds until 1 January ${year}`;
		if (statWeekday)
			statWeekday.textContent = `New Year ${year} falls on a ${weekday}`;
		if (statWeeks)
			statWeeks.textContent = `${weeks} week${weeks === 1 ? '' : 's'}`;
		if (statHours)
			statHours.textContent = `${totalHours.toLocaleString()} hour${totalHours === 1 ? '' : 's'}`;
		if (shareDays) shareDays.textContent = String(days);
	}

	const shareBtn = document.getElementById('ny-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = document.getElementById('share-days')?.textContent ?? '0';
		const newYear = getTargetNewYear();
		const year = newYear.getFullYear();
		navigator.clipboard.writeText(
			`🎆 New Year is ${days} days away! Count down to 1 January ${year} at Clockr.co`,
		);
		shareBtn.textContent = '✅ Copied to clipboard!';
		setTimeout(() => {
			shareBtn.innerHTML = `📤 New Year is <span id="share-days">${days}</span> days away`;
		}, 2000);
	});

	updateCountdown();
	setInterval(updateCountdown, 1000);

	const FIREWORK_COLORS = ['#FFD700', '#C0C0C0', '#ffffff', '#FF5C4D'];
	const PARTICLE_COUNT = 14;
	const PARTICLE_LIFE = 1200;
	const BURST_INTERVAL = 2500;
	const GRAVITY = 0.15;

	type FireworkParticle = {
		x: number;
		y: number;
		vx: number;
		vy: number;
		color: string;
		born: number;
	};

	const particles: FireworkParticle[] = [];
	let lastBurst = 0;
	let lastFrame = 0;

	function resizeFireworksCanvas(
		canvas: HTMLCanvasElement,
		ctx: CanvasRenderingContext2D,
	) {
		const hero = canvas.parentElement;
		if (!hero) return;
		const { width, height } = hero.getBoundingClientRect();
		const dpr = window.devicePixelRatio || 1;
		canvas.width = Math.floor(width * dpr);
		canvas.height = Math.floor(height * dpr);
		ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
	}

	function spawnFireworkBurst(canvas: HTMLCanvasElement, now: number) {
		const { width, height } = canvas.getBoundingClientRect();
		const x = Math.random() * width;
		const y = Math.random() * height;

		for (let i = 0; i < PARTICLE_COUNT; i++) {
			const angle = (Math.PI * 2 * i) / PARTICLE_COUNT + (Math.random() - 0.5) * 0.25;
			const speed = 2 + Math.random() * 4;
			particles.push({
				x,
				y,
				vx: Math.cos(angle) * speed,
				vy: Math.sin(angle) * speed,
				color: FIREWORK_COLORS[i % FIREWORK_COLORS.length],
				born: now,
			});
		}
	}

	function initFireworksCanvas() {
		const canvas = document.getElementById('fireworks-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		resizeFireworksCanvas(canvas, ctx);
		window.addEventListener('resize', () => resizeFireworksCanvas(canvas, ctx));

		const start = performance.now();
		spawnFireworkBurst(canvas, start);
		lastBurst = start;
		lastFrame = start;

		function tick(now: number) {
			const dt = Math.min((now - lastFrame) / 16.67, 2);
			lastFrame = now;

			if (now - lastBurst >= BURST_INTERVAL) {
				spawnFireworkBurst(canvas, now);
				lastBurst = now;
			}

			const { width, height } = canvas.getBoundingClientRect();
			ctx.clearRect(0, 0, width, height);

			for (let i = particles.length - 1; i >= 0; i--) {
				const p = particles[i];
				const age = now - p.born;
				if (age >= PARTICLE_LIFE) {
					particles.splice(i, 1);
					continue;
				}

				p.vy += GRAVITY * dt;
				p.x += p.vx * dt;
				p.y += p.vy * dt;

				const alpha = 1 - age / PARTICLE_LIFE;
				ctx.globalAlpha = alpha * 0.85;
				ctx.fillStyle = p.color;
				ctx.beginPath();
				ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
				ctx.fill();
			}

			ctx.globalAlpha = 1;
			requestAnimationFrame(tick);
		}

		requestAnimationFrame(tick);
	}

	initFireworksCanvas();
</script>
