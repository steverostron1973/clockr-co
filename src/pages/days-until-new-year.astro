		font-size: clamp(80px, 13vw, 120px);
		letter-spacing: -4px;
		min-width: 100px;
	}

	.ny-countdown-num--time {
		color: #C0C0C0;
	}

	.ny-countdown-sep {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		color: rgba(255, 255, 255, 0.3);
		line-height: 1;
		margin-bottom: 26px;
		padding: 0 2px;
	}

	.ny-countdown-unit {
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
	}

	/* ── BODY ── */
	.ny-body {
		max-width: 800px;
		margin: 0 auto;
		padding: 48px 24px 60px;
	}

	.ny-stats-section {
		margin-bottom: 16px;
	}

