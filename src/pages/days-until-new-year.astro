		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #ffffff;
		margin-bottom: 20px;
	}

	.ny-stats-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.ny-stats-grid {
			grid-template-columns: 1fr;
		}
	}

	.ny-stat-card {
		background: linear-gradient(135deg, #FFD700, #FFA500);
		border: none;
		border-radius: 14px;
		padding: 24px 20px;
	}

