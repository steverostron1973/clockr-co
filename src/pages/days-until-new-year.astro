---

<Layout
	title="Days Until New Year 2027 — New Year Countdown | Clockr"
	description="How many days until New Year 2027? Live countdown to 1st January 2027 showing exact days, hours, minutes and seconds."
>
	<div class="ny-page">
		<!-- FULL-WIDTH HERO BAND -->
		<section class="ny-hero" aria-label="New Year countdown">
			<canvas id="fireworks-canvas" aria-hidden="true"></canvas>
			<div class="ny-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="ny-float-emoji ny-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="ny-float-emoji ny-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					sparkles.map(({ top, left, size, color, duration, delay }) => (
						<span
							class="ny-sparkle"
							style={`top:${top};left:${left};width:${size}px;height:${size}px;background:${color};--twinkle-duration:${duration}s;--twinkle-delay:${delay}s`}
						/>
					))
				}
			</div>

			<div class="ny-hero-centre">
				<h1 class="ny-hero-title">Days Until New Year</h1>

				<div class="ny-countdown" id="ny-countdown">
					<div class="ny-countdown-block">
						<span class="ny-countdown-num ny-countdown-num--days" id="hero-days"
							>0</span
						>
						<span class="ny-countdown-unit">Days</span>
					</div>
					<span class="ny-countdown-sep">:</span>
					<div class="ny-countdown-block">
						<span class="ny-countdown-num ny-countdown-num--time" id="hero-hours"
							>00</span
						>
						<span class="ny-countdown-unit">Hours</span>
					</div>
					<span class="ny-countdown-sep">:</span>
					<div class="ny-countdown-block">
						<span class="ny-countdown-num ny-countdown-num--time" id="hero-mins"
							>00</span
						>
						<span class="ny-countdown-unit">Minutes</span>
					</div>
					<span class="ny-countdown-sep">:</span>
					<div class="ny-countdown-block">
						<span class="ny-countdown-num ny-countdown-num--time" id="hero-secs"
							>00</span
						>
						<span class="ny-countdown-unit">Seconds</span>
					</div>
				</div>
			</div>
		</section>

		<div class="ny-body">
			<!-- STATS -->
			<section class="ny-stats-section">
				<h2 class="ny-stats-heading">New Year by the numbers</h2>
				<div class="ny-stats-grid">
					<div class="ny-stat-card">
						<div class="ny-stat-label">Exact time remaining</div>
						<div class="ny-stat-value" id="stat-exact">—</div>
					</div>
					<div class="ny-stat-card">
						<div class="ny-stat-label">New Year's day</div>
						<div class="ny-stat-value" id="stat-weekday">—</div>
					</div>
					<div class="ny-stat-card">
						<div class="ny-stat-label">Weeks until New Year</div>
						<div class="ny-stat-value" id="stat-weeks">—</div>
					</div>
					<div class="ny-stat-card">
						<div class="ny-stat-label">Hours until New Year</div>
						<div class="ny-stat-value" id="stat-hours">—</div>
					</div>
				</div>
			</section>

			<!-- SHARE -->
			<button class="ny-share-btn" id="ny-share-btn">
				📤 New Year is <span id="share-days">0</span> days away
			</button>

			<!-- FUN FACTS -->
			<section class="ny-facts">
				<h2 class="ny-facts-title">New Year fun facts</h2>
				<div class="ny-facts-grid">
					<div class="ny-fact-card">
						<div class="ny-fact-emoji">📜</div>
						<h3 class="ny-fact-heading">Oldest recorded celebration</h3>
						<p class="ny-fact-text">
							New Year celebrations date back over 4,000 years to ancient
							Babylon, where the new year began with the first new moon after
							the spring equinox — a tradition far older than 1 January.
						</p>
					</div>
					<div class="ny-fact-card">
						<div class="ny-fact-emoji">🪩</div>
						<h3 class="ny-fact-heading">Times Square ball drop</h3>
						<p class="ny-fact-text">
							The first ball drop in Times Square was in 1907. Today's
							Waterford crystal ball weighs nearly 12,000 pounds, is 12 feet
							in diameter, and is covered with 2,688 crystal triangles.
						</p>
					</div>
					<div class="ny-fact-card">
						<div class="ny-fact-emoji">💪</div>
						<h3 class="ny-fact-heading">Most common resolutions</h3>
						<p class="ny-fact-text">
							Exercise, eating healthier, and saving money consistently top
							global New Year's resolution lists. Studies suggest only about
							9% of people keep their resolutions all year — but January
							optimism is undefeated.
						</p>
					</div>
					<div class="ny-fact-card">
						<div class="ny-fact-emoji">🌍</div>
						<h3 class="ny-fact-heading">Time zones at midnight</h3>
						<p class="ny-fact-text">
							With 24 primary time zones and several half- and quarter-hour
							offsets, midnight on New Year's Eve rolls across the globe over
							roughly 26 hours — from Kiribati to American Samoa.
						</p>
					</div>
				</div>
			</section>

			<!-- RELATED TOOLS -->
			<div class="ny-related">
				<h3 class="ny-related-title">You might also like</h3>
				<div class="ny-related-grid">
					<a href="/countdown-timer" class="ny-related-card">⏱️ Countdown Timer</a>
					<a href="/days-until-christmas" class="ny-related-card">🎄 Days Until Christmas</a>
					<a href="/year-progress" class="ny-related-card">📅 Year Progress</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.ny-page {
		width: 100%;
	}

	/* ── HERO BAND ── */
	.ny-hero {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 72px 24px;
		background: linear-gradient(135deg, #0d0d1a 0%, #1a1a3d 75%, #080808 100%);
		border: none;
		box-shadow: none;
		outline: none;
		overflow: hidden;
		position: relative;
		min-height: 320px;
	}

	#fireworks-canvas {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	.ny-hero-decor {
		position: absolute;
		inset: 0;
		pointer-events: none;
		user-select: none;
		z-index: 1;
	}

	.ny-float-emoji {
		position: absolute;
		display: inline-block;
		line-height: 1;
		transform: rotate(var(--rotation, 0deg));
		animation: ny-float 4s ease-in-out infinite;
		opacity: 0.9;
	}

	@media (max-width: 600px) {
		.ny-float-emoji {
			opacity: 0.35;
		}
	}

	@keyframes ny-float {
		0%,
		100% {
			transform: translateY(0) rotate(var(--rotation, 0deg));
		}
		33% {
			transform: translateY(-10px) rotate(calc(var(--rotation, 0deg) - 3deg));
		}
		66% {
			transform: translateY(-5px) rotate(calc(var(--rotation, 0deg) + 3deg));
		}
	}

	.ny-sparkle {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		animation: ny-twinkle var(--twinkle-duration, 2s) ease-in-out infinite;
		animation-delay: var(--twinkle-delay, 0s);
	}

	@keyframes ny-twinkle {
		0%,
		100% {
			opacity: 0.1;
			transform: scale(0.7);
		}
		50% {
			opacity: 1;
			transform: scale(1);
		}
	}

	.ny-hero-centre {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 720px;
	}

	.ny-hero-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 64px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 32px;
		background: linear-gradient(135deg, #FF5C4D, #FF9A3C);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
