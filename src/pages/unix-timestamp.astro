		flex-direction: column;
		gap: 12px;
	}

	.unix-result-row {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.unix-result-highlight {
		background: rgba(16, 185, 129, 0.06);
		border: 1px solid rgba(16, 185, 129, 0.15);
		border-radius: 10px;
		padding: 12px 14px;
	}

	.unix-result-label {
		font-family: 'Outfit', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
	}

	.unix-result-value {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.8);
		line-height: 1.4;
		word-break: break-word;
	}

	.unix-mono {
		font-family: 'Outfit', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: #84cc16;
	}

	.unix-ticker {
		background: #0c0c0c;
		border: 1px solid rgba(16, 185, 129, 0.2);
		border-radius: 20px;
		padding: 40px;
		text-align: center;
		margin-bottom: 48px;
		box-shadow: 0 0 40px rgba(16, 185, 129, 0.06);
	}

	.unix-ticker-label {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.4);
		margin-bottom: 16px;
	}

	.unix-ticker-value {
		font-family: 'Outfit', sans-serif;
		font-size: 72px;
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1;
		font-variant-numeric: tabular-nums;
		font-feature-settings: 'tnum';
		display: inline-block;
		min-width: 13ch;
		background: linear-gradient(135deg, #10b981, #84cc16);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.unix-reference {
		margin-bottom: 48px;
	}

	.unix-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.unix-how {
		margin-bottom: 48px;
	}

	.unix-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(16, 185, 129, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.unix-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.unix-how-card p:last-child {
		margin-bottom: 0;
	}

	.unix-faq {
		margin-bottom: 48px;
	}

	.unix-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.unix-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(16, 185, 129, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.unix-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #10b981, #84cc16);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.unix-faq-question::-webkit-details-marker {
		display: none;
	}

	.unix-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #10b981, #84cc16);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.unix-faq-item[open] .unix-faq-question::after {
		content: '−';
