	.unix-faq-answer {
		padding: 0 24px 18px;
	}

	.unix-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.unix-faq-answer code {
		font-family: 'Outfit', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: #84cc16;
	}

	.unix-reference-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.unix-table-wrap {
		overflow-x: auto;
		border-radius: 14px;
		border: 1px solid rgba(16, 185, 129, 0.15);
	}

	.unix-table {
		width: 100%;
		border-collapse: collapse;
		font-family: 'Inter', sans-serif;
		font-size: 14px;
	}

	.unix-table th {
		background: rgba(16, 185, 129, 0.08);
		font-family: 'Outfit', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		padding: 14px 20px;
		text-align: left;
	}

	.unix-table td {
		padding: 14px 20px;
		color: rgba(255, 255, 255, 0.65);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}

	.unix-table tr:hover td {
		background: rgba(16, 185, 129, 0.04);
	}

	.unix-table-ts {
		background: none;
		border: none;
		padding: 0;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 700;
		color: #10b981;
		cursor: pointer;
		text-decoration: underline;
		text-decoration-color: rgba(16, 185, 129, 0.3);
		text-underline-offset: 3px;
		transition: color 0.2s ease;
	}

	.unix-table-ts:hover {
		color: #84cc16;
	}

	.unix-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.unix-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.unix-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.unix-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.unix-related-card:hover {
		border-color: rgba(16, 185, 129, 0.4);
	}

	.unix-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #10b981, #84cc16);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	@media (max-width: 768px) {
		.unix-title {
			font-size: 44px;
			letter-spacing: -2px;
		}

		.unix-cards {
			grid-template-columns: 1fr;
		}

		.unix-ticker-value {
			font-size: 48px;
		}

		.unix-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const tsInput = document.getElementById('ts-input') as HTMLInputElement;
	const tsResults = document.getElementById('ts-results');
	const tsNowBtn = document.getElementById('ts-now-btn');
	const dateInput = document.getElementById('date-input') as HTMLInputElement;
	const timeInput = document.getElementById('time-input') as HTMLInputElement;
	const dateResults = document.getElementById('date-results');
	const dateNowBtn = document.getElementById('date-now-btn');
	const liveTimestamp = document.getElementById('live-timestamp');

	const dateTimeFmt: Intl.DateTimeFormatOptions = {
		weekday: 'long',
		year: 'numeric',
		month: 'long',
		day: 'numeric',
		hour: '2-digit',
		minute: '2-digit',
		second: '2-digit',
		hour12: false,
	};

	function parseTimestamp(raw: string): Date | null {
		const cleaned = raw.trim().replace(/,/g, '');
		if (!cleaned || !/^-?\d+$/.test(cleaned)) return null;

		const num = Number(cleaned);
		if (!Number.isFinite(num)) return null;

		const abs = Math.abs(num);
		const ms = abs >= 1e12 || (abs > 1e10 && cleaned.length >= 13) ? num : num * 1000;
		const date = new Date(ms);
		return isNaN(date.getTime()) ? null : date;
	}

	function formatRelative(date: Date): string {
		const now = Date.now();
		const diffMs = date.getTime() - now;
		const absSec = Math.abs(Math.round(diffMs / 1000));

		const units: [Intl.RelativeTimeFormatUnit, number][] = [
			['year', 31536000],
			['month', 2592000],
			['week', 604800],
			['day', 86400],
			['hour', 3600],
			['minute', 60],
			['second', 1],
		];

		const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });

		for (const [unit, seconds] of units) {
			if (absSec >= seconds || unit === 'second') {
				const value = Math.round(diffMs / 1000 / seconds);
				return rtf.format(value, unit);
			}
		}

		return 'now';
	}

	function convertTimestampToDate() {
		if (!tsInput || !tsResults) return;

		const date = parseTimestamp(tsInput.value);
		if (!date) {
			tsResults.style.display = 'none';
			return;
		}

		tsResults.style.display = 'flex';

		const utcEl = document.getElementById('ts-utc');
		const localEl = document.getElementById('ts-local');
		const isoEl = document.getElementById('ts-iso');
		const relativeEl = document.getElementById('ts-relative');

		if (utcEl)
			utcEl.textContent = date.toLocaleString('en-GB', {
				...dateTimeFmt,
				timeZone: 'UTC',
			}) + ' UTC';

		if (localEl)
			localEl.textContent =
				date.toLocaleString('en-GB', dateTimeFmt) +
				` (${Intl.DateTimeFormat().resolvedOptions().timeZone})`;

		if (isoEl) isoEl.textContent = date.toISOString();

		if (relativeEl) relativeEl.textContent = formatRelative(date);
	}

	function pad(n: number) {
		return String(n).padStart(2, '0');
	}

	function toDateInputValue(d: Date) {
		return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
	}

	function toTimeInputValue(d: Date) {
		return `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
	}

	function convertDateToTimestamp() {
		if (!dateInput || !timeInput || !dateResults) return;

		if (!dateInput.value) {
			dateResults.style.display = 'none';
			return;
		}

		const timePart = timeInput.value || '00:00:00';
		const date = new Date(`${dateInput.value}T${timePart}`);

		if (isNaN(date.getTime())) {
			dateResults.style.display = 'none';
			return;
		}

		dateResults.style.display = 'flex';

		const seconds = Math.floor(date.getTime() / 1000);
		const ms = date.getTime();

		const secondsEl = document.getElementById('date-seconds');
		const msEl = document.getElementById('date-ms');
		const isoEl = document.getElementById('date-iso');
		const utcEl = document.getElementById('date-utc');

		if (secondsEl) secondsEl.textContent = seconds.toLocaleString();
		if (msEl) msEl.textContent = ms.toLocaleString();
		if (isoEl) isoEl.textContent = date.toISOString();
		if (utcEl)
			utcEl.textContent = date.toLocaleString('en-GB', {
				...dateTimeFmt,
				timeZone: 'UTC',
			}) + ' UTC';
	}

	function setNow() {
		const now = new Date();
		if (dateInput) dateInput.value = toDateInputValue(now);
		if (timeInput) timeInput.value = toTimeInputValue(now);
		convertDateToTimestamp();
	}

	function updateLiveTicker() {
		const now = Math.floor(Date.now() / 1000);
		if (liveTimestamp) liveTimestamp.textContent = now.toLocaleString();
	}

	tsInput?.addEventListener('input', convertTimestampToDate);
	dateInput?.addEventListener('change', convertDateToTimestamp);
	timeInput?.addEventListener('change', convertDateToTimestamp);
	dateInput?.addEventListener('input', convertDateToTimestamp);
	timeInput?.addEventListener('input', convertDateToTimestamp);

	tsNowBtn?.addEventListener('click', () => {
		if (tsInput) {
			tsInput.value = String(Math.floor(Date.now() / 1000));
			convertTimestampToDate();
		}
	});

	dateNowBtn?.addEventListener('click', setNow);

	document.querySelectorAll('.unix-table-ts').forEach((btn) => {
		btn.addEventListener('click', () => {
			const ts = btn.getAttribute('data-timestamp');
			if (ts && tsInput) {
				tsInput.value = ts;
				convertTimestampToDate();
				tsInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
			}
		});
	});

	updateLiveTicker();
	setInterval(updateLiveTicker, 1000);

	// Refresh relative time while timestamp input is active
	setInterval(() => {
		if (tsInput?.value.trim()) convertTimestampToDate();
	}, 30000);
</script>
