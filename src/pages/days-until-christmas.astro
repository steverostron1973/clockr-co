---
import Layout from '../layouts/Layout.astro';

const leftEmojis = [
	{ emoji: '🎅', size: 48, rotation: -15, top: '10%', side: '2%', delay: 0 },
	{ emoji: '🎄', size: 32, rotation: 12, top: '25%', side: '8%', delay: 0.5 },
	{ emoji: '⭐', size: 40, rotation: -8, top: '45%', side: '4%', delay: 1 },
	{ emoji: '🦌', size: 28, rotation: 15, top: '65%', side: '10%', delay: 1.5 },
	{ emoji: '☃️', size: 44, rotation: -12, top: '80%', side: '6%', delay: 2 },
	{ emoji: '🎁', size: 36, rotation: 8, top: '35%', side: '2%', delay: 2.5 },
];

const rightEmojis = [
	{ emoji: '🔔', size: 36, rotation: -5, top: '15%', side: '3%', delay: 3 },
	{ emoji: '🕯️', size: 48, rotation: 14, top: '30%', side: '9%', delay: 3.5 },
	{ emoji: '🧦', size: 30, rotation: -10, top: '50%', side: '5%', delay: 4 },
	{ emoji: '🤶', size: 42, rotation: 6, top: '70%', side: '8%', delay: 4.5 },
	{ emoji: '❄️', size: 28, rotation: -15, top: '85%', side: '4%', delay: 5 },
	{ emoji: '🌟', size: 46, rotation: 10, top: '40%', side: '2%', delay: 5.5 },
];
---

<Layout
	title="Days Until Christmas 2026 — Christmas Countdown | Clockr"
	description="How many days until Christmas 2026? Live Christmas countdown showing exact days, hours, minutes and seconds until 25th December."
>
	<div class="xmas-page">
		<!-- FULL-WIDTH HERO BAND -->
		<section class="xmas-hero" aria-label="Christmas countdown">
			<div class="xmas-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="xmas-float-emoji xmas-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="xmas-float-emoji xmas-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
			</div>

			<div class="xmas-hero-centre">
				<h1 class="xmas-hero-title">Days Until Christmas</h1>

				<div class="xmas-countdown" id="xmas-countdown">
					<div class="xmas-countdown-block">
						<span class="xmas-countdown-num xmas-countdown-num--days" id="hero-days"
							>0</span
						>
						<span class="xmas-countdown-unit">Days</span>
					</div>
					<span class="xmas-countdown-sep">:</span>
					<div class="xmas-countdown-block">
						<span class="xmas-countdown-num" id="hero-hours">00</span>
						<span class="xmas-countdown-unit">Hours</span>
					</div>
					<span class="xmas-countdown-sep">:</span>
					<div class="xmas-countdown-block">
						<span class="xmas-countdown-num" id="hero-mins">00</span>
						<span class="xmas-countdown-unit">Minutes</span>
					</div>
					<span class="xmas-countdown-sep">:</span>
					<div class="xmas-countdown-block">
						<span class="xmas-countdown-num" id="hero-secs">00</span>
						<span class="xmas-countdown-unit">Seconds</span>
					</div>
				</div>
			</div>
		</section>

		<div class="xmas-body">
			<!-- STATS -->
			<section class="xmas-stats-section">
				<h2 class="xmas-stats-heading">Christmas by the numbers</h2>
				<div class="xmas-stats-grid">
					<div class="xmas-stat-card">
						<div class="xmas-stat-label">Exact time remaining</div>
						<div class="xmas-stat-value" id="stat-exact">—</div>
					</div>
					<div class="xmas-stat-card">
						<div class="xmas-stat-label">Christmas day</div>
						<div class="xmas-stat-value" id="stat-weekday">—</div>
					</div>
					<div class="xmas-stat-card">
						<div class="xmas-stat-label">Sleeps until Christmas</div>
						<div class="xmas-stat-value" id="stat-sleeps">—</div>
					</div>
					<div class="xmas-stat-card">
						<div class="xmas-stat-label">Weeks until Christmas</div>
						<div class="xmas-stat-value" id="stat-weeks">—</div>
					</div>
				</div>
			</section>

			<!-- SHARE -->
			<button class="xmas-share-btn" id="xmas-share-btn">
				📤 Christmas is <span id="share-days">0</span> days away
			</button>

			<!-- FUN FACTS -->
			<section class="xmas-facts">
				<h2 class="xmas-facts-title">Christmas fun facts</h2>
				<div class="xmas-facts-grid">
					<div class="xmas-fact-card">
						<div class="xmas-fact-emoji">📜</div>
						<h3 class="xmas-fact-heading">First recorded celebration</h3>
						<p class="xmas-fact-text">
							The first recorded Christmas celebration on 25 December took place
							in Rome in 336 AD, during the reign of Emperor Constantine — over
							1,600 years ago.
						</p>
					</div>
					<div class="xmas-fact-card">
						<div class="xmas-fact-emoji">🎁</div>
						<h3 class="xmas-fact-heading">Santa's delivery speed</h3>
						<p class="xmas-fact-text">
							With roughly 2 billion children worldwide, Santa would need to
							deliver about 5,000 presents per second to finish in one night.
							That's faster than a speeding sleigh!
						</p>
					</div>
					<div class="xmas-fact-card">
						<div class="xmas-fact-emoji">🎄</div>
						<h3 class="xmas-fact-heading">The Christmas tree tradition</h3>
						<p class="xmas-fact-text">
							Decorating evergreen trees for winter dates back to 16th-century
							Germany. Martin Luther is said to have added candles to a tree,
							inspiring the lights we use today.
						</p>
					</div>
					<div class="xmas-fact-card">
						<div class="xmas-fact-emoji">❄️</div>
						<h3 class="xmas-fact-heading">White Christmas odds</h3>
						<p class="xmas-fact-text">
							In London, a white Christmas (snow falling on 25 December) happens
							roughly once every six years. In New York, the odds are about 1 in
							4 — dream big, shovel optional.
						</p>
					</div>
				</div>
			</section>

			<!-- RELATED TOOLS -->
			<div class="xmas-related">
				<h3 class="xmas-related-title">You might also like</h3>
				<div class="xmas-related-grid">
					<a href="/countdown-timer" class="xmas-related-card">⏱️ Countdown Timer</a>
					<a href="/age-calculator" class="xmas-related-card">🎂 Age Calculator</a>
					<a href="/year-progress" class="xmas-related-card">📅 Year Progress</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.xmas-page {
		width: 100%;
	}

	/* ── HERO BAND ── */
	.xmas-hero {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 72px 24px;
		background: linear-gradient(135deg, #8b0000, #1a472a);
		border-bottom: 1px solid rgba(255, 92, 77, 0.25);
		overflow: hidden;
		position: relative;
		min-height: 320px;
	}

	.xmas-hero-decor {
		position: absolute;
		inset: 0;
		pointer-events: none;
		user-select: none;
	}

	.xmas-float-emoji {
		position: absolute;
		display: inline-block;
		line-height: 1;
		transform: rotate(var(--rotation, 0deg));
		animation: xmas-float 4s ease-in-out infinite;
		opacity: 0.9;
	}

	@media (max-width: 600px) {
		.xmas-float-emoji {
			opacity: 0.35;
		}
	}

	@keyframes xmas-float {
		0%,
		100% {
			transform: translateY(0) rotate(var(--rotation, 0deg));
		}
		33% {
			transform: translateY(-10px) rotate(calc(var(--rotation, 0deg) - 3deg));
		}
		66% {
			transform: translateY(-5px) rotate(calc(var(--rotation, 0deg) + 3deg));
		}
	}

	.xmas-hero-centre {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 720px;
	}

	.xmas-hero-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 64px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 32px;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.xmas-countdown {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		flex-wrap: wrap;
		gap: 8px 12px;
	}

	.xmas-countdown-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.xmas-countdown-num {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
		min-width: 64px;
		text-align: center;
	}

	.xmas-countdown-num--days {
		font-size: clamp(80px, 13vw, 120px);
		letter-spacing: -4px;
		min-width: 100px;
	}

	.xmas-countdown-sep {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		color: rgba(255, 255, 255, 0.3);
		line-height: 1;
		margin-bottom: 26px;
		padding: 0 2px;
	}

	.xmas-countdown-unit {
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
	}

	/* ── BODY ── */
	.xmas-body {
		max-width: 800px;
		margin: 0 auto;
		padding: 48px 24px 60px;
	}

	.xmas-stats-section {
		margin-bottom: 16px;
	}

	.xmas-stats-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 20px;
	}

	.xmas-stats-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.xmas-stats-grid {
			grid-template-columns: 1fr;
		}
	}

	.xmas-stat-card {
		background: #0d1f14;
		border: 1px solid rgba(0, 229, 196, 0.15);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.xmas-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		margin-bottom: 10px;
	}

	.xmas-stat-value {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.4;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.xmas-share-btn {
		display: block;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		max-width: 320px;
		margin: 0 auto 48px;
		transition: opacity 0.2s ease;
	}

	.xmas-share-btn:hover {
		opacity: 0.9;
	}

	.xmas-facts {
		margin-bottom: 48px;
	}

	.xmas-facts-title {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 20px;
	}

	.xmas-facts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.xmas-facts-grid {
			grid-template-columns: 1fr;
		}
	}

	.xmas-fact-card {
		background: #3d0a0a;
		border: 1px solid rgba(255, 100, 50, 0.2);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.xmas-fact-emoji {
		font-size: 28px;
		margin-bottom: 12px;
		line-height: 1;
	}

	.xmas-fact-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 8px;
	}

	.xmas-fact-text {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.6;
	}

	.xmas-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.xmas-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.xmas-related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.xmas-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.xmas-related-card:hover {
		border-color: rgba(255, 92, 77, 0.4);
		color: #fff;
	}
</style>

<script>
	function pad(n: number) {
		return String(n).padStart(2, '0');
	}

	function getTargetChristmas(): Date {
		const now = new Date();
		let year = now.getFullYear();
		const christmas = new Date(year, 11, 25, 0, 0, 0, 0);
		if (now.getTime() >= christmas.getTime()) {
			year += 1;
		}
		return new Date(year, 11, 25, 0, 0, 0, 0);
	}

	function updateCountdown() {
		const now = new Date();
		const christmas = getTargetChristmas();
		const diff = christmas.getTime() - now.getTime();

		if (diff <= 0) return;

		const totalSeconds = Math.floor(diff / 1000);
		const days = Math.floor(totalSeconds / 86400);
		const hours = Math.floor((totalSeconds % 86400) / 3600);
		const mins = Math.floor((totalSeconds % 3600) / 60);
		const secs = totalSeconds % 60;

		const heroDays = document.getElementById('hero-days');
		const heroHours = document.getElementById('hero-hours');
		const heroMins = document.getElementById('hero-mins');
		const heroSecs = document.getElementById('hero-secs');
		const statExact = document.getElementById('stat-exact');
		const statWeekday = document.getElementById('stat-weekday');
		const statSleeps = document.getElementById('stat-sleeps');
		const statWeeks = document.getElementById('stat-weeks');
		const shareDays = document.getElementById('share-days');

		if (heroDays) heroDays.textContent = String(days);
		if (heroHours) heroHours.textContent = pad(hours);
		if (heroMins) heroMins.textContent = pad(mins);
		if (heroSecs) heroSecs.textContent = pad(secs);

		const year = christmas.getFullYear();
		const weekday = christmas.toLocaleDateString('en-GB', { weekday: 'long' });
		const weeks = Math.floor(days / 7);

		if (statExact)
			statExact.textContent = `${days} days, ${hours} hours, ${mins} minutes, ${secs} seconds until 25 December ${year}`;
		if (statWeekday)
			statWeekday.textContent = `Christmas ${year} falls on a ${weekday}`;
		if (statSleeps)
			statSleeps.textContent =
				days === 0
					? 'Tonight! 🎄'
					: `${days} sleep${days === 1 ? '' : 's'}`;
		if (statWeeks)
			statWeeks.textContent = `${weeks} week${weeks === 1 ? '' : 's'}`;
		if (shareDays) shareDays.textContent = String(days);
	}

	const shareBtn = document.getElementById('xmas-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = document.getElementById('share-days')?.textContent ?? '0';
		const christmas = getTargetChristmas();
		const year = christmas.getFullYear();
		navigator.clipboard.writeText(
			`🎄 Christmas is ${days} days away! Only ${days} sleeps until 25 December ${year}. Count down at Clockr.co`,
		);
		shareBtn.textContent = '✅ Copied to clipboard!';
		setTimeout(() => {
			shareBtn.innerHTML = `📤 Christmas is <span id="share-days">${days}</span> days away`;
		}, 2000);
	});

	updateCountdown();
	setInterval(updateCountdown, 1000);
</script>
