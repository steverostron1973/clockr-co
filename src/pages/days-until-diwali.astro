	.diwali-stat-card {
		background: #1a1420;
		border: 1px solid rgba(232, 147, 122, 0.2);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.diwali-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		margin-bottom: 10px;
	}

	.diwali-stat-value {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.4;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.diwali-share-btn {
		display: block;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		color: #1a1420;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		max-width: 320px;
		width: 100%;
		margin: 0 auto 48px;
		transition: opacity 0.2s ease;
	}

	.diwali-share-btn:hover {
		opacity: 0.9;
	}

	.diwali-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.diwali-about {
		margin-bottom: 48px;
	}

	.diwali-about-card,
	.diwali-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(232, 147, 122, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.diwali-about-card p,
	.diwali-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.diwali-about-card p:last-child,
	.diwali-how-card p:last-child {
		margin-bottom: 0;
	}

	.diwali-how {
		margin-bottom: 48px;
	}

	.diwali-faq {
		margin-bottom: 48px;
	}

	.diwali-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.diwali-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(232, 147, 122, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.diwali-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.diwali-faq-question::-webkit-details-marker {
		display: none;
	}

	.diwali-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.diwali-faq-item[open] .diwali-faq-question::after {
		content: '−';
	}

	.diwali-faq-answer {
		padding: 0 24px 18px;
	}

	.diwali-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.diwali-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.diwali-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.diwali-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.diwali-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.diwali-related-card:hover {
		border-color: rgba(232, 147, 122, 0.4);
	}

	.diwali-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>

<script define:vars={{ diwaliDates }}>
	function pad(n) {
		return String(n).padStart(2, '0');
	}

	function getDiwaliDate(entry) {
		return new Date(entry.year, entry.month, entry.day, 0, 0, 0, 0);
	}

	function getTargetDiwali() {
		const now = new Date();
		const sorted = [...diwaliDates].sort(
			(a, b) => getDiwaliDate(a).getTime() - getDiwaliDate(b).getTime(),
		);

		for (const entry of sorted) {
			const date = getDiwaliDate(entry);
			if (now.getTime() < date.getTime()) {
				return { ...entry, date };
			}
		}

		const last = sorted[sorted.length - 1];
		return { ...last, date: getDiwaliDate(last) };
	}

	function formatDiwaliDate(date) {
		return date.toLocaleDateString('en-GB', {
			weekday: 'long',
			day: 'numeric',
			month: 'long',
			year: 'numeric',
		});
	}

	function updateCountdown() {
		const now = new Date();
		const diwali = getTargetDiwali();
		const diff = diwali.date.getTime() - now.getTime();

		if (diff <= 0) return;

		const totalSeconds = Math.floor(diff / 1000);
		const days = Math.floor(totalSeconds / 86400);
		const hours = Math.floor((totalSeconds % 86400) / 3600);
		const mins = Math.floor((totalSeconds % 3600) / 60);
		const secs = totalSeconds % 60;
		const weeks = Math.floor(days / 7);

		const heroDays = document.getElementById('hero-days');
		const heroHours = document.getElementById('hero-hours');
		const heroMins = document.getElementById('hero-mins');
		const heroSecs = document.getElementById('hero-secs');
		const heroTargetDate = document.getElementById('hero-target-date');
		const statDate = document.getElementById('stat-date');
		const statWeekday = document.getElementById('stat-weekday');
		const statWeeks = document.getElementById('stat-weeks');
		const statExact = document.getElementById('stat-exact');

		if (heroDays) heroDays.textContent = String(days);
		if (heroHours) heroHours.textContent = pad(hours);
		if (heroMins) heroMins.textContent = pad(mins);
		if (heroSecs) heroSecs.textContent = pad(secs);

		const dateLabel = formatDiwaliDate(diwali.date);
		const weekday = diwali.date.toLocaleDateString('en-GB', { weekday: 'long' });

		if (heroTargetDate) heroTargetDate.textContent = dateLabel;
		if (statDate) statDate.textContent = dateLabel;
		if (statWeekday) statWeekday.textContent = weekday;
		if (statWeeks)
			statWeeks.textContent = `${weeks} week${weeks === 1 ? '' : 's'}`;
		if (statExact)
			statExact.textContent = `${days} days, ${hours} hours, ${mins} minutes, ${secs} seconds`;
	}

	const shareBtn = document.getElementById('diwali-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = document.getElementById('hero-days')?.textContent ?? '0';
		const diwali = getTargetDiwali();
		const dateLabel = formatDiwaliDate(diwali.date);
		navigator.clipboard.writeText(
			`🪔 Diwali is ${days} days away — ${dateLabel}. Count down at clockr.co/days-until-diwali`,
		);
		shareBtn.textContent = '✓ Copied!';
		setTimeout(() => {
			shareBtn.textContent = '📋 Copy & Share';
		}, 2000);
	});

	updateCountdown();
	setInterval(updateCountdown, 1000);
</script>
