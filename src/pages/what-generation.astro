		-webkit-appearance: none;
		margin: 0;
	}

	.gen-input:focus {
		border-color: rgba(168, 85, 247, 0.8);
		box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);
	}

	.gen-input::placeholder {
		color: rgba(255, 255, 255, 0.2);
		font-weight: 600;
	}

	.gen-result-card {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.2);
		border-radius: 20px;
		padding: 40px;
		text-align: center;
		margin-bottom: 24px;
		box-shadow: 0 0 40px rgba(168, 85, 247, 0.06);
	}

	.gen-result-name {
		font-family: 'Outfit', sans-serif;
		font-size: 72px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1;
		margin-bottom: 12px;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.gen-result-range {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.5);
		margin-bottom: 20px;
	}

	.gen-result-desc {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.65);
		line-height: 1.7;
		text-align: left;
		margin-bottom: 20px;
	}

	.gen-result-age {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.4);
		padding-top: 16px;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
