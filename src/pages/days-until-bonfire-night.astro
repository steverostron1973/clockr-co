		line-height: 1.7;
		margin: 0;
	}

	.bn-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.bn-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.bn-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.bn-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.bn-related-card:hover {
		border-color: rgba(255, 100, 0, 0.4);
	}

	.bn-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	@media (max-width: 600px) {
		.bn-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	function pad(n: number) {
		return String(n).padStart(2, '0');
	}

	function getTargetBonfireNight(): Date {
		const now = new Date();
		let year = now.getFullYear();
		const bonfire = new Date(year, 10, 5, 0, 0, 0, 0);
		if (now.getTime() >= bonfire.getTime()) {
			year += 1;
		}
		return new Date(year, 10, 5, 0, 0, 0, 0);
	}

	function updateCountdown() {
		const now = new Date();
		const bonfire = getTargetBonfireNight();
		const diff = bonfire.getTime() - now.getTime();

		if (diff <= 0) return;

		const totalSeconds = Math.floor(diff / 1000);
		const days = Math.floor(totalSeconds / 86400);
		const hours = Math.floor((totalSeconds % 86400) / 3600);
		const mins = Math.floor((totalSeconds % 3600) / 60);
		const secs = totalSeconds % 60;
		const totalMinutes = Math.floor(totalSeconds / 60);

		const heroDays = document.getElementById('hero-days');
		const heroHours = document.getElementById('hero-hours');
		const heroMins = document.getElementById('hero-mins');
		const heroSecs = document.getElementById('hero-secs');
		const statExact = document.getElementById('stat-exact');
		const statWeekday = document.getElementById('stat-weekday');
		const statWeeks = document.getElementById('stat-weeks');
		const statMinutes = document.getElementById('stat-minutes');

		if (heroDays) heroDays.textContent = String(days);
		if (heroHours) heroHours.textContent = pad(hours);
		if (heroMins) heroMins.textContent = pad(mins);
		if (heroSecs) heroSecs.textContent = pad(secs);

		const year = bonfire.getFullYear();
		const weekday = bonfire.toLocaleDateString('en-GB', { weekday: 'long' });
		const weeks = Math.floor(days / 7);

		if (statExact)
			statExact.textContent = `${days} days, ${hours} hours, ${mins} minutes, ${secs} seconds until 5 November ${year}`;
		if (statWeekday)
			statWeekday.textContent = `Bonfire Night ${year} falls on a ${weekday}`;
		if (statWeeks)
			statWeeks.textContent = `${weeks} week${weeks === 1 ? '' : 's'}`;
		if (statMinutes)
			statMinutes.textContent = `${totalMinutes.toLocaleString()} minute${totalMinutes === 1 ? '' : 's'}`;
	}

	const shareBtn = document.getElementById('bn-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = document.getElementById('hero-days')?.textContent ?? '0';
		const bonfire = getTargetBonfireNight();
		const year = bonfire.getFullYear();
		navigator.clipboard.writeText(
			`🔥 Bonfire Night is ${days} days away! Count down to 5 November ${year} at Clockr.co`,
		);
		shareBtn.textContent = '✓ Copied!';
		setTimeout(() => {
			shareBtn.textContent = '📋 Copy & Share';
		}, 2000);
	});

	updateCountdown();
	setInterval(updateCountdown, 1000);
</script>
