---
import Layout from '../layouts/Layout.astro';

const leftEmojis = [
	{ emoji: '🎆', size: 48, rotation: -15, top: '10%', side: '2%', delay: 0 },
	{ emoji: '🔥', size: 32, rotation: 12, top: '25%', side: '8%', delay: 0.5 },
	{ emoji: '💥', size: 40, rotation: -8, top: '45%', side: '4%', delay: 1 },
	{ emoji: '✨', size: 28, rotation: 15, top: '65%', side: '10%', delay: 1.5 },
	{ emoji: '🌙', size: 44, rotation: -12, top: '80%', side: '6%', delay: 2 },
	{ emoji: '🎇', size: 36, rotation: 8, top: '35%', side: '2%', delay: 2.5 },
];

const rightEmojis = [
	{ emoji: '🧨', size: 36, rotation: -5, top: '15%', side: '3%', delay: 3 },
	{ emoji: '🪄', size: 48, rotation: 14, top: '30%', side: '9%', delay: 3.5 },
	{ emoji: '⭐', size: 30, rotation: -10, top: '50%', side: '5%', delay: 4 },
	{ emoji: '🌟', size: 42, rotation: 6, top: '70%', side: '8%', delay: 4.5 },
	{ emoji: '🎑', size: 28, rotation: -15, top: '85%', side: '4%', delay: 5 },
	{ emoji: '🕯️', size: 46, rotation: 10, top: '40%', side: '2%', delay: 5.5 },
];
---

<Layout
	title="Days Until Bonfire Night 2026 — Guy Fawkes Countdown | Clockr"
	description="How many days until Bonfire Night 2026? Live countdown showing exact days, hours, minutes and seconds until 5th November."
>
	<div class="bn-page">
		<section class="bn-hero" aria-label="Bonfire Night countdown">
			<div class="bn-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="bn-float-emoji bn-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="bn-float-emoji bn-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
			</div>

			<div class="bn-hero-centre">
				<h1 class="bn-hero-title">Days Until Bonfire Night</h1>

				<div class="bn-countdown" id="bn-countdown">
					<div class="bn-countdown-block">
						<span class="bn-countdown-num bn-countdown-num--days" id="hero-days"
							>0</span
						>
						<span class="bn-countdown-unit">Days</span>
					</div>
					<span class="bn-countdown-sep">:</span>
					<div class="bn-countdown-block">
						<span class="bn-countdown-num" id="hero-hours">00</span>
						<span class="bn-countdown-unit">Hours</span>
					</div>
					<span class="bn-countdown-sep">:</span>
					<div class="bn-countdown-block">
						<span class="bn-countdown-num" id="hero-mins">00</span>
						<span class="bn-countdown-unit">Minutes</span>
					</div>
					<span class="bn-countdown-sep">:</span>
					<div class="bn-countdown-block">
						<span class="bn-countdown-num" id="hero-secs">00</span>
						<span class="bn-countdown-unit">Seconds</span>
					</div>
				</div>
			</div>
		</section>

		<div class="bn-body">
			<section class="bn-stats-section">
				<h2 class="bn-stats-heading">Bonfire Night by the numbers</h2>
				<div class="bn-stats-grid">
					<div class="bn-stat-card">
						<div class="bn-stat-label">Exact time remaining</div>
						<div class="bn-stat-value" id="stat-exact">—</div>
					</div>
					<div class="bn-stat-card">
						<div class="bn-stat-label">Bonfire Night</div>
						<div class="bn-stat-value" id="stat-weekday">—</div>
					</div>
					<div class="bn-stat-card">
						<div class="bn-stat-label">Weeks until Bonfire Night</div>
						<div class="bn-stat-value" id="stat-weeks">—</div>
					</div>
					<div class="bn-stat-card">
						<div class="bn-stat-label">Minutes until Bonfire Night</div>
						<div class="bn-stat-value" id="stat-minutes">—</div>
					</div>
				</div>
			</section>

			<button class="bn-share-btn" id="bn-share-btn">📋 Copy &amp; Share</button>

			<section class="bn-facts">
				<h2 class="bn-facts-title">Bonfire Night fun facts</h2>
				<div class="bn-facts-grid">
					<div class="bn-fact-card">
						<div class="bn-fact-emoji">📜</div>
						<h3 class="bn-fact-heading">The Gunpowder Plot</h3>
						<p class="bn-fact-text">
							On 5 November 1605, Guy Fawkes was caught guarding 36 barrels of
							gunpowder beneath the House of Lords. The plotters planned to blow
							up King James I and Parliament — a conspiracy that failed and
							launched centuries of annual remembrance.
						</p>
					</div>
					<div class="bn-fact-card">
						<div class="bn-fact-emoji">🔥</div>
						<h3 class="bn-fact-heading">How it is celebrated today</h3>
						<p class="bn-fact-text">
							Modern Bonfire Night means bonfires, firework displays, sparklers,
							and toffee apples across the UK. Many towns hold organised events
							on or around 5 November, while families gather in gardens and parks
							to watch the sky light up.
						</p>
					</div>
					<div class="bn-fact-card">
						<div class="bn-fact-emoji">💥</div>
						<h3 class="bn-fact-heading">UK fireworks spending</h3>
						<p class="bn-fact-text">
							Britons spend an estimated £400 million on fireworks each year,
							with the bulk of purchases clustered around Bonfire Night and New
							Year's Eve. Retailers stock display packs from October onward as
							communities plan their November displays.
						</p>
					</div>
					<div class="bn-fact-card">
						<div class="bn-fact-emoji">🎆</div>
						<h3 class="bn-fact-heading">Biggest celebrations in the UK</h3>
						<p class="bn-fact-text">
							Lewes in East Sussex hosts the largest Bonfire Night festivities
							in Britain — seven bonfire societies parade through the town with
							flaming torches. London's Alexandra Palace and Battersea Park
							fireworks draw tens of thousands each year.
						</p>
					</div>
				</div>
			</section>

			<section class="bn-how">
				<h2 class="bn-section-title">How is the Bonfire Night countdown calculated?</h2>
				<div class="bn-how-card">
					<p>
						The countdown measures the exact number of seconds between right now
						and midnight on 5 November 2026 — the moment Bonfire Night begins.
						That total is broken down into days, hours, minutes, and seconds,
						and the display refreshes every second so you always see the precise
						time remaining.
					</p>
					<p>
						Clockr automatically checks whether 5 November has already passed
						this calendar year. If it has, the timer counts down to 5 November
						of the following year — so the countdown keeps running year after
						year without you needing to refresh the page.
					</p>
					<p>
						Bonfire Night — also known as Guy Fawkes Night — is celebrated on
						the anniversary of the failed Gunpowder Plot of 1605. The date is
						fixed on 5 November every year, unlike Easter or other moveable
						holidays, making the countdown straightforward to calculate.
					</p>
				</div>
			</section>

			<section class="bn-faq">
				<h2 class="bn-section-title">Frequently asked questions</h2>
				<div class="bn-faq-list">
					<details class="bn-faq-item">
						<summary class="bn-faq-question"
							>How many days until Bonfire Night 2026?</summary
						>
						<div class="bn-faq-answer">
							<p>
								The number changes every day, but you can see the live count at
								the top of this page — it updates every second. Bonfire Night
								2026 falls on Thursday 5 November. The countdown shows the
								exact days, hours, minutes, and seconds remaining until midnight
								on that date.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question">What is Bonfire Night?</summary>
						<div class="bn-faq-answer">
							<p>
								Bonfire Night — also called Guy Fawkes Night or Fireworks Night
								— is a British tradition held on 5 November each year. It
								commemorates the failure of the Gunpowder Plot in 1605, when
								conspirators tried to blow up the Houses of Parliament. Today it
								is marked with bonfires, fireworks, and effigies of Guy Fawkes.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question">Who was Guy Fawkes?</summary>
						<div class="bn-faq-answer">
							<p>
								Guy Fawkes was an English Catholic who joined the Gunpowder Plot
								to assassinate King James I and restore a Catholic monarch. Born
								in York in 1570, he was caught in the cellars of Parliament on
								5 November 1605 guarding barrels of gunpowder. He was tried,
								convicted, and executed in January 1606.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question">What was the Gunpowder Plot?</summary>
						<div class="bn-faq-answer">
							<p>
								The Gunpowder Plot was a 1605 conspiracy led by Robert Catesby
								to blow up King James I and the House of Lords during the State
								Opening of Parliament. Guy Fawkes was the explosives expert
								assigned to light the fuse. An anonymous letter warning a
								Catholic lord led to a search of the cellars, and the plot was
								foiled before it could be carried out.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question"
							>Why do we burn a Guy on Bonfire Night?</summary
						>
						<div class="bn-faq-answer">
							<p>
								Burning an effigy of Guy Fawkes on the bonfire dates back to
								1605 itself, when Londoners celebrated the king's survival with
								bonfires. The tradition of making a "Guy" from old clothes and
								parading it before burning it on the fire became a staple of
								Bonfire Night — a symbolic punishment for treason.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question"
							>Which UK city has the biggest Bonfire Night celebrations?</summary
						>
						<div class="bn-faq-answer">
							<p>
								Lewes in East Sussex is widely regarded as the bonfire capital of
								the UK. Its seven bonfire societies organise torchlit processions,
								rolling flaming barrels, and multiple bonfires on 5 November —
								attracting tens of thousands of visitors each year.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question"
							>What day of the week is Bonfire Night 2026?</summary
						>
						<div class="bn-faq-answer">
							<p>
								Bonfire Night 2026 falls on a Thursday, 5 November. The stat
								card above the countdown confirms the weekday for the target year
								automatically, so you always know whether the date lands on a
								weekend or a weekday.
							</p>
						</div>
					</details>
					<details class="bn-faq-item">
						<summary class="bn-faq-question"
							>Is Bonfire Night only celebrated in the UK?</summary
						>
						<div class="bn-faq-answer">
							<p>
								Bonfire Night is primarily a British tradition, especially in
								England, Scotland, and Wales. Some Commonwealth countries with
								British heritage hold similar events, but the 5 November
								commemoration of the Gunpowder Plot is most deeply rooted in the
								United Kingdom. Northern Ireland also observes the date, though
								with varying local traditions.
							</p>
						</div>
					</details>
				</div>
			</section>

			<div class="bn-related">
				<h3 class="bn-related-title">You might also like</h3>
				<div class="bn-related-grid">
					<a href="/days-until-halloween" class="bn-related-card"
						><span class="bn-related-name">Days Until Halloween</span></a
					>
					<a href="/days-until-christmas" class="bn-related-card"
						><span class="bn-related-name">Days Until Christmas</span></a
					>
					<a href="/countdown-timer" class="bn-related-card"
						><span class="bn-related-name">Countdown Timer</span></a
					>
					<a href="/year-progress" class="bn-related-card"
						><span class="bn-related-name">Year Progress Bar</span></a
					>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.bn-page {
		width: 100%;
	}

	.bn-hero {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 72px 24px;
		background: linear-gradient(135deg, #1a0800, #2d1000);
		border-bottom: 1px solid rgba(255, 100, 0, 0.25);
		overflow: hidden;
		position: relative;
		min-height: 320px;
	}

	.bn-hero-decor {
		position: absolute;
		inset: 0;
		pointer-events: none;
		user-select: none;
	}

	.bn-float-emoji {
		position: absolute;
		display: inline-block;
		line-height: 1;
		transform: rotate(var(--rotation, 0deg));
		animation: bn-float 4s ease-in-out infinite;
		opacity: 0.9;
	}

	@media (max-width: 600px) {
		.bn-float-emoji {
			opacity: 0.35;
		}
	}

	@keyframes bn-float {
		0%,
		100% {
			transform: translateY(0) rotate(var(--rotation, 0deg));
		}
		33% {
			transform: translateY(-10px) rotate(calc(var(--rotation, 0deg) - 3deg));
		}
		66% {
			transform: translateY(-5px) rotate(calc(var(--rotation, 0deg) + 3deg));
		}
	}

	.bn-hero-centre {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 720px;
	}

	.bn-hero-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 64px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 32px;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.bn-countdown {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		flex-wrap: wrap;
		gap: 8px 12px;
	}

	.bn-countdown-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.bn-countdown-num {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
		min-width: 64px;
		text-align: center;
	}

	.bn-countdown-num--days {
		font-size: clamp(80px, 13vw, 120px);
		letter-spacing: -4px;
		min-width: 100px;
	}

	.bn-countdown-sep {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		color: rgba(255, 255, 255, 0.3);
		line-height: 1;
		margin-bottom: 26px;
		padding: 0 2px;
	}

	.bn-countdown-unit {
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
	}

	.bn-body {
		max-width: 800px;
		margin: 0 auto;
		padding: 48px 24px 60px;
	}

	.bn-stats-section {
		margin-bottom: 16px;
	}

	.bn-stats-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 20px;
	}

	.bn-stats-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.bn-stats-grid {
			grid-template-columns: 1fr;
		}
	}

	.bn-stat-card {
		background: #2d1000;
		border: 1px solid rgba(255, 100, 0, 0.4);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.bn-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		margin-bottom: 10px;
	}

	.bn-stat-value {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.4;
		color: #ff6600;
	}

	.bn-share-btn {
		display: block;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		max-width: 320px;
		margin: 0 auto 48px;
		transition: opacity 0.2s ease;
	}

	.bn-share-btn:hover {
		opacity: 0.9;
	}

	.bn-facts {
		margin-bottom: 48px;
	}

	.bn-facts-title {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 20px;
	}

	.bn-facts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.bn-facts-grid {
			grid-template-columns: 1fr;
		}
	}

	.bn-fact-card {
		background: #1a0800;
		border: 1px solid rgba(255, 100, 0, 0.3);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.bn-fact-emoji {
		font-size: 28px;
		margin-bottom: 12px;
		line-height: 1;
	}

	.bn-fact-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		color: #ff6600;
		margin-bottom: 8px;
	}

	.bn-fact-text {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.6;
	}

	.bn-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.bn-how {
		margin-bottom: 48px;
	}

	.bn-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 100, 0, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.bn-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.bn-how-card p:last-child {
		margin-bottom: 0;
	}

	.bn-faq {
		margin-bottom: 48px;
	}

	.bn-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.bn-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(255, 100, 0, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.bn-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.bn-faq-question::-webkit-details-marker {
		display: none;
	}

	.bn-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
