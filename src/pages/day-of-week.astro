<script define:vars={{ dayNames, dayAbbr }}>
	const dateInput = document.getElementById('date-input');
	const results = document.getElementById('dow-results');
	const bornSection = document.getElementById('dow-born');

	function startOfDay(d) {
		return new Date(d.getFullYear(), d.getMonth(), d.getDate());
	}

	function formatDateLong(d) {
		return d.toLocaleDateString('en-GB', {
			weekday: 'long',
			day: 'numeric',
			month: 'long',
			year: 'numeric',
		});
	}

	function formatDateShort(d) {
		return d.toLocaleDateString('en-GB', {
			day: 'numeric',
			month: 'long',
		});
	}

	function getISOWeekNumber(d) {
		const date = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
		const dayNum = date.getUTCDay() || 7;
		date.setUTCDate(date.getUTCDate() + 4 - dayNum);
		const yearStart = new Date(Date.UTC(date.getUTCFullYear(), 0, 1));
		return Math.ceil(
			((date.getTime() - yearStart.getTime()) / 86400000 + 1) / 7,
		);
	}

	function daysBetween(a, b) {
		return Math.round((b.getTime() - a.getTime()) / 86400000);
	}

	function getDayDistribution(month, day) {
		const counts = [0, 0, 0, 0, 0, 0, 0];
		const endYear = new Date().getFullYear();
		const startYear = endYear - 99;

		for (let year = startYear; year <= endYear; year++) {
			const d = new Date(year, month, day);
			if (d.getMonth() !== month || d.getDate() !== day) continue;
			counts[d.getDay()]++;
		}

		return counts;
	}

	function toInputValue(d) {
		const y = d.getFullYear();
		const m = String(d.getMonth() + 1).padStart(2, '0');
		const day = String(d.getDate()).padStart(2, '0');
		return `${y}-${m}-${day}`;
	}

	function renderChart(counts, activeDayIndex) {
		const chart = document.getElementById('dow-chart');
		if (!chart) return;

		const max = Math.max(...counts, 1);
		chart.innerHTML = '';

		// Monday-first order for display
		const order = [1, 2, 3, 4, 5, 6, 0];

		for (const dayIndex of order) {
			const col = document.createElement('div');
			col.className = 'dow-bar-col';

			const countEl = document.createElement('div');
			countEl.className = 'dow-bar-count';
			countEl.textContent = String(counts[dayIndex]);

			const bar = document.createElement('div');
			bar.className = 'dow-bar';
			if (dayIndex === activeDayIndex) bar.classList.add('dow-bar--active');
			bar.style.height = `${Math.max(8, (counts[dayIndex] / max) * 80)}px`;

			const label = document.createElement('div');
			label.className = 'dow-bar-label';
			if (dayIndex === activeDayIndex) label.classList.add('dow-bar-label--active');
			label.textContent = dayAbbr[dayIndex];

			col.append(countEl, bar, label);
			chart.appendChild(col);
		}
	}

	function calculate() {
		if (!dateInput || !results) return;

		const raw = dateInput.value;
		if (!raw) {
			results.style.display = 'none';
			if (bornSection) bornSection.style.display = 'none';
			return;
		}

		const parts = raw.split('-').map(Number);
		const target = new Date(parts[0], parts[1] - 1, parts[2]);
		if (isNaN(target.getTime())) return;

		const today = startOfDay(new Date());
		const targetDay = startOfDay(target);
		const dayIndex = target.getDay();
		const dayName = dayNames[dayIndex];
		const diff = daysBetween(today, targetDay);

		results.style.display = 'block';

		const dayEl = document.getElementById('dow-day');
		const dateDisplayEl = document.getElementById('dow-date-display');
		const timelineEl = document.getElementById('dow-timeline');
		const offsetEl = document.getElementById('dow-offset');
		const weekEl = document.getElementById('dow-week-num');

		if (dayEl) dayEl.textContent = dayName;
		if (dateDisplayEl) dateDisplayEl.textContent = formatDateLong(target);

		if (timelineEl && offsetEl) {
			if (diff === 0) {
				timelineEl.textContent = 'Present';
				offsetEl.textContent = 'That date is today';
			} else if (diff < 0) {
				const days = Math.abs(diff);
				timelineEl.textContent = 'Past';
				offsetEl.textContent =
					days === 1
						? 'That was 1 day ago'
						: `That was ${days.toLocaleString()} days ago`;
			} else {
				timelineEl.textContent = 'Future';
				offsetEl.textContent =
					diff === 1
						? 'That is 1 day from now'
						: `That is ${diff.toLocaleString()} days from now`;
			}
		}

		if (weekEl) weekEl.textContent = String(getISOWeekNumber(target));

		// Born on a... section (past dates only)
		if (bornSection) {
			if (diff < 0) {
				bornSection.style.display = 'block';

				const titleEl = document.getElementById('dow-born-title');
				const factEl = document.getElementById('dow-born-fact');
				const month = target.getMonth();
				const day = target.getDate();
				const counts = getDayDistribution(month, day);
				const total = counts.reduce((a, b) => a + b, 0);
				const maxCount = Math.max(...counts);
				const mostCommonIndex = counts.indexOf(maxCount);

				if (titleEl) {
					titleEl.textContent = `Born on a ${dayName}?`;
				}

				if (factEl) {
					const shortDate = formatDateShort(target);
					factEl.textContent = `Over the last 100 years, ${shortDate} has fallen on a ${dayName} ${counts[dayIndex]} time${counts[dayIndex] === 1 ? '' : 's'} out of ${total} — most often on a ${dayNames[mostCommonIndex]} (${maxCount} times).`;
				}

				renderChart(counts, dayIndex);
			} else {
				bornSection.style.display = 'none';
			}
		}
	}

	dateInput?.addEventListener('input', calculate);
	dateInput?.addEventListener('change', calculate);

	document.querySelectorAll('.dow-quick-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const preset = btn.dataset.preset;
			if (!preset || !dateInput) return;

			let d;
			if (preset === 'today') {
				d = new Date();
			} else if (preset === 'tomorrow') {
				d = new Date();
				d.setDate(d.getDate() + 1);
			} else if (preset === 'yesterday') {
				d = new Date();
				d.setDate(d.getDate() - 1);
			} else {
				const [y, m, day] = preset.split('-').map(Number);
				d = new Date(y, m - 1, day);
			}

			dateInput.value = toInputValue(d);
			calculate();
			results?.scrollIntoView({ behavior: 'smooth', block: 'center' });
		});
	});
</script>
