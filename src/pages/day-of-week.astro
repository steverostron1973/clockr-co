---
import Layout from '../layouts/Layout.astro';

const dayNames = [
	'Sunday',
	'Monday',
	'Tuesday',
	'Wednesday',
	'Thursday',
	'Friday',
	'Saturday',
];
const dayAbbr = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
---

<Layout
	title="Day of the Week Calculator — What Day Was I Born | Clockr"
	description="Find out what day of the week any date falls on. Free calculator for birthdays, anniversaries and historical dates."
>
	<div class="dow-page">
		<!-- PAGE HEADER -->
		<div class="dow-header">
			<div class="dow-eyebrow">📅 Calendar & Dates</div>
			<h1 class="dow-title">
				<span class="dow-gradient">Day of the Week</span><br />
				<span class="dow-gradient">Calculator</span>
			</h1>
			<p class="dow-subtitle">
				Find out what day of the week any date falls on
			</p>
		</div>

		<!-- INPUT -->
		<div class="dow-input-wrap">
			<label class="dow-label" for="date-input">Enter a date</label>
			<input type="date" id="date-input" class="dow-input" />
		</div>

		<!-- RESULTS -->
		<div class="dow-results" id="dow-results" style="display:none">
			<div class="dow-main-card">
				<div class="dow-day" id="dow-day">Tuesday</div>
				<div class="dow-date-display" id="dow-date-display"></div>
				<div class="dow-timeline" id="dow-timeline"></div>
				<div class="dow-offset" id="dow-offset"></div>
			</div>

			<div class="dow-stat-card">
				<div class="dow-stat-num" id="dow-week-num">0</div>
				<div class="dow-stat-label">Week of the year</div>
			</div>
		</div>

		<!-- BORN ON A... -->
		<div class="dow-born" id="dow-born" style="display:none">
			<h2 class="dow-section-title" id="dow-born-title">Born on a Tuesday?</h2>
			<p class="dow-born-fact" id="dow-born-fact"></p>
			<div class="dow-chart-wrap">
				<div class="dow-chart" id="dow-chart" aria-label="Weekday distribution chart"></div>
			</div>
			<p class="dow-chart-caption">
				How often this date fell on each weekday over the last 100 years
			</p>
		</div>

		<!-- QUICK REFERENCE -->
		<div class="dow-quick">
			<h2 class="dow-section-title">What day was/is…</h2>
			<div class="dow-quick-grid">
				<button type="button" class="dow-quick-btn" data-preset="today"
					>Today</button
				>
				<button type="button" class="dow-quick-btn" data-preset="tomorrow"
					>Tomorrow</button
				>
				<button type="button" class="dow-quick-btn" data-preset="yesterday"
					>Yesterday</button
				>
				<button type="button" class="dow-quick-btn" data-preset="2000-01-01"
					>1 January 2000</button
				>
				<button type="button" class="dow-quick-btn" data-preset="2030-01-01"
					>1 January 2030</button
				>
				<button type="button" class="dow-quick-btn" data-preset="2026-12-25"
					>25 December 2026</button
				>
			</div>
		</div>

		<!-- HOW IT WORKS -->
		<section class="dow-how">
			<h2 class="dow-section-title">How it works</h2>
			<div class="dow-how-card">
				<p>
					Every date falls on one of seven weekdays in a repeating cycle. The
					Gregorian calendar advances by one weekday each year, but leap years
					shift the pattern by an extra day — so the same calendar date lands on
					a different weekday almost every year.
				</p>
				<p>
					Clockr calculates the day of the week using JavaScript's built-in date
					library, which accounts for leap years and century-year exceptions back
					to 1582 when the Gregorian calendar was introduced. Enter any date and
					the result appears instantly — no lookup tables or mental arithmetic
					required.
				</p>
				<p>
					The "Born on a…" chart counts how many times your month-and-day
					combination fell on each weekday over the past century. Because of the
					leap-year cycle, most dates land on each weekday between 14 and 15
					times per 100 years — but February 29th is the rare exception, appearing
					on each weekday only about twice per century.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="dow-faq">
			<h2 class="dow-section-title">Frequently asked questions</h2>
			<div class="dow-faq-list">
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>What day of the week was I born?</summary
					>
					<div class="dow-faq-answer">
						<p>
							Enter your date of birth into the calculator above. The tool
							instantly shows the weekday — Monday, Tuesday, and so on — along
							with whether that date is in the past, present, or future relative
							to today. The "Born on a…" section also reveals how often your
							birthday has fallen on each weekday over the last 100 years.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>How do I find out what day a date falls on?</summary
					>
					<div class="dow-faq-answer">
						<p>
							Type or pick any date using the date input at the top of this page.
							As soon as you enter a valid date, Clockr displays the weekday in
							large text along with the week number of the year. You can also
							click one of the quick-reference buttons — Today, Tomorrow,
							Yesterday, or a preset historical date — for an instant answer.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>What day of the week is Christmas 2026?</summary
					>
					<div class="dow-faq-answer">
						<p>
							Christmas Day 2026 falls on a Friday. Click the "25 December 2026"
							button in the quick-reference section above to see the result
							instantly, or enter 2026-12-25 in the date field.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>How many times does a date fall on the same weekday in 100 years?</summary
					>
					<div class="dow-faq-answer">
						<p>
							Most calendar dates (like 15 March or 4 July) fall on each weekday
							between 14 and 15 times over any 100-year span, because the
							400-year Gregorian cycle distributes weekdays almost evenly. The
							"Born on a…" bar chart on this page shows the exact distribution
							for your chosen date. February 29th is the outlier — it occurs only
							about 24 times per century and lands on each weekday roughly twice.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>What is the Doomsday algorithm?</summary
					>
					<div class="dow-faq-answer">
						<p>
							The Doomsday algorithm is a mental-math technique invented by
							John Horton Conway for calculating weekdays without a calendar. It
							works by memorising a few "doomsday" anchor dates that always fall
							on the same weekday in a given year — such as 4 April, 6 June, and
							31 December — then counting forward or backward from the nearest
							anchor. With practice you can determine any date's weekday in
							seconds, but a calculator is faster for most people.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>Why does the same date fall on different days each year?</summary
					>
					<div class="dow-faq-answer">
						<p>
							A common year has 365 days, which is 52 weeks plus one extra day.
							That means every date shifts forward by one weekday the following
							year. Leap years add a second shift, so dates after February 29
							jump two weekdays instead of one. Over four years the shifts cancel
							out for most dates, but the century-year rules create a longer
							400-year cycle before the pattern fully repeats.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>What day of the week occurs most often on the 13th?</summary
					>
					<div class="dow-faq-answer">
						<p>
							Friday is the most common weekday for the 13th of any month. In the
							400-year Gregorian cycle, the 13th falls on a Friday 688 times
							compared with 685 times for Thursday and Saturday and 684 for the
							other weekdays. This slight imbalance is what fuels the superstition
							around Friday the 13th — it genuinely occurs more often than any
							other weekday–date combination.
						</p>
					</div>
				</details>
				<details class="dow-faq-item">
					<summary class="dow-faq-question"
						>How do I calculate the day of the week for any date in history?</summary
					>
					<div class="dow-faq-answer">
						<p>
							For dates after 15 October 1582 (when the Gregorian calendar was
							adopted in much of Europe), enter the date directly into this
							calculator. For earlier dates you need to account for the Julian
							calendar and regional adoption dates — Britain, for example, did
							not switch until 1752. Historical researchers often use specialised
							tools or the Zeller's congruence formula for pre-Gregorian dates.
						</p>
					</div>
				</details>
			</div>
		</section>

		<!-- RELATED TOOLS -->
		<div class="dow-related">
			<h3 class="dow-related-title">You might also like</h3>
			<div class="dow-related-grid">
				<a href="/date-calculator" class="dow-related-card"
					><span class="dow-related-name">Date Calculator</span></a
				>
				<a href="/leap-year" class="dow-related-card"
					><span class="dow-related-name">Leap Year Checker</span></a
				>
				<a href="/days-until-birthday" class="dow-related-card"
					><span class="dow-related-name">Days Until My Birthday</span></a
				>
				<a href="/age-calculator" class="dow-related-card"
					><span class="dow-related-name">Age Calculator</span></a
				>
			</div>
		</div>
	</div>
</Layout>

