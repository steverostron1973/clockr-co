---
import Layout from '../layouts/Layout.astro';

const leftEmojis = [
	{ emoji: '🎃', size: 48, rotation: -15, top: '10%', side: '2%', delay: 0 },
	{ emoji: '👻', size: 32, rotation: 12, top: '25%', side: '8%', delay: 0.5 },
	{ emoji: '🕷️', size: 40, rotation: -8, top: '45%', side: '4%', delay: 1 },
	{ emoji: '🦇', size: 28, rotation: 15, top: '65%', side: '10%', delay: 1.5 },
	{ emoji: '💀', size: 44, rotation: -12, top: '80%', side: '6%', delay: 2 },
	{ emoji: '🕸️', size: 36, rotation: 8, top: '35%', side: '2%', delay: 2.5 },
];

const rightEmojis = [
	{ emoji: '🌙', size: 36, rotation: -5, top: '15%', side: '3%', delay: 3 },
	{ emoji: '🔮', size: 48, rotation: 14, top: '30%', side: '9%', delay: 3.5 },
	{ emoji: '🪄', size: 30, rotation: -10, top: '50%', side: '5%', delay: 4 },
	{ emoji: '☠️', size: 42, rotation: 6, top: '70%', side: '8%', delay: 4.5 },
	{ emoji: '🕯️', size: 28, rotation: -15, top: '85%', side: '4%', delay: 5 },
	{ emoji: '🍬', size: 46, rotation: 10, top: '40%', side: '2%', delay: 5.5 },
];
---

<Layout
	title="Days Until Halloween 2026 — Halloween Countdown | Clockr"
	description="How many days until Halloween 2026? Live Halloween countdown showing exact days, hours, minutes and seconds until 31st October."
>
	<div class="hw-page">
		<!-- FULL-WIDTH HERO BAND -->
		<section class="hw-hero" aria-label="Halloween countdown">
			<div class="hw-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="hw-float-emoji hw-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="hw-float-emoji hw-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
			</div>

			<div class="hw-hero-centre">
				<h1 class="hw-hero-title">Days Until Halloween</h1>

				<div class="hw-countdown" id="hw-countdown">
					<div class="hw-countdown-block">
						<span class="hw-countdown-num hw-countdown-num--days" id="hero-days"
							>0</span
						>
						<span class="hw-countdown-unit">Days</span>
					</div>
					<span class="hw-countdown-sep">:</span>
					<div class="hw-countdown-block">
						<span class="hw-countdown-num" id="hero-hours">00</span>
						<span class="hw-countdown-unit">Hours</span>
					</div>
					<span class="hw-countdown-sep">:</span>
					<div class="hw-countdown-block">
						<span class="hw-countdown-num" id="hero-mins">00</span>
						<span class="hw-countdown-unit">Minutes</span>
					</div>
					<span class="hw-countdown-sep">:</span>
					<div class="hw-countdown-block">
						<span class="hw-countdown-num" id="hero-secs">00</span>
						<span class="hw-countdown-unit">Seconds</span>
					</div>
				</div>
			</div>
		</section>

		<div class="hw-body">
			<!-- STATS -->
			<section class="hw-stats-section">
				<h2 class="hw-stats-heading">Halloween by the numbers</h2>
				<div class="hw-stats-grid">
					<div class="hw-stat-card">
						<div class="hw-stat-label">Exact time remaining</div>
						<div class="hw-stat-value" id="stat-exact">—</div>
					</div>
					<div class="hw-stat-card">
						<div class="hw-stat-label">Halloween day</div>
						<div class="hw-stat-value" id="stat-weekday">—</div>
					</div>
					<div class="hw-stat-card">
						<div class="hw-stat-label">Sleeps until Halloween</div>
						<div class="hw-stat-value" id="stat-sleeps">—</div>
					</div>
					<div class="hw-stat-card">
						<div class="hw-stat-label">Weeks until Halloween</div>
						<div class="hw-stat-value" id="stat-weeks">—</div>
					</div>
				</div>
			</section>

			<!-- SHARE -->
			<button class="hw-share-btn" id="hw-share-btn">📋 Copy &amp; Share</button>

			<!-- FUN FACTS -->
			<section class="hw-facts">
				<h2 class="hw-facts-title">Halloween fun facts</h2>
				<div class="hw-facts-grid">
					<div class="hw-fact-card">
						<div class="hw-fact-emoji">🎃</div>
						<h3 class="hw-fact-heading">The jack-o'-lantern origin</h3>
						<p class="hw-fact-text">
							Carving vegetables for Halloween began in Ireland with turnips,
							not pumpkins. Irish immigrants brought the tradition to America,
							where pumpkins proved far easier to hollow out.
						</p>
					</div>
					<div class="hw-fact-card">
						<div class="hw-fact-emoji">👻</div>
						<h3 class="hw-fact-heading">All Hallows' Eve</h3>
						<p class="hw-fact-text">
							Halloween marks the eve of All Saints' Day on 1 November. The name
							comes from "All Hallows' Eve" — hallow meaning saint — and dates
							back to Celtic Samhain festivals over 2,000 years ago.
						</p>
					</div>
					<div class="hw-fact-card">
						<div class="hw-fact-emoji">🍬</div>
						<h3 class="hw-fact-heading">Trick-or-treat spending</h3>
						<p class="hw-fact-text">
							Americans spend over $3 billion on Halloween candy each year. The
							most popular treat? Reese's Peanut Butter Cups — followed closely
							by M&amp;Ms and Snickers.
						</p>
					</div>
					<div class="hw-fact-card">
						<div class="hw-fact-emoji">🦇</div>
						<h3 class="hw-fact-heading">Why bats are spooky</h3>
						<p class="hw-fact-text">
							Bats became linked to Halloween through Samhain bonfires, which
							attracted insects — and the bats that fed on them. Bram Stoker's
							Dracula cemented their place in horror folklore forever.
						</p>
					</div>
				</div>
			</section>

			<!-- HOW IT WORKS -->
			<section class="hw-how">
				<h2 class="hw-section-title">How is the Halloween countdown calculated?</h2>
				<div class="hw-how-card">
					<p>
						The countdown measures the exact number of seconds between right now
						and midnight on 31 October 2026 — the moment Halloween begins. That
						total is broken down into days, hours, minutes, and seconds, and the
						display refreshes every second so you always see the precise time
						remaining, not a rounded estimate.
					</p>
					<p>
						Halloween did not begin with costumes and candy. It evolved from
						Samhain, an ancient Celtic festival marking the end of the harvest
						season. Celts believed that on this night the boundary between the
						living and the dead grew thin, allowing spirits to cross into the
						world of the living — a tradition that shaped the ghosts, ghouls, and
						supernatural themes we associate with Halloween today.
					</p>
					<p>
						Once 31 October has passed, the countdown automatically rolls over
						to the following year. You never need to refresh the page or pick a
						new date — Clockr detects that Halloween has arrived and immediately
						starts counting down to 31 October of the next year, keeping the
						timer running year after year.
					</p>
				</div>
			</section>

			<!-- FAQ -->
			<section class="hw-faq">
				<h2 class="hw-section-title">Frequently asked questions</h2>
				<div class="hw-faq-list">
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>How many days until Halloween 2026?</summary
						>
						<div class="hw-faq-answer">
							<p>
								The number changes every day, but you can see the live count at
								the top of this page — it updates every second. Halloween 2026
								falls on Saturday 31 October. The countdown shows the exact
								days, hours, minutes, and seconds remaining until midnight on
								that date.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>What day of the week is Halloween 2026?</summary
						>
						<div class="hw-faq-answer">
							<p>
								Halloween 2026 falls on a Saturday, 31 October. The stat card
								above the countdown confirms the weekday for the target year
								automatically, so you always know whether Halloween lands on a
								weekend or a weekday.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question">Where did Halloween originate?</summary>
						<div class="hw-faq-answer">
							<p>
								Halloween traces its roots to Samhain, a Celtic festival
								celebrated over 2,000 years ago in what is now Ireland, Britain,
								and northern France. When Christianity spread through Celtic
								lands, the church placed All Saints' Day on 1 November, making
								31 October "All Hallows' Eve" — which eventually became
								Halloween.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>How much is spent on Halloween in the US each year?</summary
						>
						<div class="hw-faq-answer">
							<p>
								Americans spend over $12 billion on Halloween annually, covering
								costumes, decorations, candy, and greeting cards. Per-person
								spending typically exceeds $100, with costumes and candy making
								up the largest shares. It is consistently one of the biggest
								retail events of the year in the United States.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>What is the most popular Halloween costume?</summary
						>
						<div class="hw-faq-answer">
							<p>
								Witch costumes consistently rank among the most popular Halloween
								outfits in the United States, followed by vampires, zombies,
								and superheroes. Children's favourites often include princesses,
								spiders, and characters from current films. Trends shift each
								year, but classic spooky costumes never go out of style.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>Where did trick or treating come from?</summary
						>
						<div class="hw-faq-answer">
							<p>
								Trick-or-treating has roots in medieval European traditions
								where the poor would go door to door on All Souls' Day receiving
								"soul cakes" in exchange for prayers for the dead. Irish and
								Scottish immigrants brought similar customs to America in the
								19th century, and by the 1950s the modern door-to-door
								candy tradition was firmly established.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>Which country celebrates Halloween the most?</summary
						>
						<div class="hw-faq-answer">
							<p>
								The United States celebrates Halloween more widely and
								extravagantly than any other country, with nationwide trick-or-
								treating, haunted houses, and billions in retail spending.
								Ireland and the UK also have strong Halloween traditions as
								the festival's Celtic birthplace, while countries like Canada,
								Australia, and Japan have adopted the holiday in recent decades.
							</p>
						</div>
					</details>
					<details class="hw-faq-item">
						<summary class="hw-faq-question"
							>What is the origin of carving pumpkins?</summary
						>
						<div class="hw-faq-answer">
							<p>
								Pumpkin carving began in Ireland with turnips, not pumpkins.
								According to folklore, a man named Stingy Jack tricked the
								devil and was doomed to wander with only a carved turnip lantern
								for light — the original jack-o'-lantern. Irish immigrants found
								pumpkins far easier to carve in America, and the tradition
								switched to the larger, brighter vegetable we use today.
							</p>
						</div>
					</details>
				</div>
			</section>

			<!-- RELATED TOOLS -->
			<div class="hw-related">
				<h3 class="hw-related-title">You might also like</h3>
				<div class="hw-related-grid">
					<a href="/days-until-christmas" class="hw-related-card"
						><span class="hw-related-name">Days Until Christmas</span></a
					>
					<a href="/days-until-new-year" class="hw-related-card"
						><span class="hw-related-name">Days Until New Year</span></a
					>
					<a href="/days-until-valentines" class="hw-related-card"
						><span class="hw-related-name">Days Until Valentine's Day</span></a
					>
					<a href="/countdown-timer" class="hw-related-card"
						><span class="hw-related-name">Countdown Timer</span></a
					>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.hw-page {
		width: 100%;
	}

	/* ── HERO BAND ── */
	.hw-hero {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 72px 24px;
		background: linear-gradient(135deg, #1a0a00, #2d1200);
		border-bottom: 1px solid rgba(255, 100, 0, 0.25);
		overflow: hidden;
		position: relative;
		min-height: 320px;
	}

	.hw-hero-decor {
		position: absolute;
		inset: 0;
		pointer-events: none;
		user-select: none;
	}

	.hw-float-emoji {
		position: absolute;
		display: inline-block;
		line-height: 1;
		transform: rotate(var(--rotation, 0deg));
		animation: hw-float 4s ease-in-out infinite;
		opacity: 0.9;
	}

	@media (max-width: 600px) {
		.hw-float-emoji {
			opacity: 0.35;
		}
	}

	@keyframes hw-float {
		0%,
		100% {
			transform: translateY(0) rotate(var(--rotation, 0deg));
		}
		33% {
			transform: translateY(-10px) rotate(calc(var(--rotation, 0deg) - 3deg));
		}
		66% {
			transform: translateY(-5px) rotate(calc(var(--rotation, 0deg) + 3deg));
		}
	}

	.hw-hero-centre {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 720px;
	}

	.hw-hero-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 64px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 32px;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hw-countdown {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		flex-wrap: wrap;
		gap: 8px 12px;
	}

	.hw-countdown-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.hw-countdown-num {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
		min-width: 64px;
		text-align: center;
	}

	.hw-countdown-num--days {
		font-size: clamp(80px, 13vw, 120px);
		letter-spacing: -4px;
		min-width: 100px;
	}

	.hw-countdown-sep {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 900;
		color: rgba(255, 255, 255, 0.3);
		line-height: 1;
		margin-bottom: 26px;
		padding: 0 2px;
	}

	.hw-countdown-unit {
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
	}

	/* ── BODY ── */
	.hw-body {
		max-width: 800px;
		margin: 0 auto;
		padding: 48px 24px 60px;
	}

	.hw-stats-section {
		margin-bottom: 16px;
	}

	.hw-stats-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 20px;
	}

	.hw-stats-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.hw-stats-grid {
			grid-template-columns: 1fr;
		}
	}

	.hw-stat-card {
		background: #2d1200;
		border: 1px solid rgba(255, 100, 0, 0.4);
		border-radius: 14px;
		padding: 24px 20px;
	}

	.hw-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		margin-bottom: 10px;
	}

	.hw-stat-value {
		font-family: 'Outfit', sans-serif;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.4;
		color: #ff6600;
	}

	.hw-share-btn {
		display: block;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		max-width: 320px;
		margin: 0 auto 48px;
		transition: opacity 0.2s ease;
	}

	.hw-share-btn:hover {
		opacity: 0.9;
	}

	.hw-facts {
		margin-bottom: 48px;
	}

	.hw-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.hw-how {
		margin-bottom: 48px;
	}

	.hw-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 92, 77, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.hw-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.hw-how-card p:last-child {
		margin-bottom: 0;
	}

	.hw-faq {
		margin-bottom: 48px;
	}

	.hw-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.hw-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(255, 92, 77, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.hw-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hw-faq-question::-webkit-details-marker {
		display: none;
	}

	.hw-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hw-faq-item[open] .hw-faq-question::after {
		content: '−';
	}

	.hw-faq-answer {
		padding: 0 24px 18px;
	}

	.hw-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
