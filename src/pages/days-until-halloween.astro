		padding: 24px 20px;
	}

	.hw-fact-emoji {
		font-size: 28px;
		margin-bottom: 12px;
		line-height: 1;
	}

	.hw-fact-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 8px;
	}

	.hw-fact-text {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.6;
	}

	.hw-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.hw-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.hw-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.hw-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.hw-related-card:hover {
		border-color: rgba(255, 92, 77, 0.4);
	}

	.hw-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #ff5c4d, #ff9a3c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>

<script>
	function pad(n: number) {
		return String(n).padStart(2, '0');
	}

	function getTargetHalloween(): Date {
		const now = new Date();
		let year = now.getFullYear();
		const halloween = new Date(year, 9, 31, 0, 0, 0, 0);
		if (now.getTime() >= halloween.getTime()) {
			year += 1;
		}
		return new Date(year, 9, 31, 0, 0, 0, 0);
	}

	function updateCountdown() {
		const now = new Date();
		const halloween = getTargetHalloween();
		const diff = halloween.getTime() - now.getTime();

		if (diff <= 0) return;

		const totalSeconds = Math.floor(diff / 1000);
		const days = Math.floor(totalSeconds / 86400);
		const hours = Math.floor((totalSeconds % 86400) / 3600);
		const mins = Math.floor((totalSeconds % 3600) / 60);
		const secs = totalSeconds % 60;

		const heroDays = document.getElementById('hero-days');
		const heroHours = document.getElementById('hero-hours');
		const heroMins = document.getElementById('hero-mins');
		const heroSecs = document.getElementById('hero-secs');
		const statExact = document.getElementById('stat-exact');
		const statWeekday = document.getElementById('stat-weekday');
		const statSleeps = document.getElementById('stat-sleeps');
		const statWeeks = document.getElementById('stat-weeks');
		const shareDays = document.getElementById('share-days');

		if (heroDays) heroDays.textContent = String(days);
		if (heroHours) heroHours.textContent = pad(hours);
		if (heroMins) heroMins.textContent = pad(mins);
		if (heroSecs) heroSecs.textContent = pad(secs);

		const year = halloween.getFullYear();
		const weekday = halloween.toLocaleDateString('en-GB', { weekday: 'long' });
		const weeks = Math.floor(days / 7);

		if (statExact)
			statExact.textContent = `${days} days, ${hours} hours, ${mins} minutes, ${secs} seconds until 31 October ${year}`;
		if (statWeekday)
			statWeekday.textContent = `Halloween ${year} falls on a ${weekday}`;
		if (statSleeps)
			statSleeps.textContent =
				days === 0
					? 'Tonight! 🎃'
					: `${days} sleep${days === 1 ? '' : 's'}`;
		if (statWeeks)
			statWeeks.textContent = `${weeks} week${weeks === 1 ? '' : 's'}`;
		if (shareDays) shareDays.textContent = String(days);
	}

	const shareBtn = document.getElementById('hw-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = document.getElementById('hero-days')?.textContent ?? '0';
		const halloween = getTargetHalloween();
		const year = halloween.getFullYear();
		navigator.clipboard.writeText(
			`🎃 Halloween is ${days} days away! Only ${days} sleeps until 31 October ${year}. Count down at Clockr.co`,
		);
		shareBtn.textContent = '✓ Copied!';
		setTimeout(() => {
			shareBtn.textContent = '📋 Copy & Share';
		}, 2000);
	});

	updateCountdown();
	setInterval(updateCountdown, 1000);
</script>
