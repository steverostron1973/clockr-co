	.ramadan-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #e8937a, #c9956c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
