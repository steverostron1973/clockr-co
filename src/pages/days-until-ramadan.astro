---
import Layout from '../layouts/Layout.astro';
import {
	formatRamadanDate,
	getNextRamadanStart,
	getRamadanDatesForClient,
} from '../data/ramadanDates';

const nextRamadan = getNextRamadanStart(new Date());
const targetYear = nextRamadan.year;
const targetDateLabel = formatRamadanDate(nextRamadan.date);
const hijriYear = nextRamadan.hijriYear;
const ramadanDates = getRamadanDatesForClient();

const leftEmojis = [
	{ emoji: '🕌', size: 48, rotation: -15, top: '10%', side: '2%', delay: 0 },
	{ emoji: '🌙', size: 32, rotation: 12, top: '25%', side: '8%', delay: 0.5 },
	{ emoji: '⭐', size: 40, rotation: -8, top: '45%', side: '4%', delay: 1 },
	{ emoji: '🙏', size: 28, rotation: 15, top: '65%', side: '10%', delay: 1.5 },
	{ emoji: '✨', size: 44, rotation: -12, top: '80%', side: '6%', delay: 2 },
	{ emoji: '🌙', size: 36, rotation: 8, top: '35%', side: '2%', delay: 2.5 },
];

const rightEmojis = [
	{ emoji: '☪️', size: 36, rotation: -5, top: '15%', side: '3%', delay: 3 },
	{ emoji: '🌙', size: 48, rotation: 14, top: '30%', side: '9%', delay: 3.5 },
	{ emoji: '⭐', size: 30, rotation: -10, top: '50%', side: '5%', delay: 4 },
	{ emoji: '🕌', size: 42, rotation: 6, top: '70%', side: '8%', delay: 4.5 },
	{ emoji: '🙏', size: 28, rotation: -15, top: '85%', side: '4%', delay: 5 },
	{ emoji: '✨', size: 46, rotation: 10, top: '40%', side: '2%', delay: 5.5 },
];
---

<Layout
	title={`Days Until Ramadan ${targetYear} — Ramadan Countdown | Clockr`}
	description={`How many days until Ramadan ${targetYear}? Live countdown to the start of Ramadan — ${targetDateLabel}.`}
	category="religious"
>
	<div class="ramadan-page">
		<section class="ramadan-hero" aria-label="Ramadan countdown">
			<div class="ramadan-hero-decor" aria-hidden="true">
				{
					leftEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="ramadan-float-emoji ramadan-float-emoji--left"
							style={`font-size:${size}px;top:${top};left:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
				{
					rightEmojis.map(({ emoji, size, rotation, top, side, delay }) => (
						<span
							class="ramadan-float-emoji ramadan-float-emoji--right"
							style={`font-size:${size}px;top:${top};right:${side};--rotation:${rotation}deg;animation-delay:${delay}s`}
						>
							{emoji}
						</span>
					))
				}
			</div>

			<div class="ramadan-hero-centre">
				<h1 class="ramadan-hero-title">Days Until Ramadan</h1>
				<p class="ramadan-hero-subtitle">Countdown to the start of Ramadan</p>

				<div class="ramadan-countdown" id="ramadan-countdown">
					<div class="ramadan-countdown-block">
						<span
							class="ramadan-countdown-num ramadan-countdown-num--days"
							id="hero-days">0</span
						>
						<span class="ramadan-countdown-unit">Days</span>
					</div>
					<span class="ramadan-countdown-sep">:</span>
					<div class="ramadan-countdown-block">
						<span class="ramadan-countdown-num" id="hero-hours">00</span>
						<span class="ramadan-countdown-unit">Hours</span>
					</div>
					<span class="ramadan-countdown-sep">:</span>
					<div class="ramadan-countdown-block">
						<span class="ramadan-countdown-num" id="hero-mins">00</span>
						<span class="ramadan-countdown-unit">Minutes</span>
					</div>
					<span class="ramadan-countdown-sep">:</span>
					<div class="ramadan-countdown-block">
						<span class="ramadan-countdown-num" id="hero-secs">00</span>
						<span class="ramadan-countdown-unit">Seconds</span>
					</div>
				</div>

				<p class="ramadan-target-date" id="hero-target-date">{targetDateLabel}</p>
				<p class="ramadan-disclaimer">
					Ramadan begins with the sighting of the new moon and may vary by a day
					depending on your location and local moon sighting announcements.
				</p>
			</div>
		</section>

		<div class="ramadan-body">
			<section class="ramadan-stats-section">
				<h2 class="ramadan-stats-heading">Ramadan by the numbers</h2>
				<div class="ramadan-stats-grid">
					<div class="ramadan-stat-card">
						<div class="ramadan-stat-label">Estimated start date</div>
						<div class="ramadan-stat-value" id="stat-date">—</div>
					</div>
					<div class="ramadan-stat-card">
						<div class="ramadan-stat-label">Hijri year</div>
						<div class="ramadan-stat-value" id="stat-hijri">—</div>
					</div>
					<div class="ramadan-stat-card">
						<div class="ramadan-stat-label">Weeks until Ramadan</div>
						<div class="ramadan-stat-value" id="stat-weeks">—</div>
					</div>
					<div class="ramadan-stat-card">
						<div class="ramadan-stat-label">Exact time remaining</div>
						<div class="ramadan-stat-value" id="stat-exact">—</div>
					</div>
				</div>
			</section>

			<button class="ramadan-share-btn" id="ramadan-share-btn"
				>📋 Copy &amp; Share</button
			>

			<section class="ramadan-about">
				<h2 class="ramadan-section-title">About Ramadan</h2>
				<div class="ramadan-about-card">
					<p>
						Ramadan is the ninth month of the Islamic lunar calendar and the
						holiest month in Islam. Muslims observe sawm — fasting from dawn to
						sunset — as one of the Five Pillars of Islam, alongside increased
						prayer, reflection, and charitable giving.
					</p>
					<p>
						The Quran is believed to have been first revealed during Ramadan,
						and the month includes Laylat al-Qadr (the Night of Decree), regarded
						as better than a thousand months. Ramadan lasts 29 or 30 days and
						ends with Eid al-Fitr, a festival of breaking the fast celebrated
						with family, food, and community.
					</p>
				</div>
			</section>

			<section class="ramadan-how">
				<h2 class="ramadan-section-title">How is the Ramadan countdown calculated?</h2>
				<div class="ramadan-how-card">
					<p>
						This countdown targets midnight on the estimated first day of
						Ramadan in your local time zone. The dates shown are based on the
						Umm al-Qura calendar used in Saudi Arabia and many Gulf states,
						which calculates the new moon astronomically. The display updates
						every second with the precise days, hours, minutes, and seconds
						remaining.
					</p>
					<p>
						Because the Islamic calendar follows the lunar cycle, Ramadan shifts
						about 11 days earlier each Gregorian year. Once the current
						Ramadan start date has passed, the countdown automatically rolls
						forward to the next listed date — including rare years like 2030,
						when Ramadan occurs twice in the same Gregorian calendar year.
					</p>
				</div>
			</section>

			<section class="ramadan-faq">
				<h2 class="ramadan-section-title">Frequently asked questions</h2>
				<div class="ramadan-faq-list">
					<details class="ramadan-faq-item">
						<summary class="ramadan-faq-question"
							>Why does the date of Ramadan change every year?</summary
						>
						<div class="ramadan-faq-answer">
							<p>
								The Islamic calendar is lunar, with months of 29 or 30 days
								based on the moon's cycle. A lunar year is roughly 354 days —
								about 11 days shorter than the solar Gregorian year — so Ramadan
								moves earlier through the seasons each year. Over roughly 33
								years it completes a full cycle through all seasons.
							</p>
						</div>
					</details>
					<details class="ramadan-faq-item">
						<summary class="ramadan-faq-question"
							>How is the start of Ramadan determined?</summary
						>
						<div class="ramadan-faq-answer">
							<p>
								Ramadan begins when the crescent moon (hilal) marking the start
								of the month is sighted after the new moon of Sha'ban. Many
								countries, including Saudi Arabia and most Gulf states, use
								astronomical calculation (the Umm al-Qura calendar). Others —
								such as Pakistan, parts of India, and Morocco — wait for a
								verified local moon sighting, which can shift the start by a
								day or more between regions.
							</p>
						</div>
					</details>
					<details class="ramadan-faq-item">
						<summary class="ramadan-faq-question"
							>Why might the countdown date differ from my local mosque?</summary
						>
						<div class="ramadan-faq-answer">
							<p>
								Clockr uses Umm al-Qura estimated dates for planning purposes.
								If your community follows local moon sighting, the actual start
								may be one day earlier or later. Always check announcements
								from your local Islamic authority or mosque for the confirmed
								date in your area.
							</p>
						</div>
					</details>
					<details class="ramadan-faq-item">
						<summary class="ramadan-faq-question"
							>Can Ramadan happen twice in one Gregorian year?</summary
						>
						<div class="ramadan-faq-answer">
							<p>
								Yes. Because the Islamic year is shorter than the Gregorian year,
								Ramadan drifts backward through the calendar. Roughly every 33
								years, two Ramadans fall within the same Gregorian year — the
								next occurrence is 2030, when Ramadan is expected to begin in
								early January and again in late December.
							</p>
						</div>
					</details>
				</div>
			</section>

			<div class="ramadan-related">
				<h3 class="ramadan-related-title">Related tools</h3>
				<div class="ramadan-related-grid">
					<a href="/days-until-easter" class="ramadan-related-card"
						><span class="ramadan-related-name">Days Until Easter</span></a
					>
					<a href="/moon-phase-calculator" class="ramadan-related-card"
						><span class="ramadan-related-name">Moon Phase Calculator</span></a
					>
					<a href="/countdown-timer" class="ramadan-related-card"
						><span class="ramadan-related-name">Countdown Timer</span></a
					>
					<a href="/holiday-countdowns" class="ramadan-related-card"
						><span class="ramadan-related-name">Holiday Countdowns</span></a
					>
				</div>
			</div>
		</div>
	</div>
</Layout>

