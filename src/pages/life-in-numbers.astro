---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Your Life in Numbers — Clockr.co"
	description="Enter your date of birth and discover the incredible scale of your life — days, heartbeats, breaths, Christmases, full moons and more."
>
	<div class="lin-page">
		<div class="lin-header">
			<div class="lin-eyebrow">🔢 Life in Numbers</div>
			<h1 class="lin-title">
				<span class="lin-gradient">Your Life</span><br />
				<span class="lin-gradient">in Numbers</span>
			</h1>
			<p class="lin-subtitle">
				Enter your date of birth and discover the incredible scale of your life
			</p>
		</div>

		<div class="lin-input-wrap">
			<label class="lin-label" for="dob-input">Your date of birth</label>
			<input type="date" id="dob-input" class="lin-input" />
		</div>

		<div class="lin-results" id="lin-results" style="display:none">
			<div class="lin-grid">
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-days">0</div>
					<div class="lin-stat-label">Days alive</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-hours">0</div>
					<div class="lin-stat-label">Hours alive</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-minutes">0</div>
					<div class="lin-stat-label">Minutes alive</div>
				</div>
				<div class="lin-stat-card lin-stat-card--highlight">
					<div class="lin-stat-num" id="lin-seconds">0</div>
					<div class="lin-stat-label">Seconds alive</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-weeks">0</div>
					<div class="lin-stat-label">Weeks alive</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-months">0</div>
					<div class="lin-stat-label">Months alive</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-heartbeats">0</div>
					<div class="lin-stat-label">Heartbeats</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-breaths">0</div>
					<div class="lin-stat-label">Breaths taken</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-sleeps">0</div>
					<div class="lin-stat-label">Times slept</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-christmases">0</div>
					<div class="lin-stat-label">Christmases experienced</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-newyears">0</div>
					<div class="lin-stat-label">New Years celebrated</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-mondays">0</div>
					<div class="lin-stat-label">Mondays survived</div>
				</div>
				<div class="lin-stat-card">
					<div class="lin-stat-num" id="lin-moons">0</div>
					<div class="lin-stat-label">Full moons witnessed</div>
				</div>
			</div>

			<button class="lin-share" id="lin-share-btn">📤 Share my numbers</button>
		</div>

		<!-- HOW IT WORKS -->
		<section class="lin-how">
			<h2 class="lin-section-title">How are your life numbers calculated?</h2>
			<div class="lin-how-card">
				<p>
					Every stat on this page is calculated from the exact number of
					milliseconds between your date of birth and the current moment. That
					precise interval is converted into days, hours, minutes, and seconds —
					and because the clock keeps ticking, your numbers update in real time
					every second you keep the page open.
				</p>
				<p>
					Estimates like heartbeats and breaths use widely accepted averages: a
					resting heart rate of 70 beats per minute and a breathing rate of 16
					breaths per minute. Each is multiplied by the total number of minutes
					you have been alive. These are approximations — your actual counts
					will vary with age, fitness, and activity level.
				</p>
				<p>
					Milestone detection works by calculating the exact date and time you
					will hit each landmark — 10,000 days, 1 billion seconds, and others —
					by adding the required amount to your birth date. For example, 1
					billion seconds is roughly 31 years and 8 months after you were born,
					and Clockr can pinpoint the precise day and time that milestone
					arrives.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="lin-faq">
			<h2 class="lin-section-title">Frequently asked questions</h2>
			<div class="lin-faq-list">
				<details class="lin-faq-item">
					<summary class="lin-faq-question">How many days old am I?</summary>
					<div class="lin-faq-answer">
						<p>
							Enter your date of birth above and the "Days alive" figure shows
							your exact total, updating every second. A day is counted as each
							full 24-hour period since midnight on your birth date. For
							example, if you were born on 1 January 2000, you passed 9,000 days
							around mid-2024.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>How many seconds are in a year?</summary
					>
					<div class="lin-faq-answer">
						<p>
							A common year has 31,536,000 seconds (365 × 24 × 60 × 60). A leap
							year has 31,622,400 seconds — an extra 86,400 for 29 February.
							Over a lifetime these numbers add up fast: 1 billion seconds is
							roughly 31 years and 8 months, a milestone many people reach in
							their early thirties.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>How many heartbeats does a person have in a lifetime?</summary
					>
					<div class="lin-faq-answer">
						<p>
							At an average resting rate of 70 beats per minute, a person who
							lives to 80 accumulates roughly 2.9 billion heartbeats. Your
							actual count depends on fitness, stress, and age — athletes often
							have lower resting rates, meaning fewer beats over a lifetime but
							a healthier heart. Enter your date of birth above to see your
							current total.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>What is the 10000 day milestone?</summary
					>
					<div class="lin-faq-answer">
						<p>
							10,000 days alive is a popular life milestone — equivalent to about
							27 years and 4 months. It works out to roughly 1.4 million hours
							or 86 million minutes on Earth. Many people celebrate their 10,000th
							day with more enthusiasm than a typical birthday, since it falls on
							a different calendar date each time.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>When will I turn 1 billion seconds old?</summary
					>
					<div class="lin-faq-answer">
						<p>
							One billion seconds equals about 31 years, 251 days, 13 hours, and
							20 minutes after your birth. If you were born in the early 1990s,
							you have likely already passed this milestone. Add 1,000,000,000
							seconds to your birth date to find the exact moment — or check the
							Age Calculator for your next upcoming milestone.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>How many times does the average person breathe in a lifetime?</summary
					>
					<div class="lin-faq-answer">
						<p>
							At 16 breaths per minute, a person alive for 80 years takes
							roughly 672 million breaths. Breathing rate varies with activity —
							you breathe faster during exercise and slower during sleep — so
							this is an estimate based on a lifetime average. Your live count
							appears in the results above.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>How many full moons will I see in my lifetime?</summary
					>
					<div class="lin-faq-answer">
						<p>
							The moon completes a full cycle roughly every 29.53 days. Over 80
							years that works out to about 990 full moons — nearly a thousand
							lunar cycles. Clockr estimates your count by dividing your total
							days alive by the synodic month length of 29.53059 days.
						</p>
					</div>
				</details>
				<details class="lin-faq-item">
					<summary class="lin-faq-question"
						>What is the average human lifespan in days?</summary
					>
					<div class="lin-faq-answer">
						<p>
							Global life expectancy is roughly 73 years, or about 26,645 days.
							In high-income countries the average exceeds 80 years — around
							29,200 days. These are statistical averages; individual lifespans
							vary enormously based on genetics, health, and circumstances.
						</p>
					</div>
				</details>
			</div>
		</section>

		<div class="lin-related">
			<h3 class="lin-related-title">You might also like</h3>
			<div class="lin-related-grid">
				<a href="/age-calculator" class="lin-related-card"
					><span class="lin-related-name">Age Calculator</span></a
				>
				<a href="/age-on-other-planets" class="lin-related-card"
					><span class="lin-related-name">Age on Other Planets</span></a
				>
				<a href="/what-generation" class="lin-related-card"
					><span class="lin-related-name">What Generation Am I?</span></a
				>
				<a href="/days-until-birthday" class="lin-related-card"
					><span class="lin-related-name">Days Until My Birthday</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.lin-page {
		max-width: 900px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.lin-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.lin-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.lin-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.lin-gradient {
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.lin-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.lin-input-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		margin-bottom: 48px;
	}

	.lin-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 0.5px;
	}

	.lin-input {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.3);
		border-radius: 12px;
		padding: 16px 24px;
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #ffffff;
		text-align: center;
		outline: none;
		cursor: pointer;
		transition: border-color 0.2s ease;
	}

	.lin-input:focus {
		border-color: rgba(168, 85, 247, 0.8);
		box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);
	}

	.lin-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		margin-bottom: 24px;
	}

	.lin-stat-card {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: 14px;
		padding: 28px 16px;
		text-align: center;
		transition: border-color 0.2s ease;
	}

	.lin-stat-card:hover {
		border-color: rgba(168, 85, 247, 0.35);
	}

	.lin-stat-card--highlight {
		border-color: rgba(255, 92, 77, 0.25);
		box-shadow: 0 0 30px rgba(168, 85, 247, 0.08);
	}

	.lin-stat-num {
		font-family: 'Outfit', sans-serif;
		font-size: 36px;
		font-weight: 900;
		letter-spacing: -1px;
		line-height: 1.1;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 8px;
		word-break: break-word;
	}

	.lin-stat-card--highlight .lin-stat-num {
		font-size: 42px;
	}

	.lin-stat-label {
		font-family: 'Inter', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
	}

	.lin-share {
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 16px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		width: 100%;
		margin-bottom: 60px;
		transition: opacity 0.2s ease;
	}

	.lin-share:hover {
		opacity: 0.9;
	}

	.lin-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.lin-how {
		margin-bottom: 48px;
	}

	.lin-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.lin-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0 0 16px;
	}

	.lin-how-card p:last-child {
		margin-bottom: 0;
	}

	.lin-faq {
		margin-bottom: 48px;
	}

	.lin-faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.lin-faq-item {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: 14px;
		overflow: hidden;
	}

	.lin-faq-question {
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 600;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.lin-faq-question::-webkit-details-marker {
		display: none;
	}

	.lin-faq-question::after {
		content: '+';
		float: right;
		font-size: 18px;
		font-weight: 700;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.lin-faq-item[open] .lin-faq-question::after {
		content: '−';
	}

	.lin-faq-answer {
		padding: 0 24px 18px;
	}

	.lin-faq-answer p {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.lin-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.lin-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.lin-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.lin-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.lin-related-card:hover {
		border-color: rgba(168, 85, 247, 0.4);
	}

	.lin-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	@media (max-width: 640px) {
		.lin-title {
			font-size: 44px;
			letter-spacing: -2px;
		}

		.lin-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.lin-stat-num {
			font-size: 28px;
		}

		.lin-stat-card--highlight .lin-stat-num {
			font-size: 32px;
		}

		.lin-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const dobInput = document.getElementById('dob-input') as HTMLInputElement;
		const results = document.getElementById('lin-results');

		const SYNODIC_MONTH = 29.53059;
		const HEARTBEAT_BPM = 70;
		const BREATHS_PER_MIN = 16;

		function formatNumber(n: number) {
			return n.toLocaleString();
		}

		function calendarMonthsBetween(dob: Date, now: Date) {
			let months =
				(now.getFullYear() - dob.getFullYear()) * 12 +
				(now.getMonth() - dob.getMonth());
			if (now.getDate() < dob.getDate()) months--;
			return Math.max(0, months);
		}

		function countOccurrences(
			dob: Date,
			now: Date,
			month: number,
			day: number,
		) {
			let count = 0;
			for (let y = dob.getFullYear(); y <= now.getFullYear(); y++) {
				const date = new Date(y, month, day);
				if (date >= dob && date <= now) count++;
			}
			return count;
		}

		function countMondays(dob: Date, now: Date) {
			const start = new Date(dob);
			start.setHours(0, 0, 0, 0);
			const end = new Date(now);
			end.setHours(0, 0, 0, 0);

			let count = 0;
			const cursor = new Date(start);
			while (cursor <= end) {
				if (cursor.getDay() === 1) count++;
				cursor.setDate(cursor.getDate() + 1);
			}
			return count;
		}

		function setText(id: string, value: string) {
			const el = document.getElementById(id);
			if (el) el.textContent = value;
		}

		function calculate() {
			if (!dobInput || !results) return;

			if (!dobInput.value) {
				results.style.display = 'none';
				return;
			}

			const dob = new Date(dobInput.value + 'T00:00:00');
			if (isNaN(dob.getTime())) {
				results.style.display = 'none';
				return;
			}

			const now = new Date();
			const diff = now.getTime() - dob.getTime();
			if (diff < 0) {
				results.style.display = 'none';
				return;
			}

			results.style.display = 'block';

			const totalSeconds = Math.floor(diff / 1000);
			const totalMinutes = Math.floor(totalSeconds / 60);
			const totalHours = Math.floor(totalMinutes / 60);
			const totalDays = Math.floor(totalHours / 24);
			const totalWeeks = Math.floor(totalDays / 7);

			const heartbeats = Math.floor((totalMinutes * HEARTBEAT_BPM) | 0);
			const breaths = Math.floor(totalMinutes * BREATHS_PER_MIN);
			const nightsSlept = totalDays;
			const christmases = countOccurrences(dob, now, 11, 25);
			const newYears = countOccurrences(dob, now, 0, 1);
			const mondays = countMondays(dob, now);
			const fullMoons = Math.floor(totalDays / SYNODIC_MONTH);

			setText('lin-days', formatNumber(totalDays));
			setText('lin-hours', formatNumber(totalHours));
			setText('lin-minutes', formatNumber(totalMinutes));
			setText('lin-seconds', formatNumber(totalSeconds));
			setText('lin-weeks', formatNumber(totalWeeks));
			setText('lin-months', formatNumber(calendarMonthsBetween(dob, now)));
			setText('lin-heartbeats', formatNumber(heartbeats));
			setText('lin-breaths', formatNumber(breaths));
			setText('lin-sleeps', formatNumber(nightsSlept));
			setText('lin-christmases', formatNumber(christmases));
			setText('lin-newyears', formatNumber(newYears));
			setText('lin-mondays', formatNumber(mondays));
			setText('lin-moons', formatNumber(fullMoons));

			const shareBtn = document.getElementById('lin-share-btn');
			if (shareBtn) {
				shareBtn.onclick = () => {
					navigator.clipboard.writeText(
						`I've been alive for ${formatNumber(totalDays)} days, taken ${formatNumber(breaths)} breaths, and survived ${formatNumber(mondays)} Mondays. Discover your life in numbers at Clockr.co 🔢`,
					);
					shareBtn.textContent = '✅ Copied to clipboard!';
					setTimeout(() => {
						shareBtn.textContent = '📤 Share my numbers';
					}, 2000);
				};
			}
		}

		if (dobInput) {
			dobInput.addEventListener('input', calculate);
			dobInput.addEventListener('change', calculate);
		}

		setInterval(() => {
			if (dobInput?.value) calculate();
		}, 1000);
	});
</script>
