import AnalogueClock from '../components/AnalogueClock.astro';
import { categories } from '../data/categories';
import type { CategoryId } from '../data/categories';

const categoryHrefs: Record<CategoryId, string> = {
	holidays: '/days-until-christmas',
	birthdays: '/age-calculator',
	timezones: '/world-clock',
	history: '/world-clock',
	milestones: '/life-in-numbers',
	work: '/business-days',
	seasons: '/year-progress',
	religious: '/days-until-easter',
};

const categoryFloatEmojis: Record<CategoryId, string[]> = {
	holidays: ['🎄', '🎅', '⭐', '🎁'],
	birthdays: ['🎂', '🎈', '🎉', '🎁'],
	timezones: ['🌍', '🕐', '✈️', '🗺️'],
	history: ['📜', '📅', '🏛️', '⏳'],
	milestones: ['⚡', '🎯', '💫', '🏆'],
	work: ['💼', '📊', '📆', '✅'],
	seasons: ['🍂', '🌸', '☀️', '❄️'],
	religious: ['🕌', '🕯️', '🙏', '✨'],
};

const searchTools = [
	{ name: 'Age Calculator', description: 'How old are you, exactly?', href: '/age-calculator', keywords: ['how old am i', 'age', 'birthday', 'born'], emoji: '🎂', from: '#8B5CF6', to: '#EC4899' },
	{ name: 'Date Calculator', description: 'Days between any two dates', href: '/date-calculator', keywords: ['days between dates', 'date difference'], emoji: '📅', from: '#10B981', to: '#84CC16' },
	{ name: 'Week Number Calculator', description: 'Find the ISO week number for any date', href: '/week-number-calculator', keywords: ['week number', 'iso week', 'what week is it', 'week of year'], emoji: '📆', from: '#10B981', to: '#84CC16' },
	{ name: 'Quarter Calculator', description: 'Find which quarter any date falls in', href: '/quarter-calculator', keywords: ['quarter', 'fiscal quarter', 'what quarter is it', 'calendar quarter', 'uk tax year'], emoji: '📊', from: '#10B981', to: '#84CC16' },
	{ name: 'Random Date Generator', description: 'Generate random dates within any range', href: '/random-date-generator', keywords: ['random date', 'random date generator', 'pick a date', 'random birthday'], emoji: '🎲', from: '#10B981', to: '#84CC16' },
	{ name: 'World Clock', description: 'Current time in 250+ cities', href: '/world-clock', keywords: ['time in city', 'world clock', 'current time'], emoji: '🌍', from: '#00E5C4', to: '#0099FF' },
	{ name: 'Countdown Timer', description: 'Set a timer for anything', href: '/countdown-timer', keywords: ['timer', 'countdown', 'alarm'], emoji: '⏱️', from: '#FF5C4D', to: '#FF9A3C' },
	{ name: 'Stopwatch', description: 'Track elapsed time with laps', href: '/stopwatch', keywords: ['stopwatch', 'lap timer', 'elapsed time'], emoji: '⏱️', from: '#FF5C4D', to: '#FF9A3C' },
	{ name: 'Time Zone Converter', description: 'Convert time between zones', href: '/timezone-converter', keywords: ['time zone', 'convert time', 'utc'], emoji: '🌐', from: '#00E5C4', to: '#0099FF' },
	{ name: 'Time Zone Meeting Planner', description: 'Find the best time to meet', href: '/time-zone-meeting-planner', keywords: ['meeting planner', 'schedule meeting', 'time zones'], emoji: '📅', from: '#00E5C4', to: '#0099FF' },
	{ name: 'UTC/GMT Converter', description: 'Convert to or from UTC/GMT', href: '/utc-gmt-converter', keywords: ['utc', 'gmt', 'utc converter', 'greenwich', 'zulu time'], emoji: '🕐', from: '#00E5C4', to: '#0099FF' },
	{ name: 'Year Progress', description: 'How much of the year is left?', href: '/year-progress', keywords: ['year progress', 'days left in year', '2026'], emoji: '📊', from: '#2D6A4F', to: '#74B49B' },
	{ name: 'Sleep Calculator', description: 'Find your ideal bedtime', href: '/sleep-calculator', keywords: ['sleep', 'bedtime', 'wake up', 'sleep cycles'], emoji: '😴', from: '#6366F1', to: '#8B5CF6' },
	{ name: 'Days Until Christmas', description: 'Countdown to 25 December', href: '/days-until-christmas', keywords: ['christmas countdown', 'days until christmas'], emoji: '🎄', from: '#FF5C4D', to: '#FF9A3C' },
	{ name: 'Days Until New Year', description: 'Countdown to 1 January', href: '/days-until-new-year', keywords: ['new year countdown', 'days until new year'], emoji: '🎆', from: '#C0C0C0', to: '#FFD700' },
	{ name: 'Days Until Halloween', description: 'Countdown to 31 October', href: '/days-until-halloween', keywords: ['halloween countdown', 'days until halloween'], emoji: '🎃', from: '#FF6B00', to: '#7B2FBE' },
	{ name: "Days Until Valentine's Day", description: 'Countdown to 14 February', href: '/days-until-valentines', keywords: ['valentines day', 'february 14'], emoji: '💝', from: '#FF1493', to: '#FF6B9D' },
	{ name: 'Days Until Easter', description: 'Countdown to Easter Sunday', href: '/days-until-easter', keywords: ['easter countdown', 'days until easter'], emoji: '🐣', from: '#A8D8B9', to: '#F9E79F' },
	{ name: 'Unix Timestamp', description: 'Convert epoch time instantly', href: '/unix-timestamp', keywords: ['unix timestamp', 'epoch time', 'developer'], emoji: '💻', from: '#00E5C4', to: '#0099FF' },
	{ name: 'Business Days Calculator', description: 'Working days between dates', href: '/business-days', keywords: ['working days', 'business days', 'weekdays'], emoji: '💼', from: '#10B981', to: '#84CC16' },
	{ name: 'Your Life in Numbers', description: 'Days, hours and seconds alive', href: '/life-in-numbers', keywords: ['life in numbers', 'days alive', 'seconds alive'], emoji: '⚡', from: '#A855F7', to: '#FF5C4D' },
	{ name: 'What Generation Am I', description: 'Boomer, Millennial or Gen Z?', href: '/what-generation', keywords: ['generation', 'millennial', 'gen z', 'boomer'], emoji: '🧬', from: '#8B5CF6', to: '#EC4899' },
	{ name: 'Age on Other Planets', description: 'How old are you on Mars?', href: '/age-on-other-planets', keywords: ['age on planets', 'mercury', 'mars age'], emoji: '🪐', from: '#8B5CF6', to: '#FF5C4D' },
	{ name: 'Days Until Birthday', description: 'Countdown to your next birthday', href: '/days-until-birthday', keywords: ['birthday countdown', 'days until birthday'], emoji: '🎂', from: '#8B5CF6', to: '#EC4899' },
	{ name: 'Time Difference Calculator', description: 'Time between two cities', href: '/time-difference', keywords: ['time difference', 'time between cities'], emoji: '🕐', from: '#00E5C4', to: '#0099FF' },
	{ name: 'Leap Year Checker', description: 'Is this year a leap year?', href: '/leap-year', keywords: ['leap year', 'is this a leap year'], emoji: '📆', from: '#2D6A4F', to: '#74B49B' },
];

function daysUntilChristmas(now = new Date()): number {
	let year = now.getFullYear();
	if (now.getMonth() === 11 && now.getDate() > 25) year++;
	const christmas = new Date(year, 11, 25);
	return Math.max(0, Math.ceil((christmas.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
}

const featuredTools = [
	{ emoji: '🎂', name: 'Age Calculator', description: 'How old are you, exactly?', href: '/age-calculator', from: '#8B5CF6', to: '#EC4899' },
	{ emoji: '🌍', name: 'World Clock', description: 'Current time in 250+ cities', href: '/world-clock', from: '#00E5C4', to: '#0099FF' },
	{ emoji: '⏱️', name: 'Countdown Timer', description: 'Set a timer for anything', href: '/countdown-timer', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '🎄', name: 'Days Until Christmas', description: `${daysUntilChristmas()} days and counting`, href: '/days-until-christmas', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '📅', name: 'Date Calculator', description: 'Days between any two dates', href: '/date-calculator', from: '#10B981', to: '#84CC16' },
	{ emoji: '🪐', name: 'Age on Other Planets', description: 'How old are you on Mars?', href: '/age-on-other-planets', from: '#8B5CF6', to: '#FF5C4D' },
