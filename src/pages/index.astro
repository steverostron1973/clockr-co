	'🔍 Try: Days until Christmas 2026',
	'🔍 Try: What time is it in Tokyo right now?',
	'🔍 Try: Am I a Millennial or Gen Z?',
	'🔍 Try: How many days until my birthday?',
	'🔍 Try: Is 2028 a leap year?',
	'🔍 Try: How old would I be on Mars?',
	'🔍 Try: How many working days left this month?',
	'🔍 Try: What time is it in New York?',
	'🔍 Try: How long until New Year?',
];

const allTools = [
	{ emoji: '🎂', name: 'Age Calculator', href: '/age-calculator', from: '#8B5CF6', to: '#EC4899' },
	{ emoji: '📅', name: 'Date Calculator', href: '/date-calculator', from: '#10B981', to: '#84CC16' },
	{ emoji: '📆', name: 'Week Number Calculator', href: '/week-number-calculator', from: '#10B981', to: '#84CC16' },
	{ emoji: '📊', name: 'Quarter Calculator', href: '/quarter-calculator', from: '#10B981', to: '#84CC16' },
	{ emoji: '🎲', name: 'Random Date Generator', href: '/random-date-generator', from: '#10B981', to: '#84CC16' },
	{ emoji: '🌍', name: 'World Clock', href: '/world-clock', from: '#00E5C4', to: '#0099FF' },
	{ emoji: '⏱️', name: 'Countdown Timer', href: '/countdown-timer', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '⏱️', name: 'Stopwatch', href: '/stopwatch', from: '#8B5CF6', to: '#EC4899' },
	{ emoji: '🌐', name: 'Time Zone Converter', href: '/timezone-converter', from: '#00E5C4', to: '#0099FF' },
	{ emoji: '📅', name: 'Time Zone Meeting Planner', href: '/time-zone-meeting-planner', from: '#00E5C4', to: '#0099FF' },
	{ emoji: '🕐', name: 'UTC/GMT Converter', href: '/utc-gmt-converter', from: '#00E5C4', to: '#0099FF' },
	{ emoji: '📊', name: 'Year Progress', href: '/year-progress', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '😴', name: 'Sleep Calculator', href: '/sleep-calculator', from: '#8B5CF6', to: '#EC4899' },
	{ emoji: '🎄', name: 'Days Until Christmas', href: '/days-until-christmas', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '🎆', name: 'Days Until New Year', href: '/days-until-new-year', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '🎃', name: 'Days Until Halloween', href: '/days-until-halloween', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '💝', name: "Days Until Valentine's Day", href: '/days-until-valentines', from: '#FF5C4D', to: '#FF9A3C' },
	{ emoji: '🐣', name: 'Days Until Easter', href: '/days-until-easter', from: '#10B981', to: '#84CC16' },
	{ emoji: '⚡', name: 'Unix Timestamp', href: '/unix-timestamp', from: '#10B981', to: '#84CC16' },
	{ emoji: '💼', name: 'Business Days Calculator', href: '/business-days', from: '#10B981', to: '#84CC16' },
	{ emoji: '🔢', name: 'Your Life in Numbers', href: '/life-in-numbers', from: '#8B5CF6', to: '#FF5C4D' },
