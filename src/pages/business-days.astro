</style>

<script>
	import publicHolidaysData from '../data/publicHolidays.json';

	type CountryCode = keyof typeof publicHolidaysData;

	const MONTH_NAMES = [
		'January',
		'February',
		'March',
		'April',
		'May',
		'June',
		'July',
		'August',
		'September',
		'October',
		'November',
		'December',
	];

	const MONTH_SHORT = [
		'Jan',
		'Feb',
		'Mar',
		'Apr',
		'May',
		'Jun',
		'Jul',
		'Aug',
		'Sep',
		'Oct',
		'Nov',
		'Dec',
	];

	function parseDateInput(value: string): Date | null {
		if (!value) return null;
		const [y, m, d] = value.split('-').map(Number);
		const date = new Date(y, m - 1, d);
		return isNaN(date.getTime()) ? null : date;
	}

	function isWeekend(date: Date): boolean {
		const day = date.getDay();
		return day === 0 || day === 6;
	}

	function buildHolidaySet(country: CountryCode): Set<string> {
		const set = new Set<string>();
		const countryData = publicHolidaysData[country];
		if (!countryData) return set;

		for (const yearHolidays of Object.values(countryData.holidays)) {
			for (const holiday of yearHolidays) {
				set.add(holiday.date);
			}
		}
		return set;
	}

	function isPublicHoliday(date: Date, holidaySet: Set<string>): boolean {
		return holidaySet.has(formatDateInput(date));
	}

	function isBusinessDay(
		date: Date,
		holidaySet: Set<string>,
		excludeHolidays: boolean,
	): boolean {
		if (isWeekend(date)) return false;
		if (excludeHolidays && isPublicHoliday(date, holidaySet)) return false;
		return true;
	}

	function formatDateInput(date: Date): string {
		const y = date.getFullYear();
		const m = String(date.getMonth() + 1).padStart(2, '0');
		const d = String(date.getDate()).padStart(2, '0');
		return `${y}-${m}-${d}`;
	}

	function countBetween(
		start: Date,
		end: Date,
		holidaySet: Set<string>,
		excludeHolidays: boolean,
	) {
		let s = new Date(start);
		let e = new Date(end);
		s.setHours(0, 0, 0, 0);
		e.setHours(0, 0, 0, 0);

		if (s > e) [s, e] = [e, s];

		let businessDays = 0;
		let weekends = 0;
		let holidays = 0;
		const monthly: Record<string, number> = {};
		const current = new Date(s);

		while (current <= e) {
			const key = `${current.getFullYear()}-${current.getMonth()}`;
			if (isWeekend(current)) {
				weekends++;
			} else if (
				excludeHolidays &&
				holidaySet.size > 0 &&
				isPublicHoliday(current, holidaySet)
			) {
				holidays++;
			} else {
				businessDays++;
				monthly[key] = (monthly[key] ?? 0) + 1;
			}
			current.setDate(current.getDate() + 1);
		}

		const calendarDays =
			Math.round((e.getTime() - s.getTime()) / (24 * 60 * 60 * 1000)) + 1;

		return {
			businessDays,
			calendarDays,
			weekends,
			holidays,
			monthly,
			start: s,
			end: e,
		};
	}

	function countBusinessDaysInMonth(
		year: number,
		month: number,
		holidaySet: Set<string>,
		excludeHolidays: boolean,
	): number {
		const start = new Date(year, month, 1);
		const end = new Date(year, month + 1, 0);
		let count = 0;
		const current = new Date(start);
		while (current <= end) {
			if (isBusinessDay(current, holidaySet, excludeHolidays)) count++;
			current.setDate(current.getDate() + 1);
		}
		return count;
	}

	function addBusinessDays(
		start: Date,
		days: number,
		subtract: boolean,
		holidaySet: Set<string>,
		excludeHolidays: boolean,
	): { result: Date; calendarDays: number } {
		const d = new Date(start);
		d.setHours(0, 0, 0, 0);
		const direction = subtract ? -1 : 1;
		let remaining = days;
		let calendarDays = 0;

		while (remaining > 0) {
			d.setDate(d.getDate() + direction);
			calendarDays++;
			if (isBusinessDay(d, holidaySet, excludeHolidays)) remaining--;
		}

		return { result: d, calendarDays };
	}

	function formatBusinessDayDetail(
		excludeHolidays: boolean,
		holidays: number,
	): string {
		if (!excludeHolidays || holidays === 0) {
			return 'business days (excluding weekends)';
		}
		const holidayLabel =
			holidays === 1 ? 'public holiday' : 'public holidays';
		return `business days (excluding weekends and ${formatNumber(holidays)} ${holidayLabel})`;
	}

	function getHolidaySettings(): {
		country: CountryCode;
		excludeHolidays: boolean;
		holidaySet: Set<string>;
	} {
		const countrySelect = document.getElementById(
			'country-select',
		) as HTMLSelectElement;
		const excludeToggle = document.getElementById(
			'exclude-holidays-toggle',
		) as HTMLInputElement;
		const country = (countrySelect?.value ?? 'UK') as CountryCode;
		const excludeHolidays = excludeToggle?.checked ?? true;
		const holidaySet = buildHolidaySet(country);
		return { country, excludeHolidays, holidaySet };
	}

	function formatNumber(n: number): string {
		return n.toLocaleString();
	}

	// Tabs
	const tabBetween = document.getElementById('tab-between');
	const tabAdd = document.getElementById('tab-add');
	const panelBetween = document.getElementById('panel-between');
	const panelAdd = document.getElementById('panel-add');

	function setMode(mode: 'between' | 'add') {
		tabBetween?.classList.toggle('bd-tab--active', mode === 'between');
		tabAdd?.classList.toggle('bd-tab--active', mode === 'add');
		tabBetween?.setAttribute('aria-selected', String(mode === 'between'));
		tabAdd?.setAttribute('aria-selected', String(mode === 'add'));
		if (panelBetween)
			panelBetween.style.display = mode === 'between' ? 'block' : 'none';
		if (panelAdd) panelAdd.style.display = mode === 'add' ? 'block' : 'none';
	}

	tabBetween?.addEventListener('click', () => setMode('between'));
	tabAdd?.addEventListener('click', () => setMode('add'));

	// Tab A: Days Between Dates
	const startInput = document.getElementById('start-date') as HTMLInputElement;
	const endInput = document.getElementById('end-date') as HTMLInputElement;
	const betweenResults = document.getElementById('between-results');

	function calculateBetween() {
		if (!startInput || !endInput || !betweenResults) return;

		const start = parseDateInput(startInput.value);
		const end = parseDateInput(endInput.value);
		if (!start || !end) {
			betweenResults.style.display = 'none';
			return;
		}

		betweenResults.style.display = 'block';

		const { excludeHolidays, holidaySet } = getHolidaySettings();
		const result = countBetween(start, end, holidaySet, excludeHolidays);

		const businessEl = document.getElementById('between-business');
		const summaryEl = document.getElementById('between-summary');
		const calendarEl = document.getElementById('between-calendar');
		const weekendsEl = document.getElementById('between-weekends');
		const holidaysEl = document.getElementById('between-holidays');
		const holidaysCard = document.getElementById('between-holidays-card');
		const breakdownEl = document.getElementById('month-breakdown');

		if (businessEl)
			businessEl.textContent = formatNumber(result.businessDays);
		if (summaryEl) {
			summaryEl.textContent = formatBusinessDayDetail(
				excludeHolidays,
				result.holidays,
			);
		}
		if (calendarEl)
			calendarEl.textContent = formatNumber(result.calendarDays);
		if (weekendsEl) weekendsEl.textContent = formatNumber(result.weekends);
		if (holidaysEl)
			holidaysEl.textContent = formatNumber(result.holidays);
		if (holidaysCard) {
			holidaysCard.style.display = excludeHolidays ? 'block' : 'none';
		}

		if (breakdownEl) {
			const keys = Object.keys(result.monthly).sort((a, b) => {
				const [ay, am] = a.split('-').map(Number);
				const [by, bm] = b.split('-').map(Number);
				return ay !== by ? ay - by : am - bm;
			});

			if (keys.length === 0) {
				breakdownEl.innerHTML =
					'<p class="bd-breakdown-month" style="text-align:center">No business days in range</p>';
			} else {
				breakdownEl.innerHTML = keys
					.map((key) => {
						const [year, month] = key.split('-').map(Number);
						const count = result.monthly[key];
						const label =
							keys.length > 1 && new Set(keys.map((k) => k.split('-')[0])).size > 1
								? `${MONTH_NAMES[month]} ${year}`
								: MONTH_NAMES[month];
						return `<div class="bd-breakdown-row">
							<span class="bd-breakdown-month">${label}</span>
							<span class="bd-breakdown-count">${formatNumber(count)} day${count !== 1 ? 's' : ''}</span>
						</div>`;
					})
					.join('');
			}
		}
	}

	// Tab B: Add Business Days
	const addStartInput = document.getElementById(
		'add-start-date',
	) as HTMLInputElement;
	const addDaysInput = document.getElementById('add-days') as HTMLInputElement;
	const subtractToggle = document.getElementById(
		'subtract-toggle',
	) as HTMLInputElement;
	const addResults = document.getElementById('add-results');

	function calculateAdd() {
		if (!addStartInput || !addDaysInput || !addResults) return;

		const start = parseDateInput(addStartInput.value);
		const days = parseInt(addDaysInput.value, 10);
		const subtract = subtractToggle?.checked ?? false;

		if (!start || !days || days < 1) {
			addResults.style.display = 'none';
			return;
		}

		addResults.style.display = 'block';

		const { excludeHolidays, holidaySet } = getHolidaySettings();
		const { result, calendarDays } = addBusinessDays(
			start,
			days,
			subtract,
			holidaySet,
			excludeHolidays,
		);

		const dateEl = document.getElementById('add-result-date');
		const dowEl = document.getElementById('add-result-dow');
		const calendarEl = document.getElementById('add-calendar');
		const directionEl = document.getElementById('add-direction');
		const directionLabelEl = document.getElementById('add-direction-label');

		if (dateEl) {
			dateEl.textContent = result.toLocaleDateString('en-GB', {
				day: 'numeric',
				month: 'long',
				year: 'numeric',
			});
		}
		if (dowEl) dowEl.textContent = result.toLocaleDateString('en-GB', { weekday: 'long' });
		if (calendarEl) calendarEl.textContent = formatNumber(calendarDays);
		if (directionEl) {
			directionEl.textContent = `${subtract ? '−' : '+'}${formatNumber(days)}`;
		}
		if (directionLabelEl) {
			directionLabelEl.textContent = subtract
				? 'Business days subtracted'
				: 'Business days added';
		}
	}

	// Year reference grid
	function renderYearReference() {
		const grid = document.getElementById('year-reference');
		if (!grid) return;

		const { excludeHolidays, holidaySet } = getHolidaySettings();
		const year = new Date().getFullYear();
		grid.innerHTML = MONTH_SHORT.map((name, i) => {
			const count = countBusinessDaysInMonth(
				year,
				i,
				holidaySet,
				excludeHolidays,
			);
			return `<div class="bd-ref-card">
				<div class="bd-ref-month" style="color: var(--cat-from)">${name}</div>
				<div class="bd-ref-count">${count}</div>
			</div>`;
		}).join('');
	}

	function recalculateAll() {
		calculateBetween();
		calculateAdd();
		renderYearReference();
	}

	// Default values
	const today = new Date();
	today.setHours(0, 0, 0, 0);
	const nextMonth = new Date(today);
	nextMonth.setMonth(nextMonth.getMonth() + 1);

	if (startInput) startInput.value = formatDateInput(today);
	if (endInput) endInput.value = formatDateInput(nextMonth);
	if (addStartInput) addStartInput.value = formatDateInput(today);

	startInput?.addEventListener('input', calculateBetween);
	endInput?.addEventListener('input', calculateBetween);
	addStartInput?.addEventListener('input', calculateAdd);
	addDaysInput?.addEventListener('input', calculateAdd);
	subtractToggle?.addEventListener('change', calculateAdd);

	const countrySelect = document.getElementById('country-select');
	const excludeHolidaysToggle = document.getElementById(
		'exclude-holidays-toggle',
	);
	countrySelect?.addEventListener('change', recalculateAll);
	excludeHolidaysToggle?.addEventListener('change', recalculateAll);

	renderYearReference();
	calculateBetween();
	calculateAdd();
</script>
