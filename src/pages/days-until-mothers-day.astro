<script>
	const shareBtn = document.getElementById('md-share-btn');
	shareBtn?.addEventListener('click', () => {
		const days = shareBtn.dataset.days ?? '0';
		const region = shareBtn.dataset.region ?? 'UK';
		const year = shareBtn.dataset.year ?? '';
		const label = region === 'UK' ? 'Mothering Sunday' : "Mother's Day";
		navigator.clipboard.writeText(
			`💐 ${label} is ${days} days away! Count down to ${year} at clockr.co/days-until-mothers-day`,
		);
		shareBtn.textContent = '✓ Copied!';
		setTimeout(() => {
			shareBtn.textContent = '📋 Copy & Share';
		}, 2000);
	});
</script>
