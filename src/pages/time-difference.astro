	}

	.td-swap:hover {
		border-color: rgba(0, 229, 196, 0.6);
		background: rgba(0, 229, 196, 0.12);
	}

	.td-diff-card {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.2);
		border-radius: 20px;
		padding: 32px 40px;
		text-align: center;
		margin-bottom: 16px;
