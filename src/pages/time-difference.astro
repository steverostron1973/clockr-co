		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
		margin-bottom: 16px;
	}

	.td-time-card {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.15);
		border-radius: 14px;
		padding: 24px 16px;
		text-align: center;
	}

	.td-time-city {
		font-family: 'Outfit', sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.4);
		margin-bottom: 10px;
	}

	.td-time-clock {
		font-family: 'Outfit', sans-serif;
		font-size: 36px;
		font-weight: 900;
		letter-spacing: -1px;
		line-height: 1;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
		margin-bottom: 8px;
	}

	.td-time-date {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.45);
	}

	.td-date-relation {
		background: rgba(0, 229, 196, 0.04);
		border: 1px solid rgba(0, 229, 196, 0.15);
		border-radius: 14px;
		padding: 16px 24px;
		text-align: center;
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.65);
		margin-bottom: 48px;
	}

	.td-timeline-section {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.2);
		border-radius: 20px;
		padding: 32px;
		margin-bottom: 48px;
		box-shadow: 0 0 40px rgba(0, 229, 196, 0.06);
	}

	.td-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 8px;
	}

	.td-section-sub {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.4);
		margin-bottom: 28px;
	}

	.td-timeline-wrap {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.td-timeline-row {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 12px;
		align-items: center;
	}

	.td-timeline-label {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.55);
		text-align: right;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.td-timeline-bar {
		display: grid;
		grid-template-columns: repeat(24, 1fr);
		gap: 2px;
		height: 28px;
		position: relative;
	}

	.td-hour-seg {
		border-radius: 3px;
		background: rgba(255, 255, 255, 0.06);
		position: relative;
	}

	.td-hour-seg.working {
		background: rgba(255, 255, 255, 0.12);
	}

	.td-hour-seg.overlap {
		background: linear-gradient(135deg, rgba(0, 229, 196, 0.55), rgba(0, 153, 255, 0.55));
		box-shadow: 0 0 8px rgba(0, 229, 196, 0.25);
	}

	.td-hour-seg.now {
		outline: 2px solid #00e5c4;
		outline-offset: -1px;
		z-index: 1;
	}

	.td-overlap-band {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 12px;
		align-items: center;
		min-height: 24px;
	}

	.td-overlap-band .td-overlap-text {
		grid-column: 2;
		font-family: 'Outfit', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-align: center;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.td-overlap-band.visible .td-overlap-text {
		opacity: 1;
	}

	.td-timeline-axis {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 12px;
		margin-top: 4px;
	}

	.td-timeline-axis span {
		grid-column: 2;
		display: flex;
		justify-content: space-between;
		font-family: 'Inter', sans-serif;
		font-size: 10px;
		color: rgba(255, 255, 255, 0.25);
	}

	.td-timeline-note {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.5);
		margin-top: 20px;
		line-height: 1.5;
		text-align: center;
	}

	.td-presets {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
		margin-bottom: 40px;
	}

	.td-presets-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.td-presets-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.td-preset-btn {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.td-preset-btn:hover {
		border-color: rgba(0, 229, 196, 0.4);
		color: #fff;
	}

	.td-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.td-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.td-related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.td-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.td-related-card:hover {
		border-color: rgba(0, 229, 196, 0.4);
		color: #fff;
	}

	@media (max-width: 639px) {
		.td-title {
			font-size: 48px;
			letter-spacing: -2px;
		}

		.td-selectors {
			grid-template-columns: 1fr;
			justify-items: center;
		}

		.td-swap {
			transform: rotate(90deg);
		}

		.td-form-card,
		.td-timeline-section {
			padding: 24px 20px;
		}

		.td-diff-text {
			font-size: 22px;
		}

		.td-times-grid {
			grid-template-columns: 1fr;
		}

		.td-time-clock {
			font-size: 48px;
		}

		.td-timeline-row,
		.td-overlap-band,
		.td-timeline-axis {
			grid-template-columns: 56px 1fr;
		}

		.td-timeline-label {
			font-size: 11px;
		}

		.td-presets-grid,
		.td-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const cityASelect = document.getElementById('city-a') as HTMLSelectElement;
	const cityBSelect = document.getElementById('city-b') as HTMLSelectElement;
	const swapBtn = document.getElementById('swap-btn');

	const diffText = document.getElementById('diff-text');
	const diffDirection = document.getElementById('diff-direction');
	const timeLabelA = document.getElementById('time-label-a');
	const timeLabelB = document.getElementById('time-label-b');
	const timeClockA = document.getElementById('time-clock-a');
	const timeClockB = document.getElementById('time-clock-b');
	const timeDateA = document.getElementById('time-date-a');
	const timeDateB = document.getElementById('time-date-b');
	const dateRelation = document.getElementById('date-relation');
	const timelineLabelA = document.getElementById('timeline-label-a');
	const timelineLabelB = document.getElementById('timeline-label-b');
	const timelineBarA = document.getElementById('timeline-bar-a');
	const timelineBarB = document.getElementById('timeline-bar-b');
	const overlapBand = document.getElementById('overlap-band');
	const overlapSummary = document.getElementById('overlap-summary');

	const clockFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const dateFormatterCache = new Map<string, Intl.DateTimeFormat>();
	const hourFormatterCache = new Map<string, Intl.DateTimeFormat>();

	const WORK_START = 9;
	const WORK_END = 18;

	function getSelectedTimezone(select: HTMLSelectElement): string {
		return select.selectedOptions[0]?.dataset.timezone ?? 'UTC';
	}

	function getSelectedCity(select: HTMLSelectElement): string {
		return select.value;
	}

	function getClockFormatter(timeZone: string) {
		if (!clockFormatterCache.has(timeZone)) {
			clockFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					hour: '2-digit',
					minute: '2-digit',
					second: '2-digit',
					hour12: false,
				}),
			);
		}
		return clockFormatterCache.get(timeZone)!;
	}

	function getDateFormatter(timeZone: string) {
		if (!dateFormatterCache.has(timeZone)) {
			dateFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					weekday: 'long',
					day: 'numeric',
					month: 'long',
					year: 'numeric',
				}),
			);
		}
		return dateFormatterCache.get(timeZone)!;
	}

	function getHourFormatter(timeZone: string) {
		if (!hourFormatterCache.has(timeZone)) {
			hourFormatterCache.set(
				timeZone,
				new Intl.DateTimeFormat('en-GB', {
					timeZone,
					hour: 'numeric',
					hour12: false,
				}),
			);
		}
		return hourFormatterCache.get(timeZone)!;
	}

	function getLocalHour(timeZone: string, date: Date): number {
		const parts = getHourFormatter(timeZone).formatToParts(date);
		return parseInt(
			parts.find((p) => p.type === 'hour')?.value ?? '0',
			10,
		);
	}

	function getDateKey(timeZone: string, date: Date): number {
		const fmt = new Intl.DateTimeFormat('en-CA', {
			timeZone,
			year: 'numeric',
			month: '2-digit',
			day: '2-digit',
		});
		const [y, m, d] = fmt.format(date).split('-').map(Number);
		return y * 10000 + m * 100 + d;
	}

	function getOffsetMinutes(timeZone: string, date: Date): number {
		const utc = new Date(date.toLocaleString('en-US', { timeZone: 'UTC' }));
		const tz = new Date(date.toLocaleString('en-US', { timeZone }));
		return (tz.getTime() - utc.getTime()) / 60000;
	}

	function formatDuration(totalMinutes: number): string {
		const hours = Math.floor(totalMinutes / 60);
		const mins = totalMinutes % 60;
		const parts: string[] = [];
		if (hours > 0) parts.push(`${hours} hour${hours === 1 ? '' : 's'}`);
		if (mins > 0) parts.push(`${mins} minute${mins === 1 ? '' : 's'}`);
		return parts.join(' ') || '0 hours';
	}

	function isWorkingHour(hour: number): boolean {
		return hour >= WORK_START && hour < WORK_END;
	}

	function dateAtLocalHour(
		timeZone: string,
		date: Date,
		hour: number,
	): Date {
		const fmt = new Intl.DateTimeFormat('en-CA', {
			timeZone,
			year: 'numeric',
			month: '2-digit',
			day: '2-digit',
		});
		const [y, m, d] = fmt.format(date).split('-').map(Number);

		let probe = new Date(Date.UTC(y, m - 1, d, hour, 30, 0));
		const formatter = new Intl.DateTimeFormat('en-US', {
			timeZone,
			hourCycle: 'h23',
			year: 'numeric',
			month: 'numeric',
			day: 'numeric',
			hour: 'numeric',
			minute: 'numeric',
		});

		for (let i = 0; i < 2; i++) {
			const parts = formatter.formatToParts(probe);
			const get = (type: string) =>
				parseInt(parts.find((p) => p.type === type)?.value ?? '0', 10);
			const desired = Date.UTC(y, m - 1, d, hour, 30);
			const actual = Date.UTC(
				get('year'),
				get('month') - 1,
				get('day'),
				get('hour'),
				get('minute'),
			);
			probe = new Date(probe.getTime() + (desired - actual));
		}

		return probe;
	}

	function formatHourLabel(h: number): string {
		if (h === 0 || h === 24) return '12am';
		if (h === 12) return '12pm';
		if (h < 12) return `${h}am`;
		return `${h - 12}pm`;
	}

	function formatHourRange(start: number, end: number): string {
		return `${formatHourLabel(start)}–${formatHourLabel(end)}`;
	}

	function buildTimelineBar(
		bar: HTMLElement,
		cityTz: string,
		now: Date,
		overlapHours: Set<number>,
	) {
		bar.innerHTML = '';
		const currentHour = getLocalHour(cityTz, now);

		for (let h = 0; h < 24; h++) {
			const seg = document.createElement('div');
			seg.className = 'td-hour-seg';

			if (isWorkingHour(h)) seg.classList.add('working');
			if (overlapHours.has(h)) seg.classList.add('overlap');
			if (h === currentHour) seg.classList.add('now');

			seg.title = formatHourLabel(h);

			bar.appendChild(seg);
		}
	}

	function computeOverlap(
		tzA: string,
		tzB: string,
		now: Date,
	): { overlapA: Set<number>; overlapB: Set<number> } {
		const overlapA = new Set<number>();
		const overlapB = new Set<number>();

		for (let h = 0; h < 24; h++) {
			const instantA = dateAtLocalHour(tzA, now, h);
			const hourB = getLocalHour(tzB, instantA);
			if (isWorkingHour(h) && isWorkingHour(hourB)) {
				overlapA.add(h);
				overlapB.add(hourB);
			}

			const instantB = dateAtLocalHour(tzB, now, h);
			const hourA = getLocalHour(tzA, instantB);
			if (isWorkingHour(hourA) && isWorkingHour(h)) {
				overlapA.add(hourA);
				overlapB.add(h);
			}
		}

		return { overlapA, overlapB };
	}

	function rangesFromHours(hours: Set<number>): [number, number][] {
		const sorted = [...hours].sort((a, b) => a - b);
		const ranges: [number, number][] = [];
		let start = -1;
		let prev = -1;

		for (const h of sorted) {
			if (start === -1) {
				start = h;
				prev = h;
			} else if (h === prev + 1) {
				prev = h;
			} else {
				ranges.push([start, prev + 1]);
				start = h;
				prev = h;
			}
		}
		if (start !== -1) ranges.push([start, prev + 1]);
		return ranges;
	}

	function selectCity(select: HTMLSelectElement, city: string) {
		for (const option of select.options) {
			if (option.value === city) {
				select.value = city;
				return;
			}
		}
	}

	function update() {
		if (!cityASelect || !cityBSelect) return;

		const tzA = getSelectedTimezone(cityASelect);
		const tzB = getSelectedTimezone(cityBSelect);
		const cityA = getSelectedCity(cityASelect);
		const cityB = getSelectedCity(cityBSelect);
		const now = new Date();

		if (timeLabelA) timeLabelA.textContent = cityA;
		if (timeLabelB) timeLabelB.textContent = cityB;
		if (timelineLabelA) timelineLabelA.textContent = cityA;
		if (timelineLabelB) timelineLabelB.textContent = cityB;

		if (timeClockA)
			timeClockA.textContent = getClockFormatter(tzA).format(now);
		if (timeClockB)
			timeClockB.textContent = getClockFormatter(tzB).format(now);
		if (timeDateA) timeDateA.textContent = getDateFormatter(tzA).format(now);
		if (timeDateB) timeDateB.textContent = getDateFormatter(tzB).format(now);

		const diffMinutes =
			getOffsetMinutes(tzB, now) - getOffsetMinutes(tzA, now);

		if (diffText) {
			if (diffMinutes === 0) {
				diffText.textContent = `${cityA} and ${cityB} are in the same time zone`;
			} else if (diffMinutes < 0) {
				diffText.textContent = `${cityB} is ${formatDuration(Math.abs(diffMinutes))} behind ${cityA}`;
			} else {
				diffText.textContent = `${cityB} is ${formatDuration(diffMinutes)} ahead of ${cityA}`;
			}
		}

		if (diffDirection) {
			if (diffMinutes === 0) {
				diffDirection.textContent = 'No time difference';
			} else if (diffMinutes < 0) {
				diffDirection.textContent = `${cityB} is behind ${cityA}`;
			} else {
				diffDirection.textContent = `${cityB} is ahead of ${cityA}`;
			}
		}

		const dayA = getDateKey(tzA, now);
		const dayB = getDateKey(tzB, now);
		if (dateRelation) {
			if (dayB > dayA) {
				dateRelation.textContent = `${cityB} is on the next calendar date compared to ${cityA}`;
			} else if (dayB < dayA) {
				dateRelation.textContent = `${cityB} is on the previous calendar date compared to ${cityA}`;
			} else {
				dateRelation.textContent = `Both cities are on the same calendar date`;
			}
		}

		const { overlapA, overlapB } = computeOverlap(tzA, tzB, now);

		if (timelineBarA)
			buildTimelineBar(timelineBarA, tzA, now, overlapA);
		if (timelineBarB)
			buildTimelineBar(timelineBarB, tzB, now, overlapB);

		const hasOverlap = overlapA.size > 0;
		overlapBand?.classList.toggle('visible', hasOverlap);

		if (overlapSummary) {
			if (!hasOverlap) {
				overlapSummary.textContent = `No overlap today — when it's 9am–6pm in ${cityA}, ${cityB} is outside working hours (and vice versa).`;
			} else {
				const rangesA = rangesFromHours(overlapA);
				const rangeText = rangesA
					.map(([s, e]) => formatHourRange(s, e))
					.join(' and ');
				overlapSummary.textContent = `Today in ${cityA}, the best window to call ${cityB} is ${rangeText} (${cityA} local time).`;
			}
		}
	}

	update();

	cityASelect?.addEventListener('change', update);
	cityBSelect?.addEventListener('change', update);

	swapBtn?.addEventListener('click', () => {
		if (!cityASelect || !cityBSelect) return;
		const aVal = cityASelect.value;
		const bVal = cityBSelect.value;
		cityASelect.value = bVal;
		cityBSelect.value = aVal;
		update();
	});

	document.querySelectorAll('.td-preset-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const a = (btn as HTMLButtonElement).dataset.cityA;
			const b = (btn as HTMLButtonElement).dataset.cityB;
			if (a && b && cityASelect && cityBSelect) {
				selectCity(cityASelect, a);
				selectCity(cityBSelect, b);
				update();
			}
		});
	});

	setInterval(update, 1000);
</script>
