---
import Layout from '../layouts/Layout.astro';
import { allWorldClockCities } from '../data/worldClockSearchCities';

const cities = [...allWorldClockCities].sort((a, b) =>
	a.city.localeCompare(b.city),
);

const presets = [
	{ cityA: 'London', cityB: 'New York', label: 'London ↔ New York' },
	{ cityA: 'London', cityB: 'Sydney', label: 'London ↔ Sydney' },
	{ cityA: 'New York', cityB: 'Tokyo', label: 'New York ↔ Tokyo' },
	{ cityA: 'Dubai', cityB: 'London', label: 'Dubai ↔ London' },
	{ cityA: 'Los Angeles', cityB: 'New York', label: 'LA ↔ New York' },
	{ cityA: 'Singapore', cityB: 'London', label: 'Singapore ↔ London' },
	{ cityA: 'Paris', cityB: 'New York', label: 'Paris ↔ New York' },
	{ cityA: 'Toronto', cityB: 'London', label: 'Toronto ↔ London' },
];
---

<Layout
	title="Time Difference Calculator — Time Between Cities | Clockr"
	description="Calculate the time difference between any two cities. Find the best time to call across time zones with our free time difference calculator."
	category="timezones"
>
	<div class="td-page">
		<div class="td-header">
			<div class="td-eyebrow">🌍 Time Zones</div>
			<h1 class="td-title">
				<span class="td-gradient">Time Difference</span><br />
				<span class="td-gradient">Calculator</span>
			</h1>
			<p class="td-subtitle">
				Find the time difference between any two cities in the world
			</p>
		</div>

		<div class="td-form-card">
			<div class="td-selectors">
				<div class="td-select-wrap">
					<label class="td-label" for="city-a">City A</label>
					<select id="city-a" class="td-select">
						{
							cities.map((c) => (
								<option
									value={c.city}
									data-timezone={c.timezone}
									selected={c.city === 'London'}
								>
									{c.flag} {c.city}, {c.country}
								</option>
							))
						}
					</select>
				</div>

				<button
					type="button"
					class="td-swap"
					id="swap-btn"
					aria-label="Swap cities"
					title="Swap cities"
				>
					⇄
				</button>

				<div class="td-select-wrap">
					<label class="td-label" for="city-b">City B</label>
					<select id="city-b" class="td-select">
						{
							cities.map((c) => (
								<option
									value={c.city}
									data-timezone={c.timezone}
									selected={c.city === 'New York'}
								>
									{c.flag} {c.city}, {c.country}
								</option>
							))
						}
					</select>
				</div>
			</div>
		</div>

		<div class="td-diff-card">
			<div class="td-diff-text" id="diff-text">—</div>
			<div class="td-diff-direction" id="diff-direction">—</div>
		</div>

		<div class="td-times-grid">
			<div class="td-time-card">
				<div class="td-time-city" id="time-label-a">London</div>
				<div class="td-time-clock" id="time-clock-a">--:--:--</div>
				<div class="td-time-date" id="time-date-a">—</div>
			</div>
			<div class="td-time-card">
				<div class="td-time-city" id="time-label-b">New York</div>
				<div class="td-time-clock" id="time-clock-b">--:--:--</div>
				<div class="td-time-date" id="time-date-b">—</div>
			</div>
		</div>

		<div class="td-date-relation" id="date-relation">—</div>

		<div class="td-timeline-section">
			<h3 class="td-section-title">Best time to call</h3>
			<p class="td-section-sub">
				Overlap when both cities are within 9am–6pm working hours
			</p>

			<div class="td-timeline-wrap">
				<div class="td-timeline-row">
					<span class="td-timeline-label" id="timeline-label-a">London</span>
					<div class="td-timeline-bar" id="timeline-bar-a"></div>
				</div>

				<div class="td-overlap-band" id="overlap-band">
					<span class="td-overlap-text">Good time to call</span>
				</div>

				<div class="td-timeline-row">
					<span class="td-timeline-label" id="timeline-label-b">New York</span>
					<div class="td-timeline-bar" id="timeline-bar-b"></div>
				</div>

				<div class="td-timeline-axis">
					<span>12am</span>
					<span>6am</span>
					<span>12pm</span>
					<span>6pm</span>
					<span>12am</span>
				</div>
			</div>

			<p class="td-timeline-note" id="overlap-summary">—</p>
		</div>

		<div class="td-presets">
			<h3 class="td-presets-title">Common time differences</h3>
			<div class="td-presets-grid">
				{
					presets.map((p) => (
						<button
							type="button"
							class="td-preset-btn"
							data-city-a={p.cityA}
							data-city-b={p.cityB}
						>
							{p.label}
						</button>
					))
				}
			</div>
		</div>

		<div class="td-related">
			<h3 class="td-related-title">You might also like</h3>
			<div class="td-related-grid">
				<a href="/timezone-converter" class="td-related-card"
					>🔄 Time Zone Converter</a
				>
				<a href="/world-clock" class="td-related-card">🌍 World Clock</a>
				<a href="/age-calculator" class="td-related-card">🎂 Age Calculator</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.td-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.td-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.td-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.td-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.td-gradient {
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.td-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.td-form-card {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.2);
		border-radius: 20px;
		padding: 32px;
		margin-bottom: 24px;
		box-shadow: 0 0 40px rgba(0, 229, 196, 0.06);
	}

	.td-selectors {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: 16px;
		align-items: end;
	}

	.td-select-wrap {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.td-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 0.5px;
	}

	.td-select {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.3);
		border-radius: 12px;
		padding: 14px 16px;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 600;
		color: #ffffff;
		outline: none;
		cursor: pointer;
		transition: border-color 0.2s ease;
		width: 100%;
	}

	.td-select:focus {
		border-color: rgba(0, 229, 196, 0.8);
		box-shadow: 0 0 20px rgba(0, 229, 196, 0.15);
	}

	.td-select option {
		background: #0c0c0c;
