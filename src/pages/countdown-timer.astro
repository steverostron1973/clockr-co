---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Countdown Timer — Free Online Timer | Clockr"
	description="Free online countdown timer. Set any time from seconds to hours. Simple, clean countdown timer with alarm."
>
	<div class="timer-page">
		<!-- PAGE HEADER -->
		<div class="timer-header">
			<div class="timer-eyebrow">⏱️ Timers & Countdowns</div>
			<h1 class="timer-title">
				<span class="timer-gradient">Countdown</span><br />
				<span class="timer-gradient">Timer</span>
			</h1>
			<p class="timer-subtitle">Set a timer for any amount of time</p>
		</div>

		<!-- INPUT SECTION -->
		<div class="timer-form-card" id="timer-setup">
			<div class="timer-inputs">
				<div class="timer-input-wrap">
					<label class="timer-label" for="input-hours">Hours</label>
					<input
						type="number"
						id="input-hours"
						class="timer-input"
						min="0"
						max="99"
						value="0"
					/>
				</div>
				<div class="timer-input-wrap">
					<label class="timer-label" for="input-minutes">Minutes</label>
					<input
						type="number"
						id="input-minutes"
						class="timer-input"
						min="0"
						max="59"
						value="5"
					/>
				</div>
				<div class="timer-input-wrap">
					<label class="timer-label" for="input-seconds">Seconds</label>
					<input
						type="number"
						id="input-seconds"
						class="timer-input"
						min="0"
						max="59"
						value="0"
					/>
				</div>
			</div>

			<button type="button" class="timer-start" id="start-btn">Start</button>

			<div class="timer-presets">
				<p class="timer-presets-label">Quick presets</p>
				<div class="timer-presets-grid">
					<button type="button" class="timer-preset-btn" data-seconds="60"
						>1 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="120"
						>2 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="300"
						>5 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="600"
						>10 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="900"
						>15 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="1200"
						>20 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="1800"
						>30 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="2700"
						>45 min</button
					>
					<button type="button" class="timer-preset-btn" data-seconds="3600"
						>1 hour</button
					>
				</div>
			</div>
		</div>

		<!-- ACTIVE COUNTDOWN -->
		<div class="timer-active" id="timer-active" style="display:none">
			<div class="timer-display-card" id="timer-display-card">
				<div class="timer-display" id="timer-display">00:00:00</div>
				<div class="timer-done-msg" id="timer-done-msg" style="display:none">
					Time's up! 🚨
				</div>
			</div>

			<div class="timer-controls">
				<button type="button" class="timer-control-btn" id="pause-btn"
					>Pause</button
				>
				<button type="button" class="timer-control-btn" id="reset-btn"
					>Reset</button
				>
				<button type="button" class="timer-control-btn" id="add-min-btn"
					>+1 Min</button
				>
			</div>
		</div>

		<!-- RELATED TOOLS -->
		<div class="timer-related">
			<h3 class="timer-related-title">You might also like</h3>
			<div class="timer-related-grid">
				<a href="/age-calculator" class="timer-related-card">🎂 Age Calculator</a>
				<a href="/date-calculator" class="timer-related-card">📅 Date Calculator</a>
				<a href="/world-clock" class="timer-related-card">🌍 World Clock</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.timer-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.timer-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.timer-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.timer-title {
		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.timer-gradient {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.timer-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.timer-form-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 20px;
		padding: 32px;
		margin-bottom: 48px;
		box-shadow: 0 0 40px rgba(139, 92, 246, 0.06);
	}

	.timer-inputs {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		margin-bottom: 24px;
	}

	.timer-input-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
	}

	.timer-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 0.5px;
	}

	.timer-input {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.3);
		border-radius: 12px;
		padding: 16px 24px;
		font-family: 'Outfit', sans-serif;
		font-size: 32px;
		font-weight: 700;
		color: #ffffff;
		text-align: center;
		outline: none;
		width: 100%;
		transition: border-color 0.2s ease;
		-moz-appearance: textfield;
	}

	.timer-input::-webkit-outer-spin-button,
	.timer-input::-webkit-inner-spin-button {
		-webkit-appearance: none;
		margin: 0;
	}

	.timer-input:focus {
		border-color: rgba(139, 92, 246, 0.8);
		box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);
	}

	.timer-start {
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		color: #fff;
		border: none;
		border-radius: 12px;
		padding: 20px 32px;
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		cursor: pointer;
		width: 100%;
		margin-bottom: 32px;
		transition: opacity 0.2s ease;
	}

	.timer-start:hover {
		opacity: 0.9;
	}

	.timer-presets-label {
		font-family: 'Outfit', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		margin-bottom: 12px;
		text-align: center;
	}

	.timer-presets-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
	}

	.timer-preset-btn {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 12px 8px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.timer-preset-btn:hover {
		border-color: rgba(139, 92, 246, 0.4);
		color: #fff;
	}

	.timer-active {
		margin-bottom: 48px;
	}

	.timer-display-card {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 20px;
		padding: 48px 40px;
		text-align: center;
		margin-bottom: 16px;
		box-shadow: 0 0 40px rgba(139, 92, 246, 0.06);
		transition: border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.timer-display-card.timer-flash {
		animation: timer-flash 0.8s ease-in-out infinite;
	}

	@keyframes timer-flash {
		0%,
		100% {
			border-color: rgba(236, 72, 153, 0.9);
			box-shadow: 0 0 60px rgba(236, 72, 153, 0.4);
			transform: scale(1);
		}
		50% {
			border-color: rgba(139, 92, 246, 0.5);
			box-shadow: 0 0 80px rgba(139, 92, 246, 0.25);
			transform: scale(1.02);
		}
	}

	.timer-display {
		font-family: 'Outfit', sans-serif;
		font-size: 96px;
		font-weight: 900;
		letter-spacing: -4px;
		line-height: 1;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
	}

	.timer-done-msg {
		font-family: 'Outfit', sans-serif;
		font-size: 52px;
		font-weight: 900;
		letter-spacing: -1px;
		margin-top: 20px;
		background: linear-gradient(135deg, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: timer-pulse 0.8s ease-in-out infinite;
	}

	@keyframes timer-pulse {
		0%,
		100% {
			opacity: 1;
			transform: scale(1);
		}
		50% {
			opacity: 0.7;
			transform: scale(1.05);
		}
	}

	.timer-controls {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.timer-control-btn {
		background: #0c0c0c;
		border: 1px solid rgba(139, 92, 246, 0.3);
		border-radius: 12px;
		padding: 16px;
		font-family: 'Outfit', sans-serif;
		font-size: 15px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.85);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.timer-control-btn:hover {
		border-color: rgba(139, 92, 246, 0.6);
		background: rgba(139, 92, 246, 0.08);
	}

	.timer-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.timer-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.timer-related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.timer-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-align: center;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.timer-related-card:hover {
		border-color: rgba(139, 92, 246, 0.4);
		color: #fff;
	}

	@media (max-width: 600px) {
		.timer-title {
			font-size: 48px;
		}

		.timer-display {
			font-size: 64px;
			letter-spacing: -2px;
		}

		.timer-inputs {
			gap: 12px;
		}

		.timer-input {
			font-size: 24px;
			padding: 12px 16px;
		}

		.timer-presets-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>

<script>
	const inputHours = document.getElementById('input-hours') as HTMLInputElement;
	const inputMinutes = document.getElementById(
		'input-minutes',
	) as HTMLInputElement;
	const inputSeconds = document.getElementById(
		'input-seconds',
	) as HTMLInputElement;
	const startBtn = document.getElementById('start-btn');
	const timerSetup = document.getElementById('timer-setup');
	const timerActive = document.getElementById('timer-active');
	const timerDisplay = document.getElementById('timer-display');
	const timerDisplayCard = document.getElementById('timer-display-card');
	const timerDoneMsg = document.getElementById('timer-done-msg');
	const pauseBtn = document.getElementById('pause-btn');
	const resetBtn = document.getElementById('reset-btn');
	const addMinBtn = document.getElementById('add-min-btn');
	const presetBtns = document.querySelectorAll('.timer-preset-btn');

	let remainingSeconds = 0;
	let intervalId: ReturnType<typeof setInterval> | null = null;
	let isPaused = false;
	let isFinished = false;
	let audioCtx: AudioContext | null = null;
	let activeSirenNodes: AudioNode[] = [];

	function makeDistortionCurve(amount: number): Float32Array {
		const samples = 44100;
		const curve = new Float32Array(samples);
		const deg = Math.PI / 180;
		for (let i = 0; i < samples; i++) {
			const x = (i * 2) / samples - 1;
			curve[i] =
				((3 + amount) * x * 20 * deg) / (Math.PI + amount * Math.abs(x));
		}
		return curve;
	}

	function stopSiren() {
		activeSirenNodes.forEach((node) => {
			try {
				if ('stop' in node && typeof node.stop === 'function') {
					(node as OscillatorNode).stop();
				}
				node.disconnect();
			} catch {
				/* already stopped */
			}
		});
		activeSirenNodes = [];
	}

	function clampInput(input: HTMLInputElement, max: number) {
		let val = parseInt(input.value, 10);
		if (isNaN(val) || val < 0) val = 0;
		if (val > max) val = max;
		input.value = String(val);
		return val;
	}

	function getInputTotalSeconds(): number {
		const h = clampInput(inputHours, 99);
		const m = clampInput(inputMinutes, 59);
		const s = clampInput(inputSeconds, 59);
		return h * 3600 + m * 60 + s;
	}

	function secondsToHMS(total: number): {
		hours: number;
		minutes: number;
		seconds: number;
	} {
		const hours = Math.floor(total / 3600);
		const minutes = Math.floor((total % 3600) / 60);
		const seconds = total % 60;
		return { hours, minutes, seconds };
	}

	function setInputsFromSeconds(total: number) {
		const { hours, minutes, seconds } = secondsToHMS(total);
		inputHours.value = String(hours);
		inputMinutes.value = String(minutes);
		inputSeconds.value = String(seconds);
	}

	function formatDisplay(total: number): string {
		const { hours, minutes, seconds } = secondsToHMS(total);
		const pad = (n: number) => String(n).padStart(2, '0');
		return `${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
	}

	function updateDisplay() {
		if (timerDisplay) timerDisplay.textContent = formatDisplay(remainingSeconds);
	}

	async function playCartoonSiren() {
		try {
			stopSiren();
			if (!audioCtx) audioCtx = new AudioContext();
			const ctx = audioCtx;
			if (ctx.state === 'suspended') await ctx.resume();

			const LOW = 600;
			const HIGH = 1200;
			const SWEEP = 0.28;
			const CYCLE = SWEEP * 2;
			const REPEATS = 4;
			const total = CYCLE * REPEATS;
			const t0 = ctx.currentTime;

			const waveshaper = ctx.createWaveShaper();
			waveshaper.curve = makeDistortionCurve(60);
			waveshaper.oversample = '4x';
			activeSirenNodes.push(waveshaper);

			const masterGain = ctx.createGain();
			masterGain.gain.setValueAtTime(0.45, t0);
			masterGain.gain.setValueAtTime(0.45, t0 + total - 0.05);
			masterGain.gain.exponentialRampToValueAtTime(0.001, t0 + total);
			masterGain.connect(ctx.destination);
			activeSirenNodes.push(masterGain);

			waveshaper.connect(masterGain);

			function scheduleWoop(
				osc: OscillatorNode,
				gain: GainNode,
				offset: number,
			) {
				activeSirenNodes.push(osc, gain);
				for (let i = 0; i < REPEATS; i++) {
					const start = t0 + offset + i * CYCLE;
					osc.frequency.setValueAtTime(LOW, start);
					osc.frequency.exponentialRampToValueAtTime(HIGH, start + SWEEP);
					osc.frequency.setValueAtTime(HIGH, start + SWEEP);
					osc.frequency.exponentialRampToValueAtTime(LOW, start + CYCLE);
				}
				gain.gain.setValueAtTime(0.55, t0);
				osc.start(t0 + offset);
				osc.stop(t0 + total + 0.1);
			}

			const osc1 = ctx.createOscillator();
			osc1.type = 'sawtooth';
			const gain1 = ctx.createGain();
			gain1.gain.value = 0.5;
			osc1.connect(gain1);
			gain1.connect(waveshaper);
			scheduleWoop(osc1, gain1, 0);

			const osc2 = ctx.createOscillator();
			osc2.type = 'square';
			const gain2 = ctx.createGain();
			gain2.gain.value = 0.2;
			osc2.connect(gain2);
			gain2.connect(waveshaper);
			scheduleWoop(osc2, gain2, 0.02);

			const lfo = ctx.createOscillator();
			lfo.type = 'sine';
			lfo.frequency.value = 12;
			const lfoGain = ctx.createGain();
			lfoGain.gain.value = 80;
			lfo.connect(lfoGain);
			lfoGain.connect(osc1.frequency);
			activeSirenNodes.push(lfo, lfoGain);
			lfo.start(t0);
			lfo.stop(t0 + total + 0.1);
		} catch {
			/* audio unavailable */
		}
	}

	function onTimerFinish() {
		if (intervalId) {
			clearInterval(intervalId);
			intervalId = null;
		}
		isFinished = true;
		isPaused = false;
		remainingSeconds = 0;
		updateDisplay();

		if (timerDisplayCard) timerDisplayCard.classList.add('timer-flash');
		if (timerDoneMsg) timerDoneMsg.style.display = 'block';
		if (pauseBtn) {
			pauseBtn.textContent = 'Pause';
			pauseBtn.setAttribute('disabled', 'true');
			pauseBtn.style.opacity = '0.4';
			pauseBtn.style.cursor = 'not-allowed';
		}

		playCartoonSiren();
	}

	function tick() {
		if (isPaused || isFinished) return;
		if (remainingSeconds <= 0) {
			onTimerFinish();
			return;
		}
		remainingSeconds--;
		updateDisplay();
		if (remainingSeconds <= 0) onTimerFinish();
	}

	function startInterval() {
		if (intervalId) clearInterval(intervalId);
		intervalId = setInterval(tick, 1000);
	}

	function showActiveTimer() {
		if (timerSetup) timerSetup.style.display = 'none';
		if (timerActive) timerActive.style.display = 'block';
	}

	function showSetup() {
		if (timerSetup) timerSetup.style.display = 'block';
		if (timerActive) timerActive.style.display = 'none';
	}

	function resetTimerState() {
		if (intervalId) {
			clearInterval(intervalId);
			intervalId = null;
		}
		stopSiren();
		isPaused = false;
		isFinished = false;
		if (timerDisplayCard) timerDisplayCard.classList.remove('timer-flash');
		if (timerDoneMsg) timerDoneMsg.style.display = 'none';
		if (pauseBtn) {
			pauseBtn.textContent = 'Pause';
			pauseBtn.removeAttribute('disabled');
			pauseBtn.style.opacity = '';
			pauseBtn.style.cursor = '';
		}
	}

	function startTimer() {
		const total = getInputTotalSeconds();
		if (total <= 0) return;

		resetTimerState();
		remainingSeconds = total;
		updateDisplay();
		showActiveTimer();
		startInterval();
	}

	startBtn?.addEventListener('click', startTimer);

	presetBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const secs = parseInt(btn.getAttribute('data-seconds') || '0', 10);
			setInputsFromSeconds(secs);
		});
	});

	pauseBtn?.addEventListener('click', () => {
		if (isFinished) return;
		isPaused = !isPaused;
		if (pauseBtn) pauseBtn.textContent = isPaused ? 'Resume' : 'Pause';
	});

	resetBtn?.addEventListener('click', () => {
		resetTimerState();
		showSetup();
	});

	addMinBtn?.addEventListener('click', () => {
		if (isFinished) {
			resetTimerState();
			isFinished = false;
		}
		remainingSeconds += 60;
		isPaused = false;
		if (pauseBtn) pauseBtn.textContent = 'Pause';
		updateDisplay();
		if (!intervalId) startInterval();
	});

	[inputHours, inputMinutes, inputSeconds].forEach((input) => {
		input?.addEventListener('change', () => {
			const max = input === inputHours ? 99 : 59;
			clampInput(input, max);
		});
	});
</script>
