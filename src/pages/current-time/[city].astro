---
import Layout from '../../layouts/Layout.astro';
import CityCurrentTime from '../../components/CityCurrentTime.jsx';
import { currentTimeCities } from '../../utils/currentTimeCities';
import { getTimezonePairsForCity } from '../../utils/timezoneCityPairs';

export function getStaticPaths() {
	return currentTimeCities.map((city) => ({
		params: { city: city.slug },
		props: {
			city,
			relatedPairs: getTimezonePairsForCity(city.slug),
		},
	}));
}

const { city, relatedPairs } = Astro.props;
const pageTitle = `What Time Is It In ${city.name}? — Current Local Time | Clockr`;
const pageDescription = `What time is it in ${city.name}, ${city.country} right now? See the live local time, date, UTC offset, and today's sunrise and sunset.`;
const otherCity =
	relatedPairs.length > 0
		? relatedPairs[0].from.slug === city.slug
			? relatedPairs[0].to
			: relatedPairs[0].from
		: null;
---

<Layout title={pageTitle} description={pageDescription} category="timezones">
	<div class="ct-page">
		<div class="ct-header">
			<div class="ct-eyebrow">🌍 Time Zones</div>
			<h1 class="ct-title">
				<span class="ct-gradient">What Time Is It In {city.name}?</span>
			</h1>
			<p class="ct-subtitle">
				{city.flag} {city.name}, {city.country} — current local time
			</p>
		</div>

		<CityCurrentTime
			client:load
			cityName={city.name}
			timezone={city.timezone}
			lat={city.lat}
			lng={city.lng}
		/>

		{
			otherCity ? (
				<div class="ct-convert-card">
					<h2 class="ct-section-heading">Convert to another city</h2>
					<p class="ct-convert-lead">
						Compare {city.name} with another city using the time zone converter.
					</p>
					<a
						href="/timezone-converter"
						class="ct-convert-btn"
					>
						Open Time Zone Converter
					</a>
				</div>
			) : null
		}

		{
			relatedPairs.length > 0 ? (
				<section class="ct-explore">
					<h2 class="ct-section-heading">Time zone pages for {city.name}</h2>
					<div class="ct-explore-grid">
						{relatedPairs.map((pair) => (
							<a href={`/timezone/${pair.slug}`} class="ct-explore-card">
								<span class="ct-explore-name">
									{pair.from.name} to {pair.to.name}
								</span>
							</a>
						))}
					</div>
				</section>
			) : null
		}

		<section class="ct-about">
			<h2 class="ct-section-heading">About {city.name}</h2>
			<div class="ct-about-card">
				<p class="ct-about-text">{city.fact}</p>
			</div>
		</section>

		<div class="ct-related">
			<h3 class="ct-related-title">You might also like</h3>
			<div class="ct-related-grid">
				<a href="/world-clock" class="ct-related-card"
					><span class="ct-related-name">World Clock</span></a
				>
				<a href="/timezone-converter" class="ct-related-card"
					><span class="ct-related-name">Time Zone Converter</span></a
				>
				<a href="/time-difference" class="ct-related-card"
					><span class="ct-related-name">Time Difference Calculator</span></a
				>
				<a href="/current-time/" class="ct-related-card"
					><span class="ct-related-name">Browse All Cities</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style is:global>
	.ct-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 24px;
	}

	.ct-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.ct-eyebrow {
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.ct-title {
		font-family: 'Outfit', sans-serif;
		font-size: 52px;
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.ct-gradient {
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.ct-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	.ct-tool {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin-bottom: 40px;
	}

	.ct-live-card {
		background: #0c0c0c;
		border: 1px solid rgba(0, 229, 196, 0.2);
		border-radius: 16px;
		padding: 32px 24px;
		text-align: center;
		box-shadow: 0 0 30px rgba(0, 229, 196, 0.05);
	}

	.ct-live-label {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.55);
		margin-bottom: 12px;
	}

	.ct-live-time {
		font-family: 'Outfit', sans-serif;
		font-size: 56px;
		font-weight: 900;
		letter-spacing: -2px;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-variant-numeric: tabular-nums;
		margin-bottom: 10px;
	}

	.ct-live-date,
	.ct-live-offset {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.45);
		line-height: 1.5;
	}

	.ct-sun-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 20px 24px;
		text-align: center;
	}

	.ct-sun-title {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.55);
		margin-bottom: 8px;
	}

	.ct-sun-text {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.75);
		margin: 0;
		line-height: 1.5;
	}

	.ct-section-heading {
		font-family: 'Outfit', sans-serif;
		font-size: 22px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ct-convert-card,
	.ct-about-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 24px;
		margin-bottom: 40px;
	}

	.ct-convert-lead,
	.ct-about-text {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.6;
		margin: 0 0 16px;
	}

	.ct-about-text {
		margin-bottom: 0;
	}

	.ct-convert-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 20px;
		border-radius: 10px;
		background: rgba(0, 229, 196, 0.12);
		border: 1px solid rgba(0, 229, 196, 0.25);
		color: #00e5c4;
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.ct-convert-btn:hover {
		border-color: rgba(0, 229, 196, 0.5);
	}

	.ct-explore {
		margin-bottom: 40px;
	}

	.ct-explore-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.ct-explore-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 16px;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.ct-explore-card:hover {
		border-color: rgba(0, 229, 196, 0.4);
	}

	.ct-explore-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: #fff;
	}

	.ct-about {
		margin-bottom: 40px;
	}

	.ct-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.ct-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ct-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.ct-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.ct-related-card:hover {
		border-color: rgba(0, 229, 196, 0.4);
	}

	.ct-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #00e5c4, #0099ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	@media (max-width: 639px) {
		.ct-title {
			font-size: 40px;
			letter-spacing: -1px;
		}

		.ct-live-time {
			font-size: 44px;
		}

		.ct-explore-grid,
		.ct-related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
