---
import Layout from '../layouts/Layout.astro';

function isLeapYear(year: number): boolean {
	return (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;
}

function getNextLeapYears(count: number): number[] {
	const now = new Date();
	const currentYear = now.getFullYear();
	const years: number[] = [];
	let year = currentYear;

	if (isLeapYear(currentYear) && now.getMonth() < 2) {
		years.push(currentYear);
		year = currentYear + 1;
	}

	while (years.length < count) {
		if (isLeapYear(year)) years.push(year);
		year++;
	}

	return years;
}

function getRecentLeapYears(count: number): number[] {
	const currentYear = new Date().getFullYear();
	const years: number[] = [];
	let year = currentYear;

	while (years.length < count) {
		if (isLeapYear(year)) years.push(year);
		year--;
	}

	return years;
}

const nextLeapYears = getNextLeapYears(8);
const recentLeapYears = getRecentLeapYears(8);
---

<Layout
	title="Leap Year Checker — Is This Year a Leap Year? | Clockr"
	description="Check if any year is a leap year instantly. Find the next leap year and learn why we have them. Free leap year calculator."
>
	<div class="ly-page">
		<!-- PAGE HEADER -->
		<div class="ly-header">
			<div class="ly-eyebrow">📅 Calendar & Dates</div>
			<h1 class="ly-title">
				<span class="ly-gradient">Leap Year Checker</span>
			</h1>
			<p class="ly-subtitle">
				Is this year a leap year? Find out instantly
			</p>
		</div>

		<!-- INPUT -->
		<div class="ly-input-wrap">
			<label class="ly-label" for="year-input">Enter a year</label>
			<input
				type="number"
				id="year-input"
				class="ly-input"
				placeholder="e.g. 2024"
				min="1"
				max="9999"
				inputmode="numeric"
			/>
		</div>

		<!-- RESULTS -->
		<div class="ly-results" id="ly-results" style="display:none">
			<div class="ly-main-card">
				<div class="ly-verdict" id="ly-verdict">YES</div>
				<div class="ly-summary" id="ly-summary"></div>
				<div class="ly-reason" id="ly-reason"></div>
			</div>
		</div>

		<!-- NEXT LEAP YEARS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Next leap years</h2>
			<div class="ly-grid">
				{
					nextLeapYears.map((year) => (
						<button
							type="button"
							class="ly-year-card"
							data-year={year}
						>
							<span class="ly-year-num">{year}</span>
						</button>
					))
				}
			</div>
		</div>

		<!-- RECENT LEAP YEARS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Recent leap years</h2>
			<div class="ly-grid">
				{
					recentLeapYears.map((year) => (
						<button
							type="button"
							class="ly-year-card"
							data-year={year}
						>
							<span class="ly-year-num">{year}</span>
						</button>
					))
				}
			</div>
		</div>

		<!-- FUN FACTS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Leap year fun facts</h2>
			<div class="ly-facts-grid">
				<div class="ly-fact-card">
					<div class="ly-fact-icon">🌍</div>
					<h3 class="ly-fact-title">What is a leap year?</h3>
					<p class="ly-fact-text">
						A leap year has 366 days instead of 365, with an extra day
						added to February. We need them because Earth's orbit takes
						roughly 365.25 days — without leap years, our calendar would
						drift and seasons would slowly shift out of place.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">🎂</div>
					<h3 class="ly-fact-title">Born on February 29th?</h3>
					<p class="ly-fact-text">
						The odds of being born on leap day are about 1 in 1,461 —
						that's the average number of days in four years (3 × 365 + 366).
						Only around 5 million people worldwide share a true February
						29th birthday.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">⭐</div>
					<h3 class="ly-fact-title">Famous leap day birthdays</h3>
					<p class="ly-fact-text">
						Notable February 29th babies include Pope Paul III (1468),
						composer Gioachino Rossini, rapper Ja Rule, motivational
						speaker Tony Robbins, and actor Antonio Sabàto Jr.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">📆</div>
					<h3 class="ly-fact-title">Leap day babies in non-leap years</h3>
					<p class="ly-fact-text">
						When there's no February 29th, most leap day babies celebrate
						on February 28th or March 1st — it's a personal choice. Some
						legally observe their birthday on the 28th; others wait for
						March 1st. Either way, they only get a "real" birthday every
						four years.
					</p>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
