		font-family: 'Outfit', sans-serif;
		font-size: 64px;
		font-weight: 900;
		letter-spacing: -3px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.ly-gradient {
		background: linear-gradient(135deg, #10b981, #84cc16);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
