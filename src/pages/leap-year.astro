---
import Layout from '../layouts/Layout.astro';

function isLeapYear(year: number): boolean {
	return (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;
}

function getNextLeapYears(count: number): number[] {
	const now = new Date();
	const currentYear = now.getFullYear();
	const years: number[] = [];
	let year = currentYear;

	if (isLeapYear(currentYear) && now.getMonth() < 2) {
		years.push(currentYear);
		year = currentYear + 1;
	}

	while (years.length < count) {
		if (isLeapYear(year)) years.push(year);
		year++;
	}

	return years;
}

function getRecentLeapYears(count: number): number[] {
	const currentYear = new Date().getFullYear();
	const years: number[] = [];
	let year = currentYear;

	while (years.length < count) {
		if (isLeapYear(year)) years.push(year);
		year--;
	}

	return years;
}

const nextLeapYears = getNextLeapYears(8);
const recentLeapYears = getRecentLeapYears(8);
---

<Layout
	title="Leap Year Checker — Is This Year a Leap Year? | Clockr"
	description="Check if any year is a leap year instantly. Find the next leap year and learn why we have them. Free leap year calculator."
>
	<div class="ly-page">
		<!-- PAGE HEADER -->
		<div class="ly-header">
			<div class="ly-eyebrow">📅 Calendar & Dates</div>
			<h1 class="ly-title">
				<span class="ly-gradient">Leap Year Checker</span>
			</h1>
			<p class="ly-subtitle">
				Is this year a leap year? Find out instantly
			</p>
		</div>

		<!-- INPUT -->
		<div class="ly-input-wrap">
			<label class="ly-label" for="year-input">Enter a year</label>
			<input
				type="number"
				id="year-input"
				class="ly-input"
				placeholder="e.g. 2024"
				min="1"
				max="9999"
				inputmode="numeric"
			/>
		</div>

		<!-- RESULTS -->
		<div class="ly-results" id="ly-results" style="display:none">
			<div class="ly-main-card">
				<div class="ly-verdict" id="ly-verdict">YES</div>
				<div class="ly-summary" id="ly-summary"></div>
				<div class="ly-reason" id="ly-reason"></div>
			</div>
		</div>

		<!-- NEXT LEAP YEARS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Next leap years</h2>
			<div class="ly-grid">
				{
					nextLeapYears.map((year) => (
						<button
							type="button"
							class="ly-year-card"
							data-year={year}
						>
							<span class="ly-year-num">{year}</span>
						</button>
					))
				}
			</div>
		</div>

		<!-- RECENT LEAP YEARS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Recent leap years</h2>
			<div class="ly-grid">
				{
					recentLeapYears.map((year) => (
						<button
							type="button"
							class="ly-year-card"
							data-year={year}
						>
							<span class="ly-year-num">{year}</span>
						</button>
					))
				}
			</div>
		</div>

		<!-- FUN FACTS -->
		<div class="ly-section">
			<h2 class="ly-section-title">Leap year fun facts</h2>
			<div class="ly-facts-grid">
				<div class="ly-fact-card">
					<div class="ly-fact-icon">🌍</div>
					<h3 class="ly-fact-title">What is a leap year?</h3>
					<p class="ly-fact-text">
						A leap year has 366 days instead of 365, with an extra day
						added to February. We need them because Earth's orbit takes
						roughly 365.25 days — without leap years, our calendar would
						drift and seasons would slowly shift out of place.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">🎂</div>
					<h3 class="ly-fact-title">Born on February 29th?</h3>
					<p class="ly-fact-text">
						The odds of being born on leap day are about 1 in 1,461 —
						that's the average number of days in four years (3 × 365 + 366).
						Only around 5 million people worldwide share a true February
						29th birthday.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">⭐</div>
					<h3 class="ly-fact-title">Famous leap day birthdays</h3>
					<p class="ly-fact-text">
						Notable February 29th babies include Pope Paul III (1468),
						composer Gioachino Rossini, rapper Ja Rule, motivational
						speaker Tony Robbins, and actor Antonio Sabàto Jr.
					</p>
				</div>
				<div class="ly-fact-card">
					<div class="ly-fact-icon">📆</div>
					<h3 class="ly-fact-title">Leap day babies in non-leap years</h3>
					<p class="ly-fact-text">
						When there's no February 29th, most leap day babies celebrate
						on February 28th or March 1st — it's a personal choice. Some
						legally observe their birthday on the 28th; others wait for
						March 1st. Either way, they only get a "real" birthday every
						four years.
					</p>
				</div>
			</div>
		</div>

		<!-- HOW IT WORKS -->
		<section class="ly-how">
			<h2 class="ly-section-title">How do you calculate a leap year?</h2>
			<div class="ly-how-card">
				<p>
					A leap year occurs when a year is divisible by 4. That extra day in
					February corrects for the fact that Earth takes approximately 365.25
					days to orbit the Sun — without leap years our calendar would drift
					by about 6 hours every year, and seasons would slowly shift out of
					place.
				</p>
				<p>
					There is an important exception: century years like 1800, 1900, and
					2100 are not leap years even though they are divisible by 4, because
					the solar year is slightly less than 365.25 days. However, years
					divisible by 400 — such as 1600, 2000, and 2400 — are leap years,
					restoring the balance over longer cycles.
				</p>
				<p>
					Leap years affect everyday life too. People born on February 29th,
					known as leaplings or leap day babies, technically only have a
					birthday every four years. In non-leap years they celebrate on either
					February 28th or March 1st depending on their country and personal
					preference.
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="ly-faq">
			<h2 class="ly-section-title">Frequently asked questions</h2>
			<div class="ly-faq-list">
				<details class="ly-faq-item">
					<summary class="ly-faq-question">Is 2026 a leap year?</summary>
					<div class="ly-faq-answer">
						<p>
							No — 2026 is not a leap year. It is not divisible by 4, so
							February 2026 has 28 days and the year has 365 days in total.
							Enter 2026 in the checker above to see the full explanation.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question">Is 2028 a leap year?</summary>
					<div class="ly-faq-answer">
						<p>
							Yes — 2028 is a leap year. It is divisible by 4 and is not a
							century year, so February 2028 will have 29 days and the year
							will have 366 days in total.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question">When is the next leap year?</summary>
					<div class="ly-faq-answer">
						<p>
							The next leap year is 2028. After that comes 2032, then 2036.
							The "Next leap years" grid above lists the upcoming leap years —
							click any year to check it instantly in the calculator.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question">Why do we have leap years?</summary>
					<div class="ly-faq-answer">
						<p>
							Earth takes roughly 365.25 days to orbit the Sun, but our calendar
							counts only 365 days per year. Without a leap day every four years,
							we would lose about 6 hours annually — adding up to roughly one
							extra day every four years. Leap years keep our calendar aligned
							with the seasons.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question"
						>What is a leap day baby called?</summary
					>
					<div class="ly-faq-answer">
						<p>
							People born on February 29th are called leaplings, leap day babies,
							or leap year babies. With odds of about 1 in 1,461, only around
							5 million people worldwide share a true February 29th birthday.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question">Was 2000 a leap year?</summary>
					<div class="ly-faq-answer">
						<p>
							Yes — 2000 was a leap year. Although it is a century year, 2000 is
							divisible by 400, which overrides the century rule. February 2000
							had 29 days.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question">Why is 1900 not a leap year?</summary>
					<div class="ly-faq-answer">
						<p>
							1900 is divisible by 4 and by 100, but not by 400. The leap year
							rule excludes century years unless they are also divisible by 400.
							So 1900 had only 365 days, even though 1896 and 1904 were both
							leap years.
						</p>
					</div>
				</details>
				<details class="ly-faq-item">
					<summary class="ly-faq-question"
						>How many leap years are there in 100 years?</summary
					>
					<div class="ly-faq-answer">
						<p>
							Most 100-year periods contain 24 leap years. A century normally
							has 25 years divisible by 4, but the century year itself is
							excluded unless divisible by 400 — removing one leap year. Periods
							that include a year like 2000 can have 25 leap years instead.
						</p>
					</div>
				</details>
			</div>
		</section>

		<!-- RELATED TOOLS -->
		<div class="ly-related">
			<h3 class="ly-related-title">You might also like</h3>
			<div class="ly-related-grid">
				<a href="/date-calculator" class="ly-related-card"
