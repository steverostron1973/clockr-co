<script>
	function isLeapYear(year: number): boolean {
		return (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;
	}

	function getLeapReason(year: number, leap: boolean): string {
		if (leap) {
			if (year % 400 === 0) {
				return `${year} is divisible by 400, so it is a leap year — century years divisible by 400 still get an extra day.`;
			}
			return `${year} is divisible by 4 and is not a century year, so it is a leap year.`;
		}
		if (year % 100 === 0) {
			return `${year} is divisible by 100 but not by 400 — century years are not leap years unless divisible by 400.`;
		}
		if (year % 4 !== 0) {
			return `${year} is not divisible by 4, so it is not a leap year.`;
		}
		return `${year} does not meet the leap year rules.`;
	}

	const yearInput = document.getElementById('year-input') as HTMLInputElement;
	const results = document.getElementById('ly-results');
	const verdictEl = document.getElementById('ly-verdict');
	const summaryEl = document.getElementById('ly-summary');
	const reasonEl = document.getElementById('ly-reason');

	function checkYear() {
		if (!yearInput || !results) return;

		const raw = yearInput.value.trim();
		if (!raw || !/^\d{1,4}$/.test(raw)) {
			results.style.display = 'none';
			return;
		}

		const year = parseInt(raw, 10);
		if (year < 1) {
			results.style.display = 'none';
			return;
		}

		const leap = isLeapYear(year);
		results.style.display = 'block';

		if (verdictEl) verdictEl.textContent = leap ? 'YES' : 'NO';
		if (summaryEl) {
			summaryEl.textContent = leap
				? `${year} is a leap year — it has 366 days`
				: `${year} is not a leap year — it has 365 days`;
		}
		if (reasonEl) reasonEl.textContent = getLeapReason(year, leap);
	}

	yearInput?.addEventListener('input', checkYear);

	document.querySelectorAll<HTMLButtonElement>('.ly-year-card').forEach((btn) => {
		btn.addEventListener('click', () => {
			const year = btn.dataset.year;
			if (year && yearInput) {
				yearInput.value = year;
				checkYear();
				yearInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
			}
		});
	});

	// Pre-fill current year on load
	if (yearInput) {
		yearInput.value = String(new Date().getFullYear());
		checkYear();
	}
</script>
