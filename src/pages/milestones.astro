---
import Layout from '../layouts/Layout.astro';

const tools = [
	{
		name: 'Your Life in Numbers',
		description: 'Days, hours and seconds alive',
		href: '/life-in-numbers',
		emoji: '⚡',
	},
	{
		name: 'Retirement Countdown Calculator',
		description: 'How long until you reach retirement age?',
		href: '/retirement-countdown-calculator',
		emoji: '🏖️',
	},
	{
		name: 'Anniversary Calculator',
		description: 'How long have you been together or married?',
		href: '/anniversary-calculator',
		emoji: '💍',
	},
	{
		name: 'What Generation Am I',
		description: 'Boomer, Millennial or Gen Z?',
		href: '/what-generation',
		emoji: '🧬',
	},
	{
		name: "How Many Days Until I'm X",
		description: "Find out when you'll reach any age",
		href: '/days-until-im-x',
		emoji: '🎯',
	},
];
---

<Layout
	title="Milestones — Life in Numbers, Retirement & More | Clockr"
	description="Your 10,000th day and beyond — life in numbers, retirement countdowns, anniversaries, generations and age milestones."
	category="milestones"
>
	<div class="ms-page">
		<div class="ms-header">
			<div class="ms-eyebrow">
				<span class="ms-eyebrow-square" aria-hidden="true"></span>
				MILESTONES
			</div>
			<h1 class="ms-title">
				<span class="ms-gradient">Milestones</span>
			</h1>
			<p class="ms-subtitle">Your 10,000th day and beyond</p>
		</div>

		<div class="ms-grid">
			{
				tools.map((item) => (
					<a href={item.href} class="ms-card">
						<span class="ms-card-emoji" aria-hidden="true">
							{item.emoji}
						</span>
						<span class="ms-card-name">{item.name}</span>
						<span class="ms-card-desc">{item.description}</span>
					</a>
				))
			}
		</div>

		<section class="ms-how">
			<h2 class="ms-section-title">About milestone tools</h2>
			<div class="ms-how-card">
				<p>
					From your 10,000th day alive to retirement age, wedding anniversaries,
					and which generation you belong to — these tools turn dates into
					meaningful milestones worth celebrating. Pick a card above to get
					started.
				</p>
			</div>
		</section>

		<div class="ms-related">
			<h3 class="ms-related-title">You might also like</h3>
			<div class="ms-related-grid">
				<a href="/age-birthdays" class="ms-related-card"
					><span class="ms-related-name">Age & Birthdays</span></a
				>
				<a href="/days-until-birthday" class="ms-related-card"
					><span class="ms-related-name">Days Until Birthday</span></a
				>
				<a href="/create-countdown" class="ms-related-card"
					><span class="ms-related-name">Create Your Own Countdown</span></a
				>
				<a href="/#all-tools" class="ms-related-card"
					><span class="ms-related-name">All tools</span></a
				>
			</div>
		</div>
	</div>
</Layout>

<style>
	.ms-page {
		max-width: 900px;
		margin: 0 auto;
		padding: 60px 24px 80px;
	}

	.ms-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.ms-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: 'Outfit', sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 3px;
		text-transform: uppercase;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
	}

	.ms-eyebrow-square {
		width: 8px;
		height: 8px;
		border-radius: 2px;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		flex-shrink: 0;
		-webkit-text-fill-color: initial;
	}

	.ms-title {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(36px, 6vw, 56px);
		font-weight: 900;
		letter-spacing: -2px;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.ms-gradient {
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.ms-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
		margin: 0;
		max-width: 540px;
		margin-inline: auto;
	}

	.ms-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 14px;
		margin-bottom: 56px;
	}

	@media (max-width: 640px) {
		.ms-grid {
			grid-template-columns: 1fr;
		}
	}

	.ms-card {
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: 14px;
		padding: 22px 20px;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.ms-card:hover {
		border-color: rgba(255, 92, 77, 0.45);
		transform: translateY(-3px);
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.35);
	}

	.ms-card-emoji {
		font-size: 28px;
		line-height: 1;
		margin-bottom: 4px;
	}

	.ms-card-name {
		font-family: 'Outfit', sans-serif;
		font-size: 17px;
		font-weight: 700;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.ms-card-desc {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.45);
		line-height: 1.5;
	}

	.ms-section-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ms-how {
		margin-bottom: 48px;
	}

	.ms-how-card {
		background: #0c0c0c;
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: 14px;
		padding: 24px;
	}

	.ms-how-card p {
		font-family: 'Inter', sans-serif;
		font-size: 15px;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1.7;
		margin: 0;
	}

	.ms-related {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 40px;
	}

	.ms-related-title {
		font-family: 'Outfit', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 16px;
	}

	.ms-related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	@media (max-width: 600px) {
		.ms-related-grid {
			grid-template-columns: 1fr;
		}
	}

	.ms-related-card {
		background: #0c0c0c;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 20px 16px;
		text-align: center;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.ms-related-card:hover {
		border-color: rgba(168, 85, 247, 0.4);
	}

	.ms-related-name {
		font-family: 'Outfit', sans-serif;
		font-size: 14px;
		font-weight: 600;
		background: linear-gradient(135deg, #a855f7, #ff5c4d);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
