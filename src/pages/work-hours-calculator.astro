<script>
	function parseTime(timeStr: string): number | null {
		if (!timeStr) return null;
		const parts = timeStr.split(':');
		if (parts.length < 2) return null;
		const h = Number(parts[0]);
		const m = Number(parts[1]);
		if (isNaN(h) || isNaN(m)) return null;
		return h * 60 + m;
	}

	function calcMinutes(
		startStr: string,
		endStr: string,
		breakMins: number,
	): { gross: number; net: number } | null {
		const start = parseTime(startStr);
		const end = parseTime(endStr);
		if (start === null || end === null) return null;

		let diff = end - start;
		if (diff <= 0) diff += 24 * 60;

		const brk = Math.max(0, breakMins || 0);
		const net = Math.max(0, diff - brk);
		return { gross: diff, net };
	}

	function toDecimal(mins: number): string {
		return (mins / 60).toFixed(2);
	}

	function toHHMM(mins: number): string {
		const h = Math.floor(mins / 60);
		const m = mins % 60;
		return `${h}:${String(m).padStart(2, '0')}`;
	}

	function formatCurrency(amount: number): string {
		return amount.toLocaleString('en-GB', {
			style: 'currency',
			currency: 'GBP',
			minimumFractionDigits: 2,
			maximumFractionDigits: 2,
		});
	}

	const startTime = document.getElementById('start-time') as HTMLInputElement;
	const endTime = document.getElementById('end-time') as HTMLInputElement;
	const breakMins = document.getElementById('break-mins') as HTMLInputElement;
	const hourlyRate = document.getElementById('hourly-rate') as HTMLInputElement;

	const totalDecimal = document.getElementById('total-decimal');
	const totalHhmm = document.getElementById('total-hhmm');
	const netDecimal = document.getElementById('net-decimal');
	const netHhmm = document.getElementById('net-hhmm');

	const payResults = document.getElementById('pay-results');
	const dailyPay = document.getElementById('daily-pay');
	const weeklyPay = document.getElementById('weekly-pay');
	const weeklyTotal = document.getElementById('weekly-total');
	const weeklyDecimal = document.getElementById('weekly-decimal');

	let dailyNetMins = 0;
	let weeklyNetMins = 0;

	function updateDaily() {
		const result = calcMinutes(
			startTime?.value ?? '',
			endTime?.value ?? '',
			Number(breakMins?.value) || 0,
		);

		if (!result) {
			dailyNetMins = 0;
			if (totalDecimal) totalDecimal.textContent = '—';
			if (totalHhmm) totalHhmm.textContent = '—';
			if (netDecimal) netDecimal.textContent = '—';
			if (netHhmm) netHhmm.textContent = '—';
			updatePay();
			return;
		}

		dailyNetMins = result.net;
		if (totalDecimal) totalDecimal.textContent = toDecimal(result.gross);
		if (totalHhmm) totalHhmm.textContent = toHHMM(result.gross);
		if (netDecimal) netDecimal.textContent = toDecimal(result.net);
		if (netHhmm) netHhmm.textContent = toHHMM(result.net);
		updatePay();
	}

	function updateTimesheet() {
		let weekTotal = 0;
		const starts = document.querySelectorAll<HTMLInputElement>('.whc-ts-start');
		const ends = document.querySelectorAll<HTMLInputElement>('.whc-ts-end');
		const breaks = document.querySelectorAll<HTMLInputElement>('.whc-ts-break');

		starts.forEach((startEl, i) => {
			const endEl = ends[i];
			const breakEl = breaks[i];
			const hoursCell = document.querySelector(
				`.whc-day-hours[data-day="${i}"]`,
			);

			if (!startEl.value || !endEl.value) {
				if (hoursCell) hoursCell.textContent = '—';
				return;
			}

			const result = calcMinutes(
				startEl.value,
				endEl.value,
				Number(breakEl?.value) || 0,
			);

			if (!result) {
				if (hoursCell) hoursCell.textContent = '—';
				return;
			}

			weekTotal += result.net;
			if (hoursCell) hoursCell.textContent = toHHMM(result.net);
		});

		weeklyNetMins = weekTotal;
		if (weeklyTotal) weeklyTotal.textContent = toHHMM(weekTotal);
		if (weeklyDecimal)
			weeklyDecimal.textContent = `${toDecimal(weekTotal)} hours`;
		updatePay();
	}

	function updatePay() {
		const rate = Number(hourlyRate?.value);
		const hasRate = hourlyRate?.value && rate > 0;

		if (!payResults) return;

		if (!hasRate) {
			payResults.style.display = 'none';
			return;
		}

		payResults.style.display = 'block';

		const dayAmount = (dailyNetMins / 60) * rate;
		const weekAmount = (weeklyNetMins / 60) * rate;

		if (dailyPay) dailyPay.textContent = formatCurrency(dayAmount);
		if (weeklyPay) weeklyPay.textContent = formatCurrency(weekAmount);
	}

	function bindInputs() {
		[startTime, endTime, breakMins, hourlyRate].forEach((el) => {
			el?.addEventListener('input', () => {
				updateDaily();
				if (el === hourlyRate) updatePay();
			});
			el?.addEventListener('change', () => {
				updateDaily();
				if (el === hourlyRate) updatePay();
			});
		});

		document
			.querySelectorAll<HTMLInputElement>(
				'.whc-ts-start, .whc-ts-end, .whc-ts-break',
			)
			.forEach((el) => {
				el.addEventListener('input', updateTimesheet);
				el.addEventListener('change', updateTimesheet);
			});
	}

	bindInputs();
	updateDaily();
	updateTimesheet();
</script>
